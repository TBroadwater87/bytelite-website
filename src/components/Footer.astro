<footer class="bg-gray-900 border-t border-gray-800 py-8">
  <div class="container mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">

      <!-- Company Info -->
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center space-x-2 mb-3">
          <img
            src="/bytelite-logo.png"
            alt="ByteLite"
            width="100"
            height="32"
            class="h-7 w-auto"
            loading="lazy"
            decoding="async"
          />
          <span class="text-base font-bold text-white">ByteLite</span>
        </div>
        <p class="text-gray-400 text-xs leading-relaxed mb-3">
          HeartStrings Play. ByteLite infrastructure. Deep Kore / AIya research. Products and platforms built by ByteLite LLC.
        </p>
        <p class="text-xs text-gray-500">Patent pending US 63/807,027</p>
      </div>

      <!-- Products -->
      <div>
        <h3 class="text-white text-xs font-semibold uppercase tracking-wider mb-3">Products</h3>
        <div class="space-y-1.5">
          <a href="/heartstrings" class="text-gray-400 hover:text-pink-400 text-xs block transition-colors">HeartStrings Play</a>
          <a href="/heartstrings-app" class="text-gray-400 hover:text-rose-400 text-xs block transition-colors">HeartStrings App</a>
          <a href="/technology" class="text-gray-400 hover:text-cyan-400 text-xs block transition-colors">ByteLite</a>
          <a href="/deepkore" class="text-gray-400 hover:text-purple-400 text-xs block transition-colors">Deep Kore / AIya</a>
          <a href="/demo" class="text-gray-400 hover:text-cyan-400 text-xs block transition-colors">Demos</a>
          <a href="/status" class="text-gray-400 hover:text-cyan-400 text-xs block transition-colors">Status</a>
        </div>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-white text-xs font-semibold uppercase tracking-wider mb-3">Company</h3>
        <div class="space-y-1.5">
          <a href="/about" class="text-gray-400 hover:text-cyan-400 text-xs block transition-colors">About</a>
          <a href="/research" class="text-gray-400 hover:text-cyan-400 text-xs block transition-colors">Research</a>
          <a href="/ethics" class="text-gray-400 hover:text-cyan-400 text-xs block transition-colors">Ethics</a>
          <a href="/ai-safety" class="text-gray-400 hover:text-cyan-400 text-xs block transition-colors">AI Safety</a>
          <a href="/licensing" class="text-gray-400 hover:text-cyan-400 text-xs block transition-colors">Enterprise</a>
          <a href="/contact" class="text-gray-400 hover:text-cyan-400 text-xs block transition-colors">Contact</a>
        </div>
      </div>

      <!-- Legal -->
      <div>
        <h3 class="text-white text-xs font-semibold uppercase tracking-wider mb-3">Legal</h3>
        <div class="space-y-1.5">
          <a href="/privacy" class="text-gray-400 hover:text-cyan-400 text-xs block transition-colors">Privacy</a>
          <a href="/terms" class="text-gray-400 hover:text-cyan-400 text-xs block transition-colors">Terms</a>
          <a href="/responsible-disclosure" class="text-gray-400 hover:text-cyan-400 text-xs block transition-colors">Responsible Disclosure</a>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-gray-800 mt-6 pt-5 flex flex-col sm:flex-row justify-between items-center gap-2">
      <p class="text-gray-500 text-xs">© 2026 ByteLite LLC · Helena, MT</p>
      <p class="text-gray-500 text-xs">Deterministic Engineering · Working Technology</p>
    </div>
  </div>
</footer>
