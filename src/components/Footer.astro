---

<footer class="site-footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <img src="/bytelite-logo.png" alt="ByteLite LLC" width="28" height="28" loading="lazy" />
        <span>ByteLite LLC</span>
      </a>
      <p class="footer-tagline">Privacy-first products and deterministic systems research from Helena, Montana.</p>
    </div>

    <div class="footer-col">
      <h4>Products / Research</h4>
      <a href="/heartstrings">HeartStrings Play</a>
      <a href="/heartstrings-app">HeartStrings App</a>
      <a href="/research">Research</a>
      <a href="/status">Status</a>
      <a href="/architecture">Architecture</a>
    </div>

    <div class="footer-col">
      <h4>Company</h4>
      <a href="/about">About</a>
      <a href="/contact">Contact</a>
    </div>

    <div class="footer-col">
      <h4>Legal</h4>
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/responsible-disclosure">Responsible Disclosure</a>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>&copy; 2026 ByteLite LLC &middot; Helena, Montana</p>
      <p>Privacy-first. Founder-led.</p>
    </div>
  </div>
</footer>

<style>
.site-footer {
  background: #07090f;
  border-top: 1px solid #1a2235;
  margin-top: auto;
}
.footer-inner {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 3rem; padding-top: 3.5rem; padding-bottom: 3rem;
}
@media (max-width: 900px) {
  .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
  .footer-brand { grid-column: 1 / -1; }
}
@media (max-width: 540px) {
  .footer-inner { grid-template-columns: 1fr; gap: 1.75rem; }
}
.footer-logo {
  display: flex; align-items: center; gap: .5rem;
  font-size: .9375rem; font-weight: 600; color: #e4e7f2; margin-bottom: .875rem;
}
.footer-logo img { border-radius: .25rem; }
.footer-logo:hover { color: #818cf8; }
.footer-tagline { font-size: .8125rem; color: #4a5068; line-height: 1.6; max-width: 280px; }
.footer-col h4 {
  font-size: .6875rem; font-weight: 600; letter-spacing: .1em;
  text-transform: uppercase; color: #4a5068; margin-bottom: 1rem;
}
.footer-col a {
  display: block; font-size: .875rem; color: #555e7a;
  margin-bottom: .625rem; transition: color .15s;
}
.footer-col a:hover { color: #818cf8; }
.footer-bottom {
  border-top: 1px solid #1a2235; padding: 1.25rem 0;
}
.footer-bottom-inner {
  display: flex; justify-content: space-between; align-items: center; gap: 1rem;
  flex-wrap: wrap;
}
.footer-bottom-inner p { font-size: .8125rem; color: #4a5068; }
@media (max-width: 540px) { .footer-bottom-inner { flex-direction: column; gap: .375rem; } }
</style>
