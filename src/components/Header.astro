---
const currentPath = Astro.url.pathname;
function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="site-header">
  <nav class="container nav-inner">
    <a href="/" class="nav-logo" aria-label="ByteLite LLC home">
      <img src="/bytelite-logo.png" alt="ByteLite LLC" width="32" height="32" />
      <span class="nav-logo-text">ByteLite LLC</span>
    </a>

    <div class="nav-links" id="navLinks">
      <a href="/" class:list={["nav-link", { active: isActive('/') }]}>Home</a>
      <a href="/heartstrings" class:list={["nav-link nav-link-pink", { active: isActive('/heartstrings') }]}>HeartStrings Play</a>
      <a href="/heartstrings-app" class:list={["nav-link", { active: isActive('/heartstrings-app') }]}>HeartStrings App</a>
      <a href="/research" class:list={["nav-link", { active: isActive('/research') }]}>Research</a>
      <a href="/status" class:list={["nav-link", { active: isActive('/status') }]}>Status</a>
      <a href="/about" class:list={["nav-link", { active: isActive('/about') }]}>About</a>
      <a href="/contact" class:list={["nav-link nav-link-cta", { active: isActive('/contact') }]}>Contact</a>
    </div>

    <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation" aria-expanded="false">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6" class="line-top" />
        <line x1="3" y1="12" x2="21" y2="12" class="line-mid" />
        <line x1="3" y1="18" x2="21" y2="18" class="line-bot" />
      </svg>
    </button>
  </nav>
</header>

<script>
  const toggle = document.getElementById('navToggle');
  const links = document.getElementById('navLinks');
  toggle?.addEventListener('click', () => {
    const open = links?.classList.toggle('nav-open');
    toggle.setAttribute('aria-expanded', String(!!open));
  });
  links?.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
    links.classList.remove('nav-open');
    toggle?.setAttribute('aria-expanded', 'false');
  }));
</script>

<style>
.site-header {
  position: sticky; top: 0; z-index: 100;
  background: rgba(7,9,15,.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid #1a2235;
}
.nav-inner {
  display: flex; align-items: center; justify-content: space-between;
  height: 4rem; gap: 2rem;
}
.nav-logo {
  display: flex; align-items: center; gap: .625rem; flex-shrink: 0;
}
.nav-logo img { border-radius: .25rem; }
.nav-logo-text {
  font-size: .9375rem; font-weight: 600; color: #e4e7f2;
  letter-spacing: -.01em;
}
.nav-logo:hover .nav-logo-text { color: #818cf8; }
.nav-links {
  display: flex; align-items: center; gap: .25rem;
}
.nav-link {
  display: block; padding: .5rem .875rem;
  font-size: .875rem; font-weight: 450; color: #7b829e;
  border-radius: .375rem; transition: color .15s, background .15s;
}
.nav-link:hover { color: #e4e7f2; background: rgba(255,255,255,.04); }
.nav-link.active { color: #e4e7f2; }
.nav-link-pink { color: #c4739a; }
.nav-link-pink:hover, .nav-link-pink.active { color: #f472b6; }
.nav-link-cta {
  background: rgba(99,102,241,.12); color: #818cf8;
  border: 1px solid rgba(99,102,241,.2);
}
.nav-link-cta:hover { background: #6366f1; color: #fff; }
.nav-link-cta.active { background: #6366f1; color: #fff; }
.nav-toggle {
  display: none; background: none; border: none;
  color: #7b829e; padding: .375rem; border-radius: .375rem;
}
.nav-toggle:hover { color: #e4e7f2; background: rgba(255,255,255,.05); }
@media (max-width: 900px) {
  .nav-toggle { display: flex; align-items: center; justify-content: center; }
  .nav-links {
    display: none; position: absolute; top: 4rem; left: 0; right: 0;
    background: #0d1120; border-bottom: 1px solid #1a2235;
    flex-direction: column; align-items: stretch; gap: 0; padding: .75rem 1rem;
  }
  .nav-links.nav-open { display: flex; }
  .nav-link { padding: .75rem 1rem; font-size: 1rem; border-radius: .5rem; }
}
</style>
