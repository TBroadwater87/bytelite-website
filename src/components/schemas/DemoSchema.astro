---
const siteUrl = 'https://www.thebytelite.com';

const webApplicationSchema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "ByteLite Compression Demo",
  "alternateName": "ByteLite Data Transformation Demo",
  "url": `${siteUrl}/demo`,
  "description": "Interactive demonstration of ByteLite's Bit Motion Encoding compression technology. Results observed in controlled tests on structured text corpora.",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Web Browser",
  "browserRequirements": "Requires JavaScript enabled",
  "permissions": "none",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "creator": {
    "@type": "Organization",
    "name": "ByteLite Technologies"
  },
  "featureList": [
    "Compression stage visualization (educational)",
    "Interactive BME encoding walkthrough",
    "Determinism checker",
    "BME architecture overview"
  ],
  "screenshot": [
    {
      "@type": "ImageObject",
      "url": `${siteUrl}/assets/screenshots/demo-interface.png`,
      "caption": "ByteLite Demo Interface"
    }
  ]
};

const videoObjectSchema = {
  "@context": "https://schema.org",
  "@type": "VideoObject",
  "name": "ByteLite Compression Technology Demo",
  "description": "Educational walkthrough of ByteLite compression stages. Controlled test results observed on structured text corpora.",
  "thumbnailUrl": `${siteUrl}/assets/video-thumbnail.jpg`,
  "uploadDate": "2024-01-15",
  "duration": "PT2M30S",
  "embedUrl": `${siteUrl}/demo/video-embed`,
  "contentUrl": `${siteUrl}/assets/videos/compression-demo.mp4`
};
---

<script type="application/ld+json" set:html={JSON.stringify([webApplicationSchema, videoObjectSchema])} />