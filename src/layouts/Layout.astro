---
export interface Props {
  title: string;
  description?: string;
  keywords?: string;
  canonical?: string;
  noindex?: boolean;
  ogImage?: string;
}

const {
  title,
  description = "ByteLite LLC builds privacy-first products and deterministic systems research from Helena, Montana.",
  keywords = "ByteLite LLC, HeartStrings Play, privacy-first products, deterministic systems research, Helena Montana",
  canonical,
  noindex = false,
  ogImage = "/bytelite-logo.png",
} = Astro.props;

const canonicalURL = canonical || Astro.url.href;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="ByteLite LLC" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/bytelite-logo.png" />
  <link rel="manifest" href="/site.webmanifest" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" />

  <!-- Cloudflare Beacon -->
  <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": ""}' is:inline></script>
</head>
<body>
  <slot name="header" />
  <main>
    <slot />
  </main>
  <slot name="footer" />
</body>
</html>

<style is:global>

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { font-size: 16px; scroll-behavior: smooth; }
body {
  background: #07090f;
  color: #e4e7f2;
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  line-height: 1.65;
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}
img { max-width: 100%; height: auto; display: block; }
a { color: inherit; text-decoration: none; }
button { cursor: pointer; font-family: inherit; }

/* Container */
.container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
@media (min-width: 768px) { .container { padding: 0 2rem; } }

/* Sections */
.section      { padding: 5rem 0; }
.section-sm   { padding: 3rem 0; }
.section-alt  { background: #0d1120; }
@media (max-width: 767px) { .section { padding: 3.5rem 0; } }

/* Typography */
h1 { font-size: clamp(2rem, 4.5vw, 3.25rem); font-weight: 700; line-height: 1.12; letter-spacing: -.02em; }
h2 { font-size: clamp(1.5rem, 3vw, 2.25rem); font-weight: 700; line-height: 1.18; letter-spacing: -.015em; }
h3 { font-size: clamp(1.1rem, 2.2vw, 1.5rem); font-weight: 600; line-height: 1.25; }
h4 { font-size: 1.125rem; font-weight: 600; }
p  { color: #a0a8c0; line-height: 1.7; }
.text-primary { color: #e4e7f2; }

/* Eyebrow */
.eyebrow {
  font-size: .75rem; font-weight: 600; letter-spacing: .12em;
  text-transform: uppercase; color: #6366f1; margin-bottom: .75rem;
}

/* Buttons */
.btn {
  display: inline-flex; align-items: center; gap: .5rem;
  padding: .75rem 1.75rem; border-radius: .5rem;
  font-size: .9375rem; font-weight: 500; transition: all .2s;
  border: none; white-space: nowrap;
}
.btn-primary  { background: #6366f1; color: #fff; }
.btn-primary:hover  { background: #4f52d1; transform: translateY(-1px); box-shadow: 0 4px 20px rgba(99,102,241,.35); }
.btn-pink     { background: #ec4899; color: #fff; }
.btn-pink:hover     { background: #db2777; transform: translateY(-1px); box-shadow: 0 4px 20px rgba(236,72,153,.35); }
.btn-outline  { background: transparent; color: #e4e7f2; border: 1px solid #1a2235; }
.btn-outline:hover  { border-color: #6366f1; color: #818cf8; }
.btn-ghost    { background: transparent; color: #7b829e; border: 1px solid #1a2235; }
.btn-ghost:hover    { color: #e4e7f2; border-color: #24304a; }
.btn-sm { padding: .5rem 1.25rem; font-size: .875rem; }

/* Status badges */
.badge {
  display: inline-flex; align-items: center;
  padding: .25rem .75rem; border-radius: 9999px;
  font-size: .75rem; font-weight: 500; white-space: nowrap;
}
.badge-prelaunch  { background: rgba(236,72,153,.12);  color: #f472b6; border: 1px solid rgba(236,72,153,.25); }
.badge-private    { background: rgba(99,102,241,.12);  color: #818cf8; border: 1px solid rgba(99,102,241,.25); }
.badge-research   { background: rgba(167,139,250,.12); color: #a78bfa; border: 1px solid rgba(167,139,250,.25); }
.badge-active     { background: rgba(52,211,153,.12);  color: #34d399; border: 1px solid rgba(52,211,153,.25); }
.badge-planned    { background: rgba(245,158,11,.12);  color: #fbbf24; border: 1px solid rgba(245,158,11,.25); }
.badge-none       { background: rgba(123,130,158,.1);  color: #7b829e; border: 1px solid rgba(123,130,158,.2); }

/* Cards */
.card {
  background: #0d1120; border: 1px solid #1a2235;
  border-radius: .75rem; padding: 1.75rem;
  transition: border-color .2s, box-shadow .2s;
}
.card:hover { border-color: #24304a; box-shadow: 0 4px 24px rgba(0,0,0,.25); }

/* Divider */
.divider { border: none; border-top: 1px solid #1a2235; margin: 0; }

</style>
