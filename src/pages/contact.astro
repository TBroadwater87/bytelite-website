---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact | ByteLite LLC"
  description="Contact ByteLite LLC about HeartStrings Play, private beta interest, partnerships, research inquiries, or investor conversations."
  keywords="Contact ByteLite LLC, HeartStrings inquiry, partnership, research inquiry"
  
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="ct-hero">
    <div class="container">
      <p class="eyebrow">Contact</p>
      <h1>Get in touch.</h1>
      <p class="ct-sub">
        HeartStrings pre-launch interest, app beta requests, research partnerships,
        and investor conversations are all welcome. Direct, no-middleman contact.
      </p>
    </div>
  </section>

  <!-- Contact grid -->
  <section class="section">
    <div class="container ct-grid">
      <!-- Form -->
      <div class="ct-form-area">
        <h2 style="margin-bottom:1.75rem;">Send a message.</h2>
        <form class="ct-form" action="#" method="POST">
          <div class="ct-field">
            <label for="ct-name">Name</label>
            <input type="text" id="ct-name" name="name" placeholder="Your name" required />
          </div>
          <div class="ct-field">
            <label for="ct-email">Email</label>
            <input type="email" id="ct-email" name="email" placeholder="you@example.com" required />
          </div>
          <div class="ct-field">
            <label for="ct-subject">Inquiry type</label>
            <select id="ct-subject" name="subject">
              <option value="">Select an inquiry type</option>
              <option value="heartstrings-play">HeartStrings Play — pre-launch interest</option>
              <option value="heartstrings-app">HeartStrings App — beta interest</option>
              <option value="partnership">Partnership inquiry</option>
              <option value="research">Research inquiry</option>
              <option value="architecture">Architecture / Research inquiry</option>
              <option value="investor">Investor inquiry</option>
              <option value="general">General</option>
            </select>
          </div>
          <div class="ct-field">
            <label for="ct-message">Message</label>
            <textarea id="ct-message" name="message" rows="5" placeholder="Your message..." required></textarea>
          </div>
          <button type="submit" class="btn btn-primary ct-submit">Send Message</button>
          <p class="ct-note">Your message is sent directly. No CRM. No automated tracking.</p>
        </form>
      </div>

      <!-- Info -->
      <div class="ct-info">
        <div class="card ct-info-card">
          <h4 style="color:#e4e7f2;margin-bottom:.875rem;">Inquiry Categories</h4>
          <div class="ct-categories">
            <div class="ct-cat"><span class="ct-cat-dot" style="background:#f472b6;"></span>HeartStrings Play pre-launch interest</div>
            <div class="ct-cat"><span class="ct-cat-dot" style="background:#818cf8;"></span>HeartStrings App beta access</div>
            <div class="ct-cat"><span class="ct-cat-dot" style="background:#6366f1;"></span>Partnership discussions</div>
            <div class="ct-cat"><span class="ct-cat-dot" style="background:#a78bfa;"></span>Research inquiries</div>
            <div class="ct-cat"><span class="ct-cat-dot" style="background:#818cf8;"></span>Architecture / Research inquiry</div>
            <div class="ct-cat"><span class="ct-cat-dot" style="background:#34d399;"></span>Investor conversations</div>
            <div class="ct-cat"><span class="ct-cat-dot" style="background:#4a5068;"></span>General inquiries</div>
          </div>
        </div>
        <div class="card ct-info-card">
          <h4 style="color:#e4e7f2;margin-bottom:.875rem;">Location</h4>
          <p style="font-size:.9375rem;">ByteLite LLC<br/>Helena, Montana, USA</p>
        </div>
        <div class="card ct-info-card">
          <h4 style="color:#e4e7f2;margin-bottom:.875rem;">Response time</h4>
          <p style="font-size:.9375rem;color:#7b829e;">Direct messages are responded to personally. Typical response within 1–3 business days.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>

.ct-hero { padding: 5.5rem 0 4rem; }
.ct-hero h1 { max-width: 480px; }
.ct-sub { max-width: 560px; margin-top: 1rem; font-size: 1.0625rem; color: #7b829e; line-height: 1.75; }
.ct-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 4rem; align-items: start; }
@media (max-width: 900px) { .ct-grid { grid-template-columns: 1fr; gap: 3rem; } }
.ct-form { display: flex; flex-direction: column; gap: 1.25rem; }
.ct-field { display: flex; flex-direction: column; gap: .4rem; }
.ct-field label { font-size: .875rem; font-weight: 500; color: #a0a8c0; }
.ct-field input, .ct-field select, .ct-field textarea {
  background: #0d1120; border: 1px solid #1a2235;
  border-radius: .5rem; padding: .75rem 1rem;
  color: #e4e7f2; font-family: inherit; font-size: .9375rem;
  transition: border-color .15s;
  -webkit-appearance: none;
}
.ct-field input::placeholder, .ct-field textarea::placeholder { color: #4a5068; }
.ct-field input:focus, .ct-field select:focus, .ct-field textarea:focus {
  outline: none; border-color: #6366f1; box-shadow: 0 0 0 3px rgba(99,102,241,.12);
}
.ct-field select option { background: #0d1120; }
.ct-field textarea { resize: vertical; min-height: 120px; }
.ct-submit { width: 100%; justify-content: center; padding: .875rem; }
.ct-note { font-size: .8125rem; color: #4a5068; text-align: center; }
.ct-info { display: flex; flex-direction: column; gap: 1.25rem; }
.ct-info-card { padding: 1.5rem; }
.ct-info-card p { color: #7b829e; line-height: 1.6; }
.ct-categories { display: flex; flex-direction: column; gap: .625rem; }
.ct-cat { display: flex; align-items: center; gap: .75rem; font-size: .9375rem; color: #a0a8c0; }
.ct-cat-dot { width: .625rem; height: .625rem; border-radius: 50%; flex-shrink: 0; }

</style>
