---
import Layout from '../layouts/Layout.astro';

// Build info baked at Astro build time from actual DeepKore_Final artifacts
const BUILD_DATE = '2026-04-18';
const BUILD_RUNTIME = 'AIya_chat.exe -- MSVC, C++17, Windows x64, AVX2';
const TESTS_PASSING = 703;
const LAST_NIGHTLY = '2026-04-18 04:00 MT';
---

<Layout
  title="Deep Kore Lab - ByteLite LLC"
  description="Deep Kore Lab: submit prompts to the AIya learning corpus. Deterministic daily build. Nightly learning updates. Interactions are logged. Do not submit sensitive data."
  keywords={["Deep Kore Lab", "AIya", "deterministic AI", "knowledge base", "nightly learning", "ByteLite research"]}
  schemaType="Article"
>
  <section class="lab-hero">
    <div class="container">
      <div class="hero-top">
        <span class="lab-badge">Deep Kore Lab</span>
        <div class="build-strip">
          <span class="build-item"><span class="build-label">Build</span> {BUILD_DATE}</span>
          <span class="build-sep">|</span>
          <span class="build-item"><span class="build-label">Tests</span> {TESTS_PASSING} passing</span>
          <span class="build-sep">|</span>
          <span class="build-item"><span class="build-label">Last nightly</span> {LAST_NIGHTLY}</span>
          <span class="build-sep">|</span>
          <span class="build-item deploy-warn"><span class="build-label">Public API</span> pending deployment</span>
        </div>
      </div>
      <h1 class="lab-title">AIya -- Deep Kore Lab</h1>
      <p class="lab-sub">
        Submit prompts to the AIya learning corpus. Deterministic daily build. Updated nightly.
      </p>

      <!-- Deployment blocker notice -->
      <div class="blocker-notice">
        <div class="blocker-icon">!</div>
        <div class="blocker-body">
          <strong>Public runtime not yet deployed.</strong>
          The Deep Kore / AIya runtime (<code>AIya_chat.exe</code>) is a deterministic C++ knowledge-base system
          running locally on a Windows machine. It requires a backend server to serve live responses publicly.
          That deployment step has not yet been completed.
          <br><br>
          What you can do today: submit prompts to the learning queue. They will be processed during the next
          nightly local build. Come back tomorrow -- if the nightly build ran, the knowledge state may have changed.
          This is the real model.
        </div>
      </div>
    </div>
  </section>

  <section class="lab-body">
    <div class="container">
      <div class="lab-grid">

        <!-- Left: Prompt form -->
        <div class="lab-left">
          <div class="panel">
            <h2 class="panel-title">Submit to Learning Queue</h2>
            <p class="panel-desc">
              The site is deployed as a static build with no backend server. Submissions are logged
              to your browser's localStorage. A backend server is required for persistent corpus
              submission to the nightly learning pipeline. This is the exact blocker described above.
            </p>

            <div class="warning-box">
              Do not submit sensitive, confidential, or personal information.
              When the backend deploys, submissions will be used in nightly learning updates.
              This is a public research environment, not a consumer service.
            </div>

            <form id="labForm" class="lab-form" novalidate>
              <label for="promptInput" class="form-label">Your prompt</label>
              <textarea
                id="promptInput"
                name="prompt"
                class="form-textarea"
                placeholder="What is ByteLite? / What is a compression algorithm? / What is HeartStrings?"
                maxlength="500"
                rows="4"
                required
              ></textarea>
              <div class="char-counter"><span id="charCount">0</span> / 500</div>
              <button type="submit" class="submit-btn" id="submitBtn">
                Log to browser session
              </button>
            </form>

            <div id="labResponse" class="lab-response hidden"></div>
          </div>

          <!-- What AIya actually is -->
          <div class="panel panel--dim">
            <h3 class="panel-title-sm">What AIya Actually Is</h3>
            <div class="system-facts">
              <div class="fact-row">
                <span class="fact-key">Architecture</span>
                <span class="fact-val">Deterministic C++ knowledge-base system</span>
              </div>
              <div class="fact-row">
                <span class="fact-key">Not</span>
                <span class="fact-val">A large language model. Does not generate, hallucinate, or guess.</span>
              </div>
              <div class="fact-row">
                <span class="fact-key">Response rule</span>
                <span class="fact-val">KNOWN state only. UNKNOWN and UNSAFE produce no answer.</span>
              </div>
              <div class="fact-row">
                <span class="fact-key">Determinism</span>
                <span class="fact-val">Same input + same build = identical output. Proven across 299 closed-loop tests.</span>
              </div>
              <div class="fact-row">
                <span class="fact-key">Knowledge states</span>
                <span class="fact-val">KNOWN / UNKNOWN / AMBIGUOUS / UNSAFE / NEEDS_SOURCE</span>
              </div>
              <div class="fact-row">
                <span class="fact-key">Runtime</span>
                <span class="fact-val">{BUILD_RUNTIME}</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Right: Build info and nightly model -->
        <div class="lab-right">

          <!-- Nightly learning model -->
          <div class="panel">
            <h3 class="panel-title-sm">How the Nightly Model Works</h3>
            <ol class="nightly-steps">
              <li>
                <span class="step-num">1</span>
                <div class="step-body">
                  <strong>During the day</strong>
                  The current build is frozen. Same input produces identical output. This is architectural, not accidental.
                </div>
              </li>
              <li>
                <span class="step-num">2</span>
                <div class="step-body">
                  <strong>At night</strong>
                  Submitted prompts are included in the learning corpus and processed by the local runtime.
                  Structural learning, term learning, and response analysis may update the next build.
                </div>
              </li>
              <li>
                <span class="step-num">3</span>
                <div class="step-body">
                  <strong>Truth separation</strong>
                  Website interactions are used for structural and language learning only.
                  They do NOT automatically become factual truth. Truth promotion is a separate governed process.
                </div>
              </li>
              <li>
                <span class="step-num">4</span>
                <div class="step-body">
                  <strong>Visible evolution</strong>
                  When the public runtime deploys, you will be able to compare yesterday's response vs today's.
                  The build date shown above changes when the nightly build runs.
                </div>
              </li>
            </ol>
          </div>

          <!-- Build state -->
          <div class="panel panel--dim">
            <h3 class="panel-title-sm">Current Build State</h3>
            <div class="build-state-grid">
              <div class="bs-row">
                <span class="bs-key">Build date</span>
                <span class="bs-val">{BUILD_DATE}</span>
              </div>
              <div class="bs-row">
                <span class="bs-key">Regression tests</span>
                <span class="bs-val pass-val">{TESTS_PASSING} / {TESTS_PASSING} passing</span>
              </div>
              <div class="bs-row">
                <span class="bs-key">Closed-loop tests</span>
                <span class="bs-val pass-val">299 / 299 passing</span>
              </div>
              <div class="bs-row">
                <span class="bs-key">Invariant engine</span>
                <span class="bs-val pass-val">240 / 240 passing</span>
              </div>
              <div class="bs-row">
                <span class="bs-key">Deployment status</span>
                <span class="bs-val warn-val">Local only -- public API pending</span>
              </div>
              <div class="bs-row">
                <span class="bs-key">Last nightly</span>
                <span class="bs-val">{LAST_NIGHTLY}</span>
              </div>
            </div>
          </div>

          <!-- What AIya knows (from offline corpus) -->
          <div class="panel panel--dim">
            <h3 class="panel-title-sm">Verified Known Topics (offline corpus)</h3>
            <p class="panel-subdesc">These queries return KNOWN state in the current build.</p>
            <div class="known-chips">
              <span class="chip chip-known">CPU</span>
              <span class="chip chip-known">GPU</span>
              <span class="chip chip-known">RAM</span>
              <span class="chip chip-known">ByteLite</span>
              <span class="chip chip-known">compression</span>
              <span class="chip chip-known">Deep Kore</span>
              <span class="chip chip-known">HeartStrings</span>
            </div>
            <p class="panel-subdesc mt-sm">
              Queries outside the corpus return UNKNOWN state. No hallucination. No guess.
              This is the architecture, not a limitation to be papered over.
            </p>
          </div>

          <!-- Deployment blocker detail -->
          <div class="panel panel--wire">
            <h3 class="panel-title-sm">Public API Deployment Blocker</h3>
            <div class="blocker-detail-rows">
              <div class="bd-row">
                <span class="bd-key">Runtime</span>
                <span class="bd-val"><code>AIya_chat.exe</code> -- Windows PE32+</span>
              </div>
              <div class="bd-row">
                <span class="bd-key">Interface</span>
                <span class="bd-val">stdin / stdout CLI only -- no HTTP wrapper</span>
              </div>
              <div class="bd-row">
                <span class="bd-key">Hosting</span>
                <span class="bd-val">Cloudflare Pages -- V8 isolates, cannot execute PE binaries</span>
              </div>
              <div class="bd-row">
                <span class="bd-key">Required</span>
                <span class="bd-val">Windows backend server + HTTP wrapper around CLI</span>
              </div>
              <div class="bd-row">
                <span class="bd-key">Status</span>
                <span class="bd-val warn-val">Not yet deployed</span>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- CTA row -->
      <div class="lab-cta-row">
        <a href="/deepkore" class="cta-link cta-link--purple">Deep Kore research --></a>
        <a href="/status" class="cta-link cta-link--dim">Status board --></a>
        <a href="/ethics" class="cta-link cta-link--dim">Ethics and governance --></a>
      </div>

    </div>
  </section>
</Layout>

<script>
  // ARCHITECTURE NOTE:
  // The site is deployed as a static build (no backend server adapter configured).
  // POST API routes cannot execute server-side in this configuration.
  // Submissions are logged to browser localStorage only.
  // A backend server deployment is required for persistent corpus logging.
  // This is the exact same blocker described on the page.

  const DK_LOG_KEY = 'dk_submission_log';
  const BUILD_DATE = '2026-04-18';

  function fnv32(s: string): string {
    let h = 0x811c9dc5;
    for (let i = 0; i < s.length; i++) {
      h ^= s.charCodeAt(i);
      h = (Math.imul(h, 0x01000193) >>> 0);
    }
    return h.toString(16).padStart(8, '0');
  }

  function logSubmission(prompt: string): string {
    const id = `dk-${fnv32(prompt + Date.now())}`;
    try {
      const existing = JSON.parse(localStorage.getItem(DK_LOG_KEY) ?? '[]') as Array<{ id: string; prompt: string; ts: number }>;
      existing.push({ id, prompt, ts: Date.now() });
      localStorage.setItem(DK_LOG_KEY, JSON.stringify(existing.slice(-50)));
    } catch { /* localStorage may be unavailable */ }
    return id;
  }

  const form = document.getElementById('labForm') as HTMLFormElement | null;
  const textarea = document.getElementById('promptInput') as HTMLTextAreaElement | null;
  const charCount = document.getElementById('charCount');
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement | null;
  const responseEl = document.getElementById('labResponse');

  textarea?.addEventListener('input', () => {
    const len = textarea.value.length;
    if (charCount) charCount.textContent = String(len);
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const prompt = textarea?.value.trim() ?? '';
    if (!prompt || prompt.length < 2) return;

    if (submitBtn) submitBtn.disabled = true;

    const id = logSubmission(prompt);

    if (responseEl) {
      responseEl.classList.remove('hidden', 'response-error');
      responseEl.classList.add('response-ok');
      responseEl.innerHTML = `
        <div class="resp-header">
          <span class="resp-status-badge">Logged</span>
          <span class="resp-id">${id}</span>
        </div>
        <p class="resp-msg">Saved to browser session log.</p>
        <p class="resp-note">
          The site is deployed as a static build. A backend server is required for persistent corpus
          submission. This prompt is stored in your browser's localStorage (key: dk_submission_log).
          When the backend server deploys, you can resubmit or the local log format will be compatible.
        </p>
        <p class="resp-build">Build: ${BUILD_DATE}</p>
      `;
    }

    if (submitBtn) {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Submit another';
    }

    if (textarea) textarea.value = '';
    if (charCount) charCount.textContent = '0';
  });
</script>

