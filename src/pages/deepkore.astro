  @media (max-width: 768px) {
    .aiya-tabs { gap: 0.3rem; }
    .aiya-tab { font-size: 0.72rem; padding: 0.45rem 0.65rem; }
  }
</style>

<script>
  // ===== AIya Tab Gallery =====
  const tabs = document.querySelectorAll('.aiya-tab');
  const panels = document.querySelectorAll('.aiya-panel');

  const governanceStates = [
    {
      inputClass: 'Research inquiry (default)',
      responseMode: 'Structured explanation',
      knowledgeSource: 'Deep Kore research scope',
      result: 'Approved - within scope',
      resultClass: 'gov-approved',
      outputStyle: 'Plain-English technical',
    },
    {
      inputClass: 'Comparative technical question',
      responseMode: 'Structured comparison',
      knowledgeSource: 'ByteLite technical scope',
      result: 'Approved - within scope',
      resultClass: 'gov-approved',
      outputStyle: 'Technical prose',
    },
    {
      inputClass: 'Out-of-scope request',
      responseMode: 'Safety redirect',
      knowledgeSource: 'Governance framework',
      result: 'Redirected - out of scope',
      resultClass: 'gov-redirected',
      outputStyle: 'Structured refusal',
    },
    {
      inputClass: 'Technical research question',
      responseMode: 'Deterministic reasoning walkthrough',
      knowledgeSource: 'ByteLite architecture scope',
      result: 'Approved - within scope',
      resultClass: 'gov-approved',
      outputStyle: 'Step-by-step technical',
    },
  ];

  function updateGovernancePanel(index) {
    const state = governanceStates[index];
    if (!state) return;
    const setField = (id, value, cls) => {
      const el = document.getElementById(id);
      if (!el) return;
      el.textContent = value;
      el.className = 'gov-value' + (cls ? ' ' + cls : '');
    };
    setField('gov-input-class', state.inputClass);
    setField('gov-response-mode', state.responseMode);
    setField('gov-knowledge-source', state.knowledgeSource);
    setField('gov-result', state.result, state.resultClass);
    setField('gov-output-style', state.outputStyle);
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const tabIndex = parseInt(tab.getAttribute('data-tab') || '0', 10);

      tabs.forEach((t) => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach((p) => p.classList.remove('active'));

      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');

      const targetPanel = document.getElementById('aiya-panel-' + tabIndex);
      if (targetPanel) targetPanel.classList.add('active');

      updateGovernancePanel(tabIndex);
    });
  });

  // ===== AIya Mini Sandbox =====
  const sandboxResponses = [
    'ByteLite is a deterministic lossless compression system using Bit Motion Encoding over the Sigma-9 alphabet, achieving extreme payload convergence on structured text corpora in controlled tests.',
    'Deep Kore investigates whether the recursive mathematical structures in extreme compression share properties with computational cognition architectures. It is blueprint-stage research, unproven until tested, and governed by the Genesis Goal Keeper safety framework.',
    'HeartStrings Play is a physical board game with a six-tier emotional card progression, guide characters AIya and AIon, and a token-based mechanics system. It is the first public launch product from ByteLite LLC. A companion app called HeartStrings App is in development alongside the physical game.',
    'AIya is a structured response interface for Deep Kore research interaction. The current public version serves curated, deterministic responses within a defined scope. It is not an unconstrained language model. It is an Interactive Preview of the planned AIya interface layer.',
  ];

  const sandboxBtns = document.querySelectorAll('.sandbox-btn');
  const sandboxResponse = document.getElementById('sandbox-response');

  sandboxBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const promptIndex = parseInt(btn.getAttribute('data-prompt') || '0', 10);

      sandboxBtns.forEach((b) => b.classList.remove('selected'));
      btn.classList.add('selected');

      if (sandboxResponse) {
        sandboxResponse.innerHTML = '';
        const text = document.createTextNode(sandboxResponses[promptIndex] || '');
        sandboxResponse.appendChild(text);
      }
    });
  });
</script>
