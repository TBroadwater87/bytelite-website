---
import Layout from '../layouts/Layout.astro';
import InteractiveCompressionDemo from '../components/InteractiveCompressionDemo.tsx';
---

<Layout
  title="Demos - ByteLite Public Lab"
  description="The public-facing lab for ByteLite, Deep Kore / AIya, and HeartStrings. Every demo is labeled with its actual availability."
  keywords={["compression demo", "ByteLite demo", "AIya demo", "HeartStrings demo", "Deep Kore demo", "interactive preview", "ByteLite public lab"]}
  schemaType="WebApplication"
>

  <!-- HERO -->
  <section class="lab-hero">
    <div class="container">
      <h1 class="hero-title">ByteLite Public Lab. Try it.</h1>
      <p class="hero-sub">Every demo is labeled with its actual availability. No hype.</p>
      <div class="legend-row">
        <span class="badge badge-live">Live</span><span class="leg-txt">production</span>
        <span class="badge badge-preview">Interactive Preview</span><span class="leg-txt">functional prototype</span>
        <span class="badge badge-indev">In Development</span><span class="leg-txt">not yet public</span>
      </div>
    </div>
  </section>

  <section class="lab-body">
    <div class="container">

      <!-- BYTELITE -->
      <div class="product-section" id="bytelite">
        <div class="prod-header prod-header--cyan">
          <h2>ByteLite</h2>
          <span class="prod-note">Browser-local. No data leaves your device.</span>
        </div>

        <InteractiveCompressionDemo client:load />

        <div class="notice">
          <strong>Demo data handling:</strong> Files are processed in your browser only. Nothing is uploaded or stored. Do not upload sensitive or personal data. Educational use only.
        </div>

        <div class="card-grid">
          <div class="card">
            <div class="card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3>Stage Visualizer</h3>
            </div>
            <p>Dictionary cascade stages. Pedagogical representation of the compression pipeline.</p>
            <a href="/technology" class="card-link card-link--cyan">View on technology page -></a>
          </div>
          <div class="card">
            <div class="card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3>Determinism Checker</h3>
            </div>
            <p>Same input, same output. Sample proof of identical outputs from identical inputs.</p>
            <a href="/technology" class="card-link card-link--cyan">View on technology page -></a>
          </div>
          <div class="card">
            <div class="card-top">
              <span class="badge badge-indev">In Development</span>
              <h3>Developer API</h3>
            </div>
            <p>Planned ByteLite API integration interface. Enterprise partnerships available now.</p>
            <a href="/contact" class="card-link card-link--cyan">Contact for access -></a>
          </div>
        </div>
      </div>

      <!-- DEEP KORE / AIya -->
      <div class="product-section" id="deepkore">
        <div class="prod-header prod-header--purple">
          <h2>Deep Kore / AIya</h2>
          <span class="prod-note">Research architecture previews and curated AIya interaction samples.</span>
        </div>
        <div class="card-grid">
          <div class="card">
            <div class="card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3>AIya Conversation Gallery</h3>
            </div>
            <p>Four curated sample conversations showing how AIya responds across different query types.</p>
            <a href="/deepkore#aiya-gallery" class="card-link card-link--purple">Explore -></a>
          </div>
          <div class="card">
            <div class="card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3>AIya Sandbox</h3>
            </div>
            <p>Preset prompts, deterministic responses. Not live AI generation.</p>
            <a href="/deepkore#aiya-sandbox" class="card-link card-link--purple">Try it -></a>
          </div>
          <div class="card">
            <div class="card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3>Governance Panel</h3>
            </div>
            <p>Genesis Goal Keeper governance metadata for each response category.</p>
            <a href="/deepkore#governance" class="card-link card-link--purple">View -></a>
          </div>
        </div>
      </div>

      <!-- HEARTSTRINGS -->
      <div class="product-section" id="heartstrings">
        <div class="prod-header prod-header--pink">
          <h2>HeartStrings</h2>
          <span class="prod-note">Interface prototypes and compatibility framework previews.</span>
        </div>
        <div class="card-grid">
          <div class="card">
            <div class="card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3>Interface Gallery</h3>
            </div>
            <p>Mock UI panels: profile cards, match view, conversation screen, settings, safety tools.</p>
            <a href="/heartstrings#interface-gallery" class="card-link card-link--pink">Explore -></a>
          </div>
          <div class="card">
            <div class="card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3>Prototype Flow</h3>
            </div>
            <p>Step through the experience: profile, compatibility, match explanation, conversation starters.</p>
            <a href="/heartstrings#prototype-flow" class="card-link card-link--pink">Try it -></a>
          </div>
          <div class="card">
            <div class="card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3>Match Explanation</h3>
            </div>
            <p>Why a match scores where it does. Fully transparent rationale breakdown.</p>
            <a href="/heartstrings#match-explanation" class="card-link card-link--pink">View -></a>
          </div>
        </div>
      </div>

      <!-- COMPACT CTA -->
      <div class="bottom-cta">
        <a href="/status" class="cta-link">Full status board -></a>
      </div>

    </div>
  </section>
</Layout>

<style>
  .lab-hero {
    padding: 3.5rem 0 2.5rem;
    background: var(--color-bg-darker);
    text-align: center;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .hero-title {
    font-size: 2.75rem;
    font-weight: 800;
    margin: 0 0 0.6rem;
    background: linear-gradient(135deg, #00D4FF 0%, #A855F7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: var(--color-text-dim);
    margin: 0 0 1.5rem;
  }

  .legend-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    justify-content: center;
    align-items: center;
    font-size: 0.8rem;
  }

  .leg-txt {
    color: var(--color-text-dim);
    margin-right: 0.5rem;
  }

  .lab-body {
    padding: 3rem 0 5rem;
    background: var(--color-bg-darker);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Badges */
  .badge {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.18rem 0.6rem;
    border-radius: 20px;
    white-space: nowrap;
    border: 1px solid;
  }

  .badge-live {
    background: rgba(34,197,94,0.12);
    color: #22C55E;
    border-color: rgba(34,197,94,0.35);
  }

  .badge-preview {
    background: rgba(0,212,255,0.08);
    color: #00D4FF;
    border-color: rgba(0,212,255,0.3);
  }

  .badge-indev {
    background: rgba(168,85,247,0.08);
    color: #A855F7;
    border-color: rgba(168,85,247,0.3);
  }

  /* Product sections */
  .product-section {
    margin-bottom: 5rem;
  }

  .prod-header {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 2rem;
    padding-bottom: 0.85rem;
    border-bottom: 2px solid;
    flex-wrap: wrap;
  }

  .prod-header h2 {
    font-size: 1.6rem;
    font-weight: 800;
    margin: 0;
  }

  .prod-note {
    font-size: 0.875rem;
    color: var(--color-text-dim);
  }

  .prod-header--cyan { border-color: #00D4FF; }
  .prod-header--cyan h2 { color: #00D4FF; }
  .prod-header--purple { border-color: #A855F7; }
  .prod-header--purple h2 { color: #A855F7; }
  .prod-header--pink { border-color: #EC4899; }
  .prod-header--pink h2 { color: #EC4899; }

  /* Demo notice */
  .notice {
    background: rgba(10,14,39,0.7);
    border: 1px solid rgba(168,85,247,0.25);
    border-radius: 8px;
    padding: 0.85rem 1.25rem;
    margin: 1.5rem 0 2.5rem;
    font-size: 0.85rem;
    color: var(--color-text-dim);
    max-width: 680px;
  }

  .notice strong {
    color: var(--color-text);
  }

  /* Cards */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .card {
    background: rgba(10,14,39,0.65);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 10px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    transition: border-color 0.2s ease;
  }

  .card:hover {
    border-color: rgba(255,255,255,0.15);
  }

  .card-top {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .card h3 {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    line-height: 1.3;
  }

  .card p {
    font-size: 0.84rem;
    color: var(--color-text-dim);
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }

  .card-link {
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    margin-top: auto;
    transition: opacity 0.2s ease;
  }

  .card-link:hover { opacity: 0.75; }
  .card-link--cyan { color: #00D4FF; }
  .card-link--purple { color: #A855F7; }
  .card-link--pink { color: #EC4899; }

  /* Bottom CTA */
  .bottom-cta {
    text-align: center;
    padding: 2rem 0 0;
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  .cta-link {
    font-size: 1rem;
    font-weight: 600;
    color: #00D4FF;
    text-decoration: none;
    border-bottom: 1px solid rgba(0,212,255,0.3);
    transition: border-color 0.2s ease;
  }

  .cta-link:hover {
    border-color: #00D4FF;
  }

  /* Interactive compression demo globals */
  :global(.compression-demo) {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  :global(.upload-zone) {
    background: linear-gradient(135deg, rgba(0,212,255,0.05), rgba(168,85,247,0.05));
    border: 2px dashed rgba(0,212,255,0.3);
    border-radius: 16px;
    padding: 3rem 2rem;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-bottom: 2rem;
  }

  :global(.upload-zone:hover),
  :global(.upload-zone:focus) {
    border-color: #00D4FF;
    background: linear-gradient(135deg, rgba(0,212,255,0.1), rgba(168,85,247,0.1));
    outline: none;
  }

  :global(.upload-zone.drag-active) {
    border-color: #00D4FF;
    border-style: solid;
    background: rgba(0,212,255,0.1);
  }

  :global(.compress-button) {
    background: linear-gradient(135deg, #00D4FF, #0099CC);
    color: var(--color-bg-dark);
    border: none;
    padding: 1rem 3rem;
    border-radius: 8px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  :global(.compress-button:hover:not(:disabled)) {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0,212,255,0.4);
  }

  :global(.compress-button:disabled) { opacity: 0.7; cursor: not-allowed; }

  :global(.compression-result) {
    background: rgba(10,14,39,0.6);
    border: 1px solid rgba(0,212,255,0.2);
    border-radius: 16px;
    padding: 2rem;
    margin-top: 2rem;
    animation: fadeIn 0.5s ease;
  }

  :global(.result-comparison) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  :global(.spinner) {
    width: 16px;
    height: 16px;
    border: 2px solid transparent;
    border-top-color: currentColor;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }

  :global(.progress-bar) {
    width: 100%;
    height: 8px;
    background: rgba(255,255,255,0.1);
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 1rem;
  }

  :global(.progress-fill) {
    height: 100%;
    background: linear-gradient(90deg, #00D4FF, #0099CC);
    border-radius: 4px;
    transition: width 0.3s ease;
  }

  :global(.ratio) {
    background: #00D4FF;
    color: var(--color-bg-dark);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 600;
  }

  :global(.try-another) {
    background: transparent;
    border: 2px solid #00D4FF;
    color: #00D4FF;
    padding: 0.75rem 2rem;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-weight: 600;
  }

  :global(.try-another:hover) {
    background: #00D4FF;
    color: var(--color-bg-dark);
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Responsive */
  @media (max-width: 900px) {
    .card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .hero-title { font-size: 2rem; }

    .legend-row {
      flex-direction: column;
      align-items: center;
    }

    .card-grid {
      grid-template-columns: 1fr;
    }

    :global(.result-comparison) {
      flex-direction: column;
      gap: 1rem;
    }

    :global(.upload-zone) {
      padding: 2rem 1rem;
    }
  }
</style>
