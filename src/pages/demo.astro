---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Research Preview | ByteLite LLC"
  description="ByteLite research demonstrations are available by request."
  noindex={true}
>
  <Header slot="header" />

  <section class="section">
    <div class="container" style="max-width:640px;text-align:center;padding-top:5rem;">
      <p class="eyebrow">Research Preview</p>
      <h1 style="font-size:2rem;margin-bottom:1rem;">Preview by Request</h1>
      <p style="font-size:1.0625rem;line-height:1.8;margin-bottom:2rem;">
        ByteLite research demonstrations are available by request for research and partnership inquiries.
        No public file upload tool is available. Research demonstrations are available by request only.
      </p>
      <a href="/contact" class="btn btn-primary">Request a Preview</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>
<style>

</style>
