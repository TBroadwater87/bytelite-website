---
import Layout from '../layouts/Layout.astro';
import InteractiveCompressionDemo from '../components/InteractiveCompressionDemo.tsx';
import HighLevelVisualization from '../components/HighLevelVisualization.astro';
import CompressionDemo from '../components/CompressionDemo.astro';
import DemoSchema from '../components/schemas/DemoSchema.astro';
---

<Layout
  title="Demos - ByteLite Public Lab"
  description="The public-facing lab for ByteLite, Deep Kore / AIya, and HeartStrings. Every demo is labeled with its actual availability."
  keywords={["compression demo", "ByteLite demo", "AIya demo", "HeartStrings demo", "Deep Kore demo", "interactive preview", "ByteLite public lab"]}
  schemaType="WebApplication"
>
  <DemoSchema slot="head" />

  <!-- HERO SECTION -->
  <section class="demo-hero">
    <div class="container">
      <h1 class="hero-title">Demos</h1>
      <p class="hero-subtitle">The public-facing lab. Every demo is labeled with its actual availability.</p>

      <!-- Badge Legend -->
      <div class="badge-legend">
        <div class="legend-item">
          <span class="badge badge-live">Live</span>
          <span class="legend-label">Running in production</span>
        </div>
        <div class="legend-item">
          <span class="badge badge-preview">Interactive Preview</span>
          <span class="legend-label">Functional prototype or curated interaction</span>
        </div>
        <div class="legend-item">
          <span class="badge badge-recorded">Recorded Walkthrough</span>
          <span class="legend-label">Video or guided tour</span>
        </div>
        <div class="legend-item">
          <span class="badge badge-indev">In Development</span>
          <span class="legend-label">Not yet available publicly</span>
        </div>
      </div>
    </div>
  </section>

  <section class="demo-content">
    <div class="container">

      <!-- ============================
           SECTION 1: ByteLite Demos
           ============================ -->
      <div class="product-section" id="bytelite">
        <div class="product-header product-header--cyan">
          <h2>ByteLite Demos</h2>
          <p class="product-tagline">Compression technology demos. Browser-local. No data leaves your device.</p>
        </div>

        <!-- ByteLite Demo Cards -->
        <div class="demo-card-grid">

          <div class="demo-card">
            <div class="demo-card-top">
              <span class="badge badge-live">Live</span>
              <h3 class="demo-card-title">File Compression Playground</h3>
            </div>
            <p class="demo-card-desc">Upload a structured file and see ByteLite process it. Browser-only. No data leaves your device.</p>
            <a href="#bytelite-playground" class="demo-card-cta demo-card-cta--cyan">Try It Below</a>
          </div>

          <div class="demo-card">
            <div class="demo-card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3 class="demo-card-title">Stage Visualizer</h3>
            </div>
            <p class="demo-card-desc">See the dictionary cascade stages conceptually. Pedagogical representation of the compression pipeline.</p>
            <a href="/technology" class="demo-card-cta demo-card-cta--cyan">View on ByteLite page</a>
          </div>

          <div class="demo-card">
            <div class="demo-card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3 class="demo-card-title">Determinism Proof</h3>
            </div>
            <p class="demo-card-desc">Same input, same output. View a sample proof showing identical outputs from identical inputs.</p>
            <a href="/technology" class="demo-card-cta demo-card-cta--cyan">View on ByteLite page</a>
          </div>

          <div class="demo-card">
            <div class="demo-card-top">
              <span class="badge badge-indev">In Development</span>
              <h3 class="demo-card-title">Developer API Preview</h3>
            </div>
            <p class="demo-card-desc">Placeholder integration interface showing the planned ByteLite API shape.</p>
            <a href="/technology" class="demo-card-cta demo-card-cta--cyan">View on ByteLite page</a>
          </div>

        </div>

        <!-- Live Demo: File Compression Playground -->
        <div class="demo-section" id="bytelite-playground">
          <h2>Try It Yourself</h2>
          <p class="section-description">
            ByteLite is built for real-world structured data: text, code, documents, logs.
            The closer your data fits our dictionary domain, the more dramatic the ratio.
            Try it and see.
          </p>
          <InteractiveCompressionDemo client:load />

          <!-- Data Handling Notice -->
          <div class="data-handling-notice">
            <h4>Demo Data Handling</h4>
            <ul>
              <li><strong>Processing:</strong> Files are processed locally in your browser. No data is uploaded to our servers.</li>
              <li><strong>Retention:</strong> No files or content are stored after you close this page.</li>
              <li><strong>Privacy:</strong> Do not upload sensitive, confidential, or personal data.</li>
              <li><strong>Purpose:</strong> This demo is for educational and evaluation purposes only.</li>
            </ul>
          </div>
        </div>

        <!-- Benchmark Results -->
        <div class="demo-section">
          <h2>Benchmark Results</h2>
          <p class="section-description">
            Verified results on standard compression benchmarks.
          </p>
          <CompressionDemo />
        </div>

        <!-- How It Works -->
        <div class="demo-section">
          <h2>How It Works</h2>
          <p class="section-description">
            A high-level overview of ByteLite's compression technology.
          </p>
          <HighLevelVisualization />
        </div>
      </div>

      <!-- ============================
           SECTION 2: Deep Kore / AIya Demos
           ============================ -->
      <div class="product-section" id="deepkore">
        <div class="product-header product-header--purple">
          <h2>Deep Kore / AIya Demos</h2>
          <p class="product-tagline">Research architecture previews and curated AIya interaction samples.</p>
        </div>

        <!-- Deep Kore Demo Cards -->
        <div class="demo-card-grid">

          <div class="demo-card">
            <div class="demo-card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3 class="demo-card-title">AIya Conversation Gallery</h3>
            </div>
            <p class="demo-card-desc">Four curated sample conversations showing how AIya responds across different query types.</p>
            <a href="/deepkore#aiya-gallery" class="demo-card-cta demo-card-cta--purple">Explore</a>
          </div>

          <div class="demo-card">
            <div class="demo-card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3 class="demo-card-title">AIya Mini Sandbox</h3>
            </div>
            <p class="demo-card-desc">Select from preset prompts to see deterministic AIya responses. Not live AI generation.</p>
            <a href="/deepkore#aiya-sandbox" class="demo-card-cta demo-card-cta--purple">Try It</a>
          </div>

          <div class="demo-card">
            <div class="demo-card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3 class="demo-card-title">Governance Panel</h3>
            </div>
            <p class="demo-card-desc">See the public view of Genesis Goal Keeper's governance metadata for each response category.</p>
            <a href="/deepkore#governance" class="demo-card-cta demo-card-cta--purple">View</a>
          </div>

          <div class="demo-card">
            <div class="demo-card-top">
              <span class="badge badge-recorded">Recorded Walkthrough</span>
              <h3 class="demo-card-title">Full Deep Kore Research Page</h3>
            </div>
            <p class="demo-card-desc">In-depth architecture overview, thesis, timeline, and FAQ.</p>
            <a href="/deepkore" class="demo-card-cta demo-card-cta--purple">Read More</a>
          </div>

        </div>
      </div>

      <!-- ============================
           SECTION 3: HeartStrings Demos
           ============================ -->
      <div class="product-section" id="heartstrings">
        <div class="product-header product-header--pink">
          <h2>HeartStrings Demos</h2>
          <p class="product-tagline">Interface prototypes and compatibility framework previews.</p>
        </div>

        <!-- HeartStrings Demo Cards -->
        <div class="demo-card-grid">

          <div class="demo-card">
            <div class="demo-card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3 class="demo-card-title">Interface Gallery</h3>
            </div>
            <p class="demo-card-desc">Five mock UI panels showing profile cards, match view, conversation screen, settings, and safety tools.</p>
            <a href="/heartstrings#interface-gallery" class="demo-card-cta demo-card-cta--pink">Explore</a>
          </div>

          <div class="demo-card">
            <div class="demo-card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3 class="demo-card-title">Prototype Flow</h3>
            </div>
            <p class="demo-card-desc">Step through the HeartStrings experience: profile, compatibility, match explanation, conversation starters.</p>
            <a href="/heartstrings#prototype-flow" class="demo-card-cta demo-card-cta--pink">Try It</a>
          </div>

          <div class="demo-card">
            <div class="demo-card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3 class="demo-card-title">Deterministic Match Explanation</h3>
            </div>
            <p class="demo-card-desc">See why a match scores where it does with a fully transparent rationale breakdown.</p>
            <a href="/heartstrings#match-explanation" class="demo-card-cta demo-card-cta--pink">View</a>
          </div>

          <div class="demo-card">
            <div class="demo-card-top">
              <span class="badge badge-preview">Interactive Preview</span>
              <h3 class="demo-card-title">Full HeartStrings Page</h3>
            </div>
            <p class="demo-card-desc">Complete product overview, origin story, what is real today, and what comes next.</p>
            <a href="/heartstrings" class="demo-card-cta demo-card-cta--pink">See More</a>
          </div>

        </div>
      </div>

      <!-- BOTTOM CTA -->
      <div class="cta-section">
        <h3>Status</h3>
        <p>See exactly what is live, what is preview, and what is in active development across all three systems.</p>
        <div class="cta-buttons">
          <a href="/status" class="btn btn-primary">View Status Page</a>
        </div>
      </div>

    </div>
  </section>
</Layout>

<style>
  /* =====================
     HERO
     ===================== */
  .demo-hero {
    padding: 5rem 0 3rem;
    background: var(--color-bg-darker);
    text-align: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    margin: 0 0 1rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    color: var(--color-text-dim);
    max-width: 560px;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
  }

  /* Badge Legend */
  .badge-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    justify-content: center;
    align-items: center;
    max-width: 800px;
    margin: 0 auto;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .legend-label {
    font-size: 0.8rem;
    color: var(--color-text-dim);
  }

  /* =====================
     BADGES
     ===================== */
  .badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.2rem 0.65rem;
    border-radius: 20px;
    white-space: nowrap;
  }

  .badge-live {
    background: rgba(34, 197, 94, 0.15);
    color: #22C55E;
    border: 1px solid rgba(34, 197, 94, 0.4);
  }

  .badge-preview {
    background: rgba(0, 212, 255, 0.1);
    color: #00D4FF;
    border: 1px solid rgba(0, 212, 255, 0.35);
  }

  .badge-recorded {
    background: rgba(168, 85, 247, 0.1);
    color: #A855F7;
    border: 1px solid rgba(168, 85, 247, 0.35);
  }

  .badge-indev {
    background: rgba(224, 224, 224, 0.08);
    color: rgba(224, 224, 224, 0.55);
    border: 1px solid rgba(224, 224, 224, 0.2);
  }

  /* =====================
     MAIN CONTENT
     ===================== */
  .demo-content {
    padding: 4rem 0;
    background: var(--color-bg-darker);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* =====================
     PRODUCT SECTIONS
     ===================== */
  .product-section {
    margin-bottom: 7rem;
  }

  .product-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.25rem;
    border-bottom: 2px solid;
  }

  .product-header h2 {
    font-size: 2rem;
    font-weight: 800;
    margin: 0 0 0.4rem;
  }

  .product-tagline {
    font-size: 1rem;
    color: var(--color-text-dim);
    margin: 0;
    line-height: 1.5;
  }

  .product-header--cyan {
    border-color: #00D4FF;
  }

  .product-header--cyan h2 {
    color: #00D4FF;
  }

  .product-header--purple {
    border-color: #A855F7;
  }

  .product-header--purple h2 {
    color: #A855F7;
  }

  .product-header--pink {
    border-color: #EC4899;
  }

  .product-header--pink h2 {
    color: #EC4899;
  }

  /* =====================
     DEMO CARD GRID
     ===================== */
  .demo-card-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-bottom: 3.5rem;
  }

  .demo-card {
    background: rgba(10, 14, 39, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }

  .demo-card:hover {
    border-color: rgba(255, 255, 255, 0.18);
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.3);
  }

  .demo-card-top {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .demo-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0;
    line-height: 1.35;
  }

  .demo-card-desc {
    font-size: 0.875rem;
    color: var(--color-text-dim);
    line-height: 1.55;
    margin: 0;
    flex: 1;
  }

  .demo-card-cta {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.4rem 1rem;
    border-radius: 6px;
    text-decoration: none;
    border: 1px solid;
    transition: all 0.2s ease;
    align-self: flex-start;
    margin-top: auto;
  }

  .demo-card-cta--cyan {
    color: #00D4FF;
    border-color: rgba(0, 212, 255, 0.35);
    background: rgba(0, 212, 255, 0.05);
  }

  .demo-card-cta--cyan:hover {
    background: rgba(0, 212, 255, 0.15);
    border-color: #00D4FF;
  }

  .demo-card-cta--purple {
    color: #A855F7;
    border-color: rgba(168, 85, 247, 0.35);
    background: rgba(168, 85, 247, 0.05);
  }

  .demo-card-cta--purple:hover {
    background: rgba(168, 85, 247, 0.15);
    border-color: #A855F7;
  }

  .demo-card-cta--pink {
    color: #EC4899;
    border-color: rgba(236, 72, 153, 0.35);
    background: rgba(236, 72, 153, 0.05);
  }

  .demo-card-cta--pink:hover {
    background: rgba(236, 72, 153, 0.15);
    border-color: #EC4899;
  }

  /* =====================
     DEMO SUB-SECTIONS
     ===================== */
  .demo-section {
    margin-bottom: 5rem;
  }

  .demo-section h2 {
    font-size: 2rem;
    color: var(--color-primary);
    text-align: center;
    margin-bottom: 1rem;
  }

  .section-description {
    text-align: center;
    color: var(--color-text-dim);
    font-size: 1.125rem;
    max-width: 600px;
    margin: 0 auto 3rem;
    line-height: 1.6;
  }

  .data-handling-notice {
    background: rgba(10, 14, 39, 0.8);
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 12px;
    padding: 1.5rem 2rem;
    margin-top: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .data-handling-notice h4 {
    color: #A855F7;
    font-size: 1rem;
    margin-bottom: 1rem;
    text-align: center;
  }

  .data-handling-notice ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .data-handling-notice li {
    color: var(--color-text-dim);
    font-size: 0.875rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    line-height: 1.5;
  }

  .data-handling-notice li:last-child {
    border-bottom: none;
  }

  .data-handling-notice strong {
    color: var(--color-text);
  }

  /* =====================
     BOTTOM CTA
     ===================== */
  .cta-section {
    background: linear-gradient(135deg, rgba(0, 212, 255, 0.05) 0%, rgba(255, 0, 110, 0.05) 100%);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 16px;
    padding: 4rem 2rem;
    text-align: center;
    margin-top: 2rem;
  }

  .cta-section h3 {
    font-size: 2rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .cta-section p {
    color: var(--color-text-dim);
    font-size: 1.125rem;
    margin-bottom: 2rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    padding: 1rem 2rem;
    font-size: 1.125rem;
    font-weight: 600;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .btn-primary {
    background: var(--color-primary);
    color: var(--color-bg-dark);
  }

  .btn-primary:hover {
    background: #00A8CC;
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0, 212, 255, 0.3);
  }

  .btn-secondary {
    background: transparent;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
  }

  .btn-secondary:hover {
    background: var(--color-primary);
    color: var(--color-bg-dark);
  }

  /* =====================
     INTERACTIVE COMPRESSION DEMO GLOBALS
     ===================== */
  :global(.compression-demo) {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  :global(.demo-header) {
    margin-bottom: 2rem;
  }

  :global(.demo-header h3) {
    font-size: 1.5rem;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  :global(.demo-header p) {
    color: var(--color-text-dim);
  }

  :global(.upload-zone) {
    background: linear-gradient(135deg, rgba(0, 212, 255, 0.05), rgba(255, 0, 110, 0.05));
    border: 2px dashed rgba(0, 212, 255, 0.3);
    border-radius: 16px;
    padding: 3rem 2rem;
    cursor: pointer;
    transition: all 0.3s ease;
    margin-bottom: 2rem;
  }

  :global(.upload-zone:hover) {
    border-color: var(--color-primary);
    background: linear-gradient(135deg, rgba(0, 212, 255, 0.1), rgba(255, 0, 110, 0.1));
  }

  :global(.upload-zone.drag-active) {
    border-color: var(--color-primary);
    border-style: solid;
    background: rgba(0, 212, 255, 0.1);
  }

  :global(.upload-zone.has-file) {
    border-style: solid;
  }

  :global(.upload-icon) {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  :global(.upload-text) {
    font-size: 1.125rem;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  :global(.upload-hint) {
    font-size: 0.875rem;
    color: var(--color-text-dim);
  }

  :global(.file-info) {
    animation: fadeIn 0.3s ease;
  }

  :global(.file-info h4) {
    color: var(--color-text);
    margin: 0.5rem 0;
  }

  :global(.file-size) {
    color: var(--color-primary);
    font-weight: 600;
    margin-bottom: 1rem;
  }

  :global(.change-file) {
    background: transparent;
    border: 1px solid var(--color-text-dim);
    color: var(--color-text-dim);
    padding: 0.5rem 1rem;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-size: 0.875rem;
  }

  :global(.change-file:hover) {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  :global(.compress-button) {
    background: linear-gradient(135deg, var(--color-primary), #0099CC);
    color: var(--color-bg-dark);
    border: none;
    padding: 1rem 3rem;
    border-radius: 8px;
    font-size: 1.125rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0 auto;
  }

  :global(.compress-button:hover:not(:disabled)) {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0, 212, 255, 0.4);
  }

  :global(.compress-button:disabled) {
    opacity: 0.7;
    cursor: not-allowed;
  }

  :global(.spinner) {
    width: 16px;
    height: 16px;
    border: 2px solid transparent;
    border-top-color: currentColor;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
  }

  :global(.compression-result) {
    background: rgba(10, 14, 39, 0.6);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 16px;
    padding: 2rem;
    margin-top: 2rem;
    animation: fadeIn 0.5s ease;
  }

  :global(.result-header) {
    margin-bottom: 2rem;
  }

  :global(.result-header h4) {
    color: var(--color-primary);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  :global(.compression-time) {
    color: var(--color-text-dim);
    font-size: 0.875rem;
  }

  :global(.result-comparison) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    margin-bottom: 2rem;
  }

  :global(.result-box) {
    background: rgba(0, 0, 0, 0.3);
    padding: 1.5rem;
    border-radius: 12px;
    min-width: 120px;
  }

  :global(.result-box h5) {
    color: var(--color-text-dim);
    font-size: 0.875rem;
    margin-bottom: 0.5rem;
  }

  :global(.result-box .size) {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text);
  }

  :global(.result-box.compressed .size) {
    color: var(--color-primary);
  }

  :global(.extension) {
    color: var(--color-text-dim);
    font-size: 0.875rem;
    margin-top: 0.25rem;
  }

