---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="HeartStrings App | Private-Test Digital Companion"
  description="HeartStrings App is the private-test digital companion for the HeartStrings ecosystem. No public app store release is available yet."
  keywords="HeartStrings App, private beta, digital companion, ByteLite LLC"
  
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="app-hero">
    <div class="container">
      <p class="eyebrow">HeartStrings App</p>
      <h1>The private-test digital companion<br/>for the HeartStrings ecosystem.</h1>
      <p class="app-hero-sub">
        HeartStrings App is in private Android testing and beta development.
        It is not publicly available in any app store.
      </p>
      <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap;margin-top:1.75rem;">
        <span class="badge badge-private">Private beta development</span>
        <span style="font-size:.875rem;color:#555e7a;">No public app store listing</span>
      </div>
      <div style="display:flex;gap:.875rem;flex-wrap:wrap;margin-top:2rem;">
        <a href="/contact" class="btn btn-primary">Beta Interest</a>
        <a href="/status" class="btn btn-outline btn-sm" style="align-self:center;">View Status</a>
      </div>
    </div>
  </section>

  <!-- Current status -->
  <section class="section section-alt">
    <div class="container" style="max-width:760px;">
      <div class="app-status-box">
        <h3 style="color:#e4e7f2;margin-bottom:1rem;">Current Status</h3>
        <div class="app-status-grid">
          <div class="app-status-item">
            <span class="badge badge-private">Private test builds</span>
            <p>Used for internal development validation. Not for public distribution.</p>
          </div>
          <div class="app-status-item">
            <span class="badge badge-none">No public app store listing</span>
            <p>Not available on Google Play, Apple App Store, or any third-party marketplace.</p>
          </div>
          <div class="app-status-item">
            <span class="badge badge-active">Active development</span>
            <p>Profiles, onboarding, and companion features are actively under development.</p>
          </div>
          <div class="app-status-item">
            <span class="badge badge-planned">Beta program planned</span>
            <p>A limited private beta program is planned. Contact to express interest.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features in development -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">In Development</p>
      <h2 style="margin-bottom:.75rem;">What is being built.</h2>
      <p style="max-width:580px;margin-bottom:2.5rem;font-size:1.0625rem;">
        These features are in active development. None are publicly available yet.
        Status reflects private testing only.
      </p>
      <div class="features-grid">
        <div class="card feature-card">
          <div class="feature-tag tag-dev">In Development</div>
          <h4 style="color:#e4e7f2;margin:.5rem 0 .5rem;">Profiles &amp; Onboarding</h4>
          <p class="feature-desc">Private profile creation and onboarding flow for HeartStrings ecosystem participants.</p>
        </div>
        <div class="card feature-card">
          <div class="feature-tag tag-dev">In Development</div>
          <h4 style="color:#e4e7f2;margin:.5rem 0 .5rem;">Companion Features</h4>
          <p class="feature-desc">Digital companion layer for HeartStrings Play sessions and follow-on connection.</p>
        </div>
        <div class="card feature-card">
          <div class="feature-tag tag-planned">Planned</div>
          <h4 style="color:#e4e7f2;margin:.5rem 0 .5rem;">Matching &amp; Discovery</h4>
          <p class="feature-desc">Private, consent-first discovery between compatible users. Planned for a later release phase.</p>
        </div>
        <div class="card feature-card">
          <div class="feature-tag tag-planned">Planned</div>
          <h4 style="color:#e4e7f2;margin:.5rem 0 .5rem;">Date Safety Features</h4>
          <p class="feature-desc">Location-aware safety tooling for in-person meeting. In design phase.</p>
        </div>
        <div class="card feature-card">
          <div class="feature-tag tag-planned">Planned</div>
          <h4 style="color:#e4e7f2;margin:.5rem 0 .5rem;">Social Layer</h4>
          <p class="feature-desc">Private social features for HeartStrings ecosystem participants. Post-beta scope.</p>
        </div>
        <div class="card feature-card">
          <div class="feature-tag tag-research">Research</div>
          <h4 style="color:#e4e7f2;margin:.5rem 0 .5rem;">Guided Interface (AIya)</h4>
          <p class="feature-desc">AIya is a research concept for a deterministic guide interface. Not a production AI system.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Privacy -->
  <section class="section section-alt">
    <div class="container" style="max-width:760px;">
      <p class="eyebrow">Privacy Stance</p>
      <h2 style="margin-bottom:1.5rem;">Privacy-first by design.</h2>
      <div class="privacy-list">
        <div class="privacy-item">
          <span class="privacy-icon">&#10003;</span>
          <p>Private test builds are not connected to advertising networks.</p>
        </div>
        <div class="privacy-item">
          <span class="privacy-icon">&#10003;</span>
          <p>No personal data is sold or shared with third parties.</p>
        </div>
        <div class="privacy-item">
          <span class="privacy-icon">&#10003;</span>
          <p>A full app-specific privacy policy will be published before any public launch or broader beta release.</p>
        </div>
        <div class="privacy-item">
          <span class="privacy-icon">&#10003;</span>
          <p>Beta participants will be informed of any data handling specific to their testing role.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Beta interest CTA -->
  <section class="section">
    <div class="container cta-block">
      <h2>Interested in private beta?</h2>
      <p>The beta program is not yet open. Express interest and you will be contacted when slots become available.</p>
      <a href="/contact" class="btn btn-primary">Express Beta Interest</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>

.app-hero {
  padding: 6rem 0 4.5rem;
  background: radial-gradient(ellipse 70% 50% at 50% -5%, rgba(99,102,241,.07) 0%, transparent 70%);
}
.app-hero h1 { max-width: 700px; }
.app-hero-sub { max-width: 560px; margin-top: 1.25rem; font-size: 1.0625rem; color: #7b829e; line-height: 1.75; }
.app-status-box { background: #111828; border: 1px solid #1a2235; border-radius: .875rem; padding: 2rem; }
.app-status-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-top: 1.25rem; }
@media (max-width: 640px) { .app-status-grid { grid-template-columns: 1fr; } }
.app-status-item { display: flex; flex-direction: column; gap: .625rem; }
.app-status-item p { font-size: .875rem; color: #7b829e; }
.features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
@media (max-width: 900px) { .features-grid { grid-template-columns: repeat(2, 1fr); } }
@media (max-width: 640px) { .features-grid { grid-template-columns: 1fr; } }
.feature-card {}
.feature-desc { font-size: .875rem; color: #7b829e; }
.feature-tag { font-size: .6875rem; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; padding: .25rem .625rem; border-radius: .25rem; display: inline-block; }
.tag-dev     { background: rgba(99,102,241,.12);  color: #818cf8; }
.tag-planned { background: rgba(245,158,11,.12);  color: #fbbf24; }
.tag-research{ background: rgba(167,139,250,.12); color: #a78bfa; }
.privacy-list { display: flex; flex-direction: column; gap: 1rem; }
.privacy-item { display: flex; align-items: flex-start; gap: .875rem; }
.privacy-icon { font-size: 1rem; color: #34d399; flex-shrink: 0; margin-top: .125rem; }
.privacy-item p { font-size: 1rem; color: #a0a8c0; }
.cta-block {
  background: #0d1120; border: 1px solid #1a2235; border-radius: 1rem;
  padding: 3.5rem; text-align: center;
}
.cta-block h2 { margin-bottom: 1rem; }
.cta-block p { max-width: 480px; margin: 0 auto 2rem; font-size: 1.0625rem; }

</style>
