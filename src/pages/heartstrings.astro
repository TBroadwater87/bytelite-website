---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="HeartStrings - Relationship Intelligence Platform"
  description="HeartStrings is a deterministic relationship intelligence platform. Authentic connection through structured compatibility and honest matching rationale. Interface prototype stage."
  keywords={["HeartStrings", "relationship platform", "deterministic matching", "compatibility engine", "ByteLite"]}
  schemaType="WebPage"
>

  <!-- Banner -->
  <img src="/HeartStrings_Banner.png" style="width:100%; height:auto; max-height:340px; object-fit:cover; display:block;" alt="HeartStrings - Relationship Intelligence Platform">

  <!-- Hero -->
  <section class="hs-hero">
    <div class="container">
      <div class="hero-badge">Interface Prototype</div>
      <h1>HeartStrings</h1>
      <p class="hero-tagline">Relationship intelligence built on deterministic compatibility.</p>
      <p class="hero-sub">Every match shows exactly why it ranked — structured dimensions, no opaque scores, no engagement-optimized dark patterns.</p>
      <div class="hero-cta">
        <a href="/demo" class="btn btn-pink">See Demo</a>
        <a href="/status" class="btn btn-outline">Current Status</a>
      </div>
    </div>
  </section>

  <!-- Interface Gallery -->
  <section class="hs-gallery">
    <div class="container">
      <h2>Interface Gallery</h2>
      <p class="section-subtitle">Prototype UI — panels below show planned interface design. Not backed by live matching data.</p>
      <div class="gallery-grid">

        <div class="ui-panel panel-pink">
          <div class="preview-badge">Preview</div>
          <div class="panel-label">Profile Card</div>
          <div class="profile-name">Alex M.</div>
          <div class="profile-meta">Helena, MT &nbsp;|&nbsp; Long-term relationship</div>
          <div class="profile-values">Authenticity | Depth | Growth</div>
          <div class="interest-tags">
            <span class="tag">Engineering</span>
            <span class="tag">Hiking</span>
            <span class="tag">Philosophy</span>
          </div>
          <div class="compat-row">
            <span class="compat-label">Compatibility</span>
            <span class="compat-pct">87%</span>
          </div>
          <div class="bar-track"><div class="bar-fill bar-pink" style="width:87%;"></div></div>
          <button class="mock-btn" disabled>Match</button>
        </div>

        <div class="ui-panel panel-cyan">
          <div class="preview-badge">Preview</div>
          <div class="panel-label">Why This Match</div>
          <div class="dim-row"><span class="dim-name">Values alignment</span><span class="dim-pct pct-green">94%</span></div>
          <div class="bar-track"><div class="bar-fill bar-green" style="width:94%;"></div></div>
          <div class="dim-row"><span class="dim-name">Communication style</span><span class="dim-pct pct-cyan">81%</span></div>
          <div class="bar-track"><div class="bar-fill bar-cyan" style="width:81%;"></div></div>
          <div class="dim-row"><span class="dim-name">Life goals</span><span class="dim-pct pct-green">89%</span></div>
          <div class="bar-track"><div class="bar-fill bar-green" style="width:89%;"></div></div>
          <div class="dim-row dealbreaker-row"><span class="dim-name">Dealbreakers</span><span class="check-ok">[OK] None flagged</span></div>
        </div>

        <div class="ui-panel panel-purple">
          <div class="preview-badge">Preview</div>
          <div class="panel-label">Conversation</div>
          <div class="chat-area">
            <div class="chat-msg chat-you"><span class="chat-sender">You:</span> What drew you to engineering originally?</div>
            <div class="chat-msg chat-them"><span class="chat-sender">Alex:</span> Honestly, it started with trying to build a better mousetrap as a kid...</div>
          </div>
          <div class="chat-input-bar"><span class="chat-placeholder">Type a message...</span></div>
          <div class="conv-tip">HeartStrings tip: Authentic curiosity builds connection.</div>
        </div>

        <div class="ui-panel panel-pink">
          <div class="preview-badge">Preview</div>
          <div class="panel-label">Your Filters</div>
          <div class="filter-list">
            <div class="filter-item">[x] Must share growth mindset</div>
            <div class="filter-item">[x] Open to long-term commitment</div>
            <div class="filter-item">[x] Respect for boundaries</div>
            <div class="filter-item">[x] Intellectual curiosity</div>
          </div>
          <div class="slider-visual">
            <span class="slider-label">Distance:</span>
            <span class="slider-track"><span class="slider-thumb" style="left:50%;"></span></span>
            <span class="slider-value">50 miles</span>
          </div>
          <div class="slider-visual">
            <span class="slider-label">Age range:</span>
            <span class="slider-track"><span class="slider-thumb" style="left:30%;"></span></span>
            <span class="slider-value">28-45</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Prototype Flow -->
  <section class="hs-flow">
    <div class="container">
      <h2>Prototype Flow</h2>
      <p class="section-subtitle">Walk through the HeartStrings experience — interactive preview, local state only.</p>

      <div class="flow-step-indicators" id="flow-indicators">
        <button class="step-dot step-active" onclick="goToStep(1)">1</button>
        <button class="step-dot" onclick="goToStep(2)">2</button>
        <button class="step-dot" onclick="goToStep(3)">3</button>
        <button class="step-dot" onclick="goToStep(4)">4</button>
      </div>

      <div class="flow-panels">

        <div class="flow-panel" id="flow-step-1">
          <div class="flow-card">
            <div class="flow-card-title">Step 1 — Profile</div>
            <div class="flow-row"><span class="flow-key">Compatibility style</span><span class="flow-val">Deep Connector</span></div>
            <div class="flow-row"><span class="flow-key">Top values</span><span class="flow-val">Authenticity, Depth, Intellectual curiosity</span></div>
            <div class="flow-row"><span class="flow-key">Intent</span><span class="flow-val">Long-term relationship</span></div>
            <div class="flow-row"><span class="flow-key">Match radius</span><span class="flow-val">50 miles</span></div>
            <div class="flow-badge-row"><span class="flow-badge">Profile Complete</span></div>
          </div>
        </div>

        <div class="flow-panel flow-hidden" id="flow-step-2">
          <div class="flow-card">
            <div class="flow-card-title">Step 2 — Match: Alex M. (87%)</div>
            <div class="flow-dim-row">
              <span class="flow-dim-name">Values</span>
              <span class="flow-dim-bar-wrap"><span class="flow-dim-bar bar-green" style="width:94%;"></span></span>
              <span class="flow-dim-pct">94%</span>
            </div>
            <div class="flow-dim-row">
              <span class="flow-dim-name">Communication</span>
              <span class="flow-dim-bar-wrap"><span class="flow-dim-bar bar-cyan" style="width:81%;"></span></span>
              <span class="flow-dim-pct">81%</span>
            </div>
            <div class="flow-dim-row">
              <span class="flow-dim-name">Life Goals</span>
              <span class="flow-dim-bar-wrap"><span class="flow-dim-bar bar-green" style="width:89%;"></span></span>
              <span class="flow-dim-pct">89%</span>
            </div>
            <div class="flow-dim-row">
              <span class="flow-dim-name">Shared Interests</span>
              <span class="flow-dim-bar-wrap"><span class="flow-dim-bar bar-pink" style="width:76%;"></span></span>
              <span class="flow-dim-pct">76%</span>
            </div>
            <div class="flow-note">Dimensions weighted by what matters most to you.</div>
          </div>
        </div>

        <div class="flow-panel flow-hidden" id="flow-step-3">
          <div class="flow-card">
            <div class="flow-card-title">Step 3 — Compatibility Rationale</div>
            <ul class="flow-bullet-list">
              <li>Shares your top value: Authenticity (confirmed, not inferred)</li>
              <li>Communication style: Reflective and direct (matches your preference)</li>
              <li>Life goal: Long-term commitment (stated, not assumed)</li>
              <li>No dealbreaker flags</li>
              <li>Mutual interest: Philosophy and systems thinking</li>
            </ul>
            <div class="flow-note">Rationale built from stated preferences, not behavioral inference.</div>
          </div>
        </div>

        <div class="flow-panel flow-hidden" id="flow-step-4">
          <div class="flow-card">
            <div class="flow-card-title">Step 4 — Conversation</div>
            <div class="starter-card">"What project are you most proud of from the last year?"</div>
            <div class="starter-card">"You both listed philosophy — is there a thinker who changed how you see things?"</div>
            <div class="starter-card">"You flagged depth as your top value. What does that look like day-to-day?"</div>
            <button class="mock-btn" style="margin-top:0.75rem;" disabled>Start Conversation</button>
            <div class="flow-note">Conversation starters generated from your shared match dimensions.</div>
          </div>
        </div>

      </div>

      <div class="flow-nav">
        <button class="flow-btn" id="flow-prev" onclick="flowNav(-1)" disabled>Previous</button>
        <button class="flow-btn flow-btn-primary" id="flow-next" onclick="flowNav(1)">Next</button>
      </div>

    </div>
  </section>

  <!-- Deterministic Match Explanation -->
  <section class="hs-deterministic">
    <div class="container">
      <h2>Deterministic Matching</h2>
      <div class="det-grid">
        <div class="det-col">
          <h3 class="col-title-pink">Problem</h3>
          <p>Most platforms use engagement-optimized engines that favor matches who keep you swiping, not matches who will work out. Scoring is opaque and unverifiable.</p>
        </div>
        <div class="det-col">
          <h3 class="col-title-cyan">Approach</h3>
          <p>Every match scored against your stated, structured preferences. Dimensions are public. Same two profiles always produce the same score — no A/B testing on your outcomes.</p>
        </div>
        <div class="det-col">
          <h3 class="col-title-green">What You See</h3>
          <p>A ranked list with a full rationale for each position. Not a swipe deck. A structured explanation of why this person is or is not a fit for what you said you wanted.</p>
        </div>
      </div>
      <div class="factor-table-wrap">
        <table class="factor-table">
          <thead>
            <tr><th>Factor</th><th>Your Preference</th><th>Their Profile</th><th>Result</th></tr>
          </thead>
          <tbody>
            <tr><td>Values</td><td>Authenticity first</td><td>Authenticity first</td><td class="match-strong">Strong match</td></tr>
            <tr><td>Commitment</td><td>Long-term</td><td>Long-term</td><td class="match-strong">Strong match</td></tr>
            <tr><td>Communication</td><td>Direct + reflective</td><td>Direct</td><td class="match-good">Good match</td></tr>
            <tr><td>Distance</td><td>50 miles</td><td>12 miles</td><td class="match-good">Within range</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- What Is Real Today -->
  <section class="hs-what-real">
    <div class="container">
      <h2>What Is Real Today</h2>
      <div class="reality-grid">
        <div class="reality-card live">
          <h3>Live Now</h3>
          <ul>
            <li>Interface design system</li>
            <li>Profile card components</li>
            <li>Compatibility dimension framework</li>
          </ul>
        </div>
        <div class="reality-card preview">
          <h3>Prototype / Preview</h3>
          <ul>
            <li>Match view UI</li>
            <li>Conversation screen layout</li>
            <li>Filters and intent settings</li>
          </ul>
        </div>
        <div class="reality-card development">
          <h3>In Development</h3>
          <ul>
            <li>Core matching engine</li>
            <li>Safety and authenticity tools</li>
            <li>ByteLite compression integration</li>
          </ul>
        </div>
        <div class="reality-card planned">
          <h3>Access Timeline</h3>
          <ul>
            <li>Public beta after ByteLite demo</li>
            <li>Early interest list open now</li>
            <li>No launch date set</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- What Is Next -->
  <section class="hs-next">
    <div class="container">
      <h2>What Is Next</h2>
      <ol class="next-list">
        <li>ByteLite demonstration application launches first — HeartStrings depends on that infrastructure.</li>
        <li>Matching engine development begins in parallel once ByteLite core is stable.</li>
        <li>Public beta opens to early interest list after successful ByteLite demo.</li>
      </ol>
    </div>
  </section>

  <!-- CTA Row -->
  <section class="hs-cta">
    <div class="container">
      <div class="cta-row">
        <a href="/demo" class="btn btn-pink">See Demo</a>
        <a href="/status" class="btn btn-outline">Current Status</a>
        <a href="/contact" class="btn btn-outline">Contact</a>
      </div>
    </div>
  </section>

</Layout>

<script>
  let currentStep = 1;
  const totalSteps = 4;

  function showStep(n: number) {
    for (let i = 1; i <= totalSteps; i++) {
      const panel = document.getElementById('flow-step-' + i);
      const dots = document.querySelectorAll('.flow-step-indicators .step-dot');
      const dot = dots[i - 1];
      if (panel) {
        if (i === n) { panel.classList.remove('flow-hidden'); }
        else { panel.classList.add('flow-hidden'); }
      }
      if (dot) {
        if (i === n) { dot.classList.add('step-active'); }
        else { dot.classList.remove('step-active'); }
      }
    }
    const prevBtn = document.getElementById('flow-prev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('flow-next') as HTMLButtonElement | null;
    if (prevBtn) prevBtn.disabled = n <= 1;
    if (nextBtn) nextBtn.disabled = n >= totalSteps;
  }

  (window as any).goToStep = function(n: number) {
    currentStep = n;
    showStep(currentStep);
  };

  (window as any).flowNav = function(dir: number) {
    currentStep = Math.max(1, Math.min(totalSteps, currentStep + dir));
    showStep(currentStep);
  };
</script>

<style>
  :root {
    --hs-pink: #EC4899;
    --hs-primary: #00D4FF;
    --hs-bg: #0A0E27;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Hero */
  .hs-hero {
    padding: 4.5rem 0 3.5rem;
    text-align: center;
    background: linear-gradient(180deg, #0A0E27 0%, rgba(236, 72, 153, 0.05) 50%, #060813 100%);
  }

  .hero-badge {
    display: inline-block;
    padding: 0.3rem 0.9rem;
    border-radius: 100px;
    background: rgba(236, 72, 153, 0.1);
    border: 1px solid rgba(236, 72, 153, 0.3);
    color: #EC4899;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.25rem;
  }

  .hs-hero h1 {
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    font-weight: 800;
    background: linear-gradient(135deg, #F9A8D4 0%, #EC4899 50%, #BE185D 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 0 1rem;
    line-height: 1;
  }

  .hero-tagline {
    font-size: clamp(1rem, 2vw, 1.25rem);
    color: rgba(224, 224, 224, 0.9);
    max-width: 560px;
    margin: 0 auto 0.5rem;
    font-weight: 600;
  }

  .hero-sub {
    font-size: 0.95rem;
    color: rgba(224, 224, 224, 0.6);
    max-width: 520px;
    margin: 0 auto 2rem;
    line-height: 1.55;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Buttons */
  .btn {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .btn:hover { opacity: 0.85; }

  .btn-pink {
    background: #EC4899;
    color: #fff;
    border: 1px solid #EC4899;
  }

  .btn-outline {
    background: transparent;
    color: #00D4FF;
    border: 1px solid #00D4FF;
  }

  /* Section commons */
  .hs-gallery, .hs-flow, .hs-deterministic, .hs-what-real, .hs-next, .hs-cta {
    padding: 3.5rem 0;
  }

  .hs-gallery { background: rgba(236, 72, 153, 0.02); }
  .hs-flow { background: rgba(0, 212, 255, 0.02); }
  .hs-deterministic { background: rgba(236, 72, 153, 0.03); }
  .hs-what-real { background: rgba(0, 212, 255, 0.02); }
  .hs-next { background: rgba(236, 72, 153, 0.02); }
  .hs-cta { padding: 2.5rem 0 3.5rem; background: #060813; }

  section h2 {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    color: #fff;
    margin: 0 0 0.5rem;
  }

  .section-subtitle {
    color: rgba(224, 224, 224, 0.55);
    font-size: 0.88rem;
    margin: 0 0 1.75rem;
    max-width: 600px;
  }

  /* Gallery grid */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .ui-panel {
    background: rgba(10, 14, 39, 0.9);
    border-radius: 10px;
    padding: 1rem;
    position: relative;
    font-size: 0.82rem;
  }

  .panel-pink { border: 1px solid rgba(236, 72, 153, 0.3); }
  .panel-cyan { border: 1px solid rgba(0, 212, 255, 0.3); }
  .panel-purple { border: 1px solid rgba(139, 92, 246, 0.3); }

  .preview-badge {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    background: rgba(236, 72, 153, 0.15);
    border: 1px solid rgba(236, 72, 153, 0.3);
    color: #EC4899;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.15rem 0.45rem;
    border-radius: 4px;
  }

  .panel-label {
    display: block;
    font-weight: 700;
    color: #EC4899;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.75rem;
  }

  .profile-name { font-size: 1.05rem; font-weight: 700; color: #fff; }
  .profile-meta { color: rgba(224,224,224,0.5); font-size: 0.75rem; margin: 0.2rem 0 0.4rem; }
  .profile-values { color: rgba(236,72,153,0.8); font-size: 0.75rem; margin-bottom: 0.5rem; }

  .interest-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-bottom: 0.6rem; }
  .tag {
    background: rgba(236,72,153,0.1);
    border: 1px solid rgba(236,72,153,0.25);
    color: rgba(236,72,153,0.9);
    font-size: 0.68rem;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
  }

  .compat-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem; }
  .compat-label { color: rgba(224,224,224,0.6); font-size: 0.75rem; }
  .compat-pct { color: #EC4899; font-weight: 700; font-size: 0.9rem; }

  .bar-track { height: 4px; background: rgba(255,255,255,0.08); border-radius: 2px; margin-bottom: 0.5rem; overflow: hidden; }
  .bar-fill { height: 100%; border-radius: 2px; }
  .bar-pink { background: #EC4899; }
  .bar-green { background: #22c55e; }
  .bar-cyan { background: #00D4FF; }

  .dim-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.2rem; font-size: 0.78rem; }
  .dim-name { color: rgba(224,224,224,0.7); }
  .dim-pct { font-weight: 700; }
  .pct-green { color: #22c55e; }
  .pct-cyan { color: #00D4FF; }
  .dealbreaker-row { margin-top: 0.5rem; }
  .check-ok { color: #22c55e; font-size: 0.75rem; }

  .mock-btn {
    background: rgba(236,72,153,0.15);
    border: 1px solid rgba(236,72,153,0.4);
    color: #EC4899;
    padding: 0.3rem 0.8rem;
    border-radius: 4px;
    font-size: 0.75rem;
    cursor: not-allowed;
    opacity: 0.6;
    margin-top: 0.4rem;
  }

  .chat-area { background: rgba(255,255,255,0.03); border-radius: 6px; padding: 0.5rem; margin-bottom: 0.4rem; }
  .chat-msg { font-size: 0.75rem; color: rgba(224,224,224,0.7); margin-bottom: 0.35rem; line-height: 1.4; }
  .chat-sender { font-weight: 700; color: #EC4899; }
  .chat-them .chat-sender { color: #00D4FF; }
  .chat-input-bar {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 4px;
    padding: 0.3rem 0.5rem;
    font-size: 0.72rem;
    color: rgba(224,224,224,0.3);
    margin-bottom: 0.4rem;
  }
  .conv-tip { font-size: 0.68rem; color: rgba(236,72,153,0.6); font-style: italic; }

  .filter-list { margin-bottom: 0.6rem; }
  .filter-item { color: rgba(224,224,224,0.7); font-size: 0.75rem; padding: 0.15rem 0; }

  .slider-visual { display: flex; align-items: center; gap: 0.4rem; margin-bottom: 0.3rem; font-size: 0.72rem; }
  .slider-label { color: rgba(224,224,224,0.5); min-width: 65px; }
  .slider-track { flex: 1; height: 3px; background: rgba(255,255,255,0.1); border-radius: 2px; position: relative; }
  .slider-thumb { position: absolute; top: -3px; width: 9px; height: 9px; background: #EC4899; border-radius: 50%; transform: translateX(-50%); }
  .slider-value { color: #EC4899; font-weight: 600; min-width: 50px; text-align: right; }

  /* Prototype Flow */
  .flow-step-indicators {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }

  .step-dot {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    color: rgba(224,224,224,0.5);
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  .step-dot.step-active {
    background: rgba(236,72,153,0.15);
    border-color: #EC4899;
    color: #EC4899;
  }

  .flow-panel { display: block; }
  .flow-hidden { display: none; }

  .flow-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(236,72,153,0.2);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    max-width: 560px;
  }

  .flow-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: #EC4899;
    margin-bottom: 0.9rem;
  }

  .flow-row { display: flex; gap: 1rem; justify-content: space-between; padding: 0.3rem 0; border-bottom: 1px solid rgba(255,255,255,0.05); font-size: 0.85rem; }
  .flow-key { color: rgba(224,224,224,0.55); }
  .flow-val { color: #fff; font-weight: 500; text-align: right; }

  .flow-badge-row { margin-top: 0.75rem; }
