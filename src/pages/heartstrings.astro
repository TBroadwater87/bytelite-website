---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="HeartStrings Play | Premium Consent-First Adult Social Board Game"
  description="HeartStrings Play is a pre-launch premium adult social board game for private groups, built around consent-first connection and escalating card-based play."
  keywords="HeartStrings Play, adult social board game, consent-first, pre-launch, ByteLite LLC"
  
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="hs-hero">
    <div class="container">
      <p class="eyebrow">HeartStrings Play</p>
      <h1>A consent-first social board game<br/>for private groups.</h1>
      <p class="hs-hero-sub">
        Premium adult social play designed around intentional connection,
        shared agency, and escalating card-based experiences.
        For private groups of two to eighteen players.
      </p>
      <div class="hs-hero-badges">
        <span class="badge badge-prelaunch">Pre-launch</span>
        <span class="hs-badge-detail">Manufacturing preparation underway</span>
      </div>
      <div style="display:flex;gap:.875rem;flex-wrap:wrap;margin-top:2rem;">
        <a href="/contact" class="btn btn-pink">Express Interest</a>
        <a href="/status" class="btn btn-outline btn-sm" style="align-self:center;">View Status</a>
      </div>
    </div>
  </section>

  <!-- Quick specs -->
  <section class="section-sm section-alt">
    <div class="container hs-specs-row">
      <div class="hs-spec"><span class="hs-spec-num">2–18</span><span class="hs-spec-label">Players</span></div>
      <div class="hs-spec-div"></div>
      <div class="hs-spec"><span class="hs-spec-num">350</span><span class="hs-spec-label">Cards</span></div>
      <div class="hs-spec-div"></div>
      <div class="hs-spec"><span class="hs-spec-num">6</span><span class="hs-spec-label">Escalation tiers</span></div>
      <div class="hs-spec-div"></div>
      <div class="hs-spec"><span class="hs-spec-num">3</span><span class="hs-spec-label">Board versions</span></div>
    </div>
  </section>

  <!-- About the game -->
  <section class="section">
    <div class="container" style="max-width:760px;">
      <p class="eyebrow">The Game</p>
      <h2 style="margin-bottom:1.25rem;">Designed for intentional play.</h2>
      <p style="font-size:1.0625rem;line-height:1.8;margin-bottom:1.5rem;">
        HeartStrings Play is a premium adult social board game where players move across a board
        of action squares and draw from six escalating tier decks as the session builds.
        Each session is shaped by the players in it — not by a fixed script.
      </p>
      <p style="font-size:1.0625rem;line-height:1.8;">
        Decree cards allow any player to skip or redraw at any time.
        Consent is built into the game structure, not handled separately.
        The Consent Cup is available at any time for any player to end or pause play gracefully.
      </p>
    </div>
  </section>

  <!-- The Box (renders pending) -->
  <section class="section">
    <div class="container">
      <p class="eyebrow" style="text-align:center;">The Box</p>
      <h2 style="text-align:center;margin-bottom:2.5rem;">Box front and back.</h2>
      <div class="asset-ph-grid" style="grid-template-columns:repeat(2,minmax(0,1fr));max-width:820px;margin:0 auto;">
        <div class="asset-ph" style="aspect-ratio:4/5;" role="img" aria-label="HeartStrings Play box — front cover art">
          <span class="asset-ph-tag">Asset pending</span>
          <span class="asset-ph-path">/heartstrings/box-front.png</span>
          <span class="asset-ph-alt">HeartStrings Play box — front cover art</span>
        </div>
        <div class="asset-ph" style="aspect-ratio:4/5;" role="img" aria-label="HeartStrings Play box — back with contents and details">
          <span class="asset-ph-tag">Asset pending</span>
          <span class="asset-ph-path">/heartstrings/box-back.png</span>
          <span class="asset-ph-alt">HeartStrings Play box — back with contents and details</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Action squares -->
  <section class="section section-alt">
    <div class="container" style="max-width:760px;">
      <p class="eyebrow" style="text-align:center;">On the Board</p>
      <h2 style="text-align:center;margin-bottom:1.5rem;">Action squares drive each turn.</h2>
      <p style="font-size:1.0625rem;line-height:1.8;text-align:center;">
        As players move around the board they land on action squares that trigger game actions.
        The action squares are a board mechanic, separate from the escalation tiers below, and
        they keep each turn varied without a fixed script.
      </p>
    </div>
  </section>

  <!-- Six Tiers -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">Six Escalation Tiers</p>
      <h2 style="margin-bottom:2.5rem;">Progress at your pace.</h2>
      <div class="tiers-list">
        <div class="tier-row tier-1"><span class="tier-num">1</span><span class="tier-name">Initiate</span><span class="tier-desc">Entry. Low stakes. Setting the tone.</span></div>
        <div class="tier-row tier-2"><span class="tier-num">2</span><span class="tier-name">Connect</span><span class="tier-desc">Building rapport. Shared presence.</span></div>
        <div class="tier-row tier-3"><span class="tier-num">3</span><span class="tier-name">Seduce</span><span class="tier-desc">Intentional flirtation. Energy shifts.</span></div>
        <div class="tier-row tier-4"><span class="tier-num">4</span><span class="tier-name">Stimulate</span><span class="tier-desc">Heightened engagement. Closer attention.</span></div>
        <div class="tier-row tier-5"><span class="tier-num">5</span><span class="tier-name">Edge</span><span class="tier-desc">Near the limit. High intention required.</span></div>
        <div class="tier-row tier-6"><span class="tier-num">6</span><span class="tier-name">Climax</span><span class="tier-desc">Full escalation. For groups who have agreed.</span></div>
      </div>
    </div>
  </section>

  <!-- Mechanics -->
  <section class="section section-alt">
    <div class="container mech-grid">
      <div class="card">
        <h3 style="margin-bottom:.875rem;color:#e4e7f2;">Decree Cards</h3>
        <p>Any player can play a Decree card at any time to skip a card or redraw. Maximum two Decree cards per hand. Built-in pressure relief without requiring a verbal request.</p>
      </div>
      <div class="card">
        <h3 style="margin-bottom:.875rem;color:#e4e7f2;">The Consent Cup</h3>
        <p>The Consent Cup is available at all times. Any player can use it to pause or end the session without explanation. It is not a game mechanic — it is a standing option.</p>
      </div>
      <div class="card">
        <h3 style="margin-bottom:.875rem;color:#e4e7f2;">The Board</h3>
        <p>The game ships in three board versions: a 20x20 board, a larger 20x40 board, and an ultimate double-sided board that unfolds and flips, with a different layout on each side to change how the game is played.</p>
      </div>
    </div>
  </section>

  <!-- How it plays -->
  <section class="section">
    <div class="container" style="max-width:760px;">
      <p class="eyebrow">How It Plays</p>
      <h2 style="margin-bottom:1.25rem;">One shared session, set by the group.</h2>
      <p style="font-size:1.0625rem;line-height:1.8;margin-bottom:1.5rem;">
        Players take turns moving around the board and landing on action squares that trigger
        game actions. Cards are drawn from the six escalation tier decks, and the group moves
        up the tiers together, at whatever pace everyone agrees to.
      </p>
      <p style="font-size:1.0625rem;line-height:1.8;">
        There is no fixed script and no forced escalation. A Decree card or the Consent Cup is
        always within reach, so any player can redirect or pause the session at any time.
      </p>
      <div class="asset-ph" style="aspect-ratio:16/9;margin-top:2rem;" role="img" aria-label="Session-flow diagram — how a HeartStrings session moves through turns, tiers, and consent options">
        <span class="asset-ph-tag">Asset pending</span>
        <span class="asset-ph-path">/heartstrings/session-flow.svg</span>
        <span class="asset-ph-alt">Session-flow diagram — how a HeartStrings session moves through turns, tiers, and consent options</span>
      </div>
    </div>
  </section>

  <!-- What's in the box -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow">What's in the Box</p>
      <h2 style="margin-bottom:2.5rem;">350 cards, six tiers, three boards.</h2>
      <div class="mech-grid">
        <div class="card">
          <h3 style="margin-bottom:.875rem;color:#e4e7f2;">Six tier decks (300 cards)</h3>
          <p>One 50-card deck for each escalation tier: Initiate, Connect, Seduce, Stimulate, Edge, and Climax.</p>
        </div>
        <div class="card">
          <h3 style="margin-bottom:.875rem;color:#e4e7f2;">Decree deck (50 cards)</h3>
          <p>A separate 50-card deck. Decree cards let any player skip, redraw, or redirect play at any time.</p>
        </div>
        <div class="card">
          <h3 style="margin-bottom:.875rem;color:#e4e7f2;">The board (three versions)</h3>
          <p>A 20x20 board, a larger 20x40 board, and an ultimate double-sided board that unfolds and flips to change how the game is played.</p>
        </div>
      </div>

      <!-- Component render placeholders (assets pending) -->
      <div class="asset-ph-grid" style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr));margin-top:2rem;">
        <div class="asset-ph" style="aspect-ratio:16/10;" role="img" aria-label="Board render — the 20x20 board layout">
          <span class="asset-ph-tag">Asset pending</span>
          <span class="asset-ph-path">/heartstrings/board-20x20.png</span>
          <span class="asset-ph-alt">Board render — the 20x20 board layout</span>
        </div>
        <div class="asset-ph" style="aspect-ratio:16/10;" role="img" aria-label="Board render — the 20x40 board layout">
          <span class="asset-ph-tag">Asset pending</span>
          <span class="asset-ph-path">/heartstrings/board-20x40.png</span>
          <span class="asset-ph-alt">Board render — the 20x40 board layout</span>
        </div>
        <div class="asset-ph" style="aspect-ratio:16/10;" role="img" aria-label="Board render — the ultimate double-sided flip board">
          <span class="asset-ph-tag">Asset pending</span>
          <span class="asset-ph-path">/heartstrings/board-ultimate.png</span>
          <span class="asset-ph-alt">Board render — the ultimate double-sided flip board</span>
        </div>
        <img src="/heartstrings/tier-deck-backs.jpg" alt="Tier deck backs — the six escalation deck designs" style="width:100%;display:block;height:auto;border-radius:12px;" loading="lazy" />
        <div class="asset-ph" style="aspect-ratio:16/10;" role="img" aria-label="The Consent Cup component">
          <span class="asset-ph-tag">Asset pending</span>
          <span class="asset-ph-path">/heartstrings/consent-cup.png</span>
          <span class="asset-ph-alt">The Consent Cup component</span>
        </div>
        <div class="asset-ph" style="aspect-ratio:16/10;" role="img" aria-label="Token cutaway — play pieces detail">
          <span class="asset-ph-tag">Asset pending</span>
          <span class="asset-ph-path">/heartstrings/token-cutaway.png</span>
          <span class="asset-ph-alt">Token cutaway — play pieces detail</span>
        </div>
      </div>

      <!-- PENDING COMPONENT FACTS - do not publish quantities until Tash confirms:
           the Consent Cup as a physical component (and how many), play tokens / movers,
           dice, and any rulebook / insert cards. Add these here once confirmed. -->
    </div>
  </section>

  <!-- Player scaling -->
  <section class="section">
    <div class="container" style="max-width:760px;">
      <p class="eyebrow">Player Scaling</p>
      <h2 style="margin-bottom:1.25rem;">From two players to eighteen.</h2>
      <p style="font-size:1.0625rem;line-height:1.8;">
        HeartStrings Play is built for private groups of 2 to 18 players &mdash; an intimate
        session for a couple or a larger gathering of friends who have agreed to play together.
      </p>
    </div>
  </section>

  <!-- App companion -->
  <section class="section section-alt">
    <div class="container hs-app-companion">
      <div class="hs-app-text">
        <p class="eyebrow">Digital Companion</p>
        <h2>A companion app is in development.</h2>
        <p style="margin-top:1rem;font-size:1.0625rem;line-height:1.8;">
          HeartStrings Connect is a private Android companion in active development alongside HeartStrings Play.
          It is not available in any public app store. Screenshots show current private test UI.
        </p>
        <div style="margin-top:1.5rem;">
          <span class="badge badge-private">Private beta development</span>
        </div>
        <a href="/heartstrings-app" class="btn btn-outline btn-sm" style="margin-top:1.5rem;display:inline-flex;">See Connect Details &rarr;</a>
      </div>
      <div class="hs-app-screens" aria-hidden="true">
        <div class="hs-phone-mini">
          <img src="/heartstrings/screenshots/29_discover_carousel.png" alt="HeartStrings Connect discover carousel — private development" loading="lazy" />
        </div>
        <div class="hs-phone-mini hs-phone-offset">
          <img src="/heartstrings/screenshots/06_matches.png" alt="HeartStrings Connect matches screen — private development" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Status notice -->
  <section class="section">
    <div class="container" style="max-width:760px;">
      <div class="hs-status-box">
        <div class="hs-status-header">
          <span class="badge badge-prelaunch">Pre-launch</span>
          <strong>Manufacturing preparation underway</strong>
        </div>
        <p>HeartStrings Play has not been released for retail sale. No purchase date has been announced. Product design is complete. Manufacturing is in preparation. To express interest or be notified when pre-orders open, contact below.</p>
        <a href="/contact" class="btn btn-pink btn-sm" style="margin-top:1.25rem;">Express Interest</a>
      </div>
    </div>
  </section>

  <!-- Ecosystem note -->
  <section class="section-sm section-alt">
    <div class="container" style="max-width:760px;text-align:center;">
      <p style="font-size:.875rem;color:#4a5068;">Part of the ByteLite LLC ecosystem.</p>
      <p style="font-size:.875rem;color:#4a5068;margin-top:.375rem;">
        HeartStrings Play is the first public-facing product in a broader privacy-first company.
        Broader deterministic systems research remains private and proof-gated.
        <a href="/architecture" style="color:#555e7a;">The Architecture &rarr;</a>
      </p>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>

.hs-hero {
  padding: 6rem 0 4.5rem;
  background: radial-gradient(ellipse 70% 50% at 50% -5%, rgba(236,72,153,.07) 0%, transparent 70%);
}
.hs-hero h1 { max-width: 680px; }
.hs-hero-sub { max-width: 560px; margin-top: 1.25rem; font-size: 1.0625rem; color: #7b829e; line-height: 1.75; }
.hs-hero-badges { display: flex; align-items: center; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap; }
.hs-badge-detail { font-size: .8125rem; color: #555e7a; }
.hs-specs-row {
  display: flex; align-items: center; flex-wrap: wrap; gap: 1rem;
}
.hs-spec { text-align: center; flex: 1; min-width: 80px; }
.hs-spec-num { display: block; font-size: 2rem; font-weight: 700; color: #f472b6; letter-spacing: -.04em; line-height: 1; }
.hs-spec-label { font-size: .75rem; color: #7b829e; margin-top: .25rem; }
.hs-spec-div { width: 1px; height: 2.5rem; background: #1a2235; flex-shrink: 0; }
@media (max-width: 640px) { .hs-spec-div { display: none; } }
.paths-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
@media (max-width: 640px) { .paths-grid { grid-template-columns: 1fr; } }
.path-card {}
.path-name { font-size: 1.125rem; font-weight: 700; color: #f472b6; margin-bottom: .5rem; }
.path-contact .path-name { color: #ec4899; }
.path-desc { font-size: .9375rem; color: #7b829e; }
.tiers-list { display: flex; flex-direction: column; gap: .75rem; max-width: 640px; }
.tier-row {
  display: flex; align-items: center; gap: 1.25rem;
  background: #0d1120; border: 1px solid #1a2235;
  border-radius: .625rem; padding: 1rem 1.25rem;
  transition: border-color .2s;
}
.tier-row:hover { border-color: #24304a; }
.tier-num { font-size: .8125rem; font-weight: 600; color: #4a5068; width: 1.25rem; flex-shrink: 0; }
.tier-name { font-size: 1rem; font-weight: 600; color: #e4e7f2; min-width: 90px; }
.tier-desc { font-size: .9375rem; color: #7b829e; }
.mech-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
@media (max-width: 767px) { .mech-grid { grid-template-columns: 1fr; } }
.hs-app-companion {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 3rem;
  align-items: center;
}
@media (max-width: 767px) {
  .hs-app-companion { grid-template-columns: 1fr; }
  .hs-app-screens { display: none; }
}
.hs-app-screens {
  display: flex;
  gap: 1.25rem;
  justify-content: center;
  align-items: flex-start;
}
.hs-phone-mini {
  width: 140px;
  flex-shrink: 0;
  border-radius: 1.5rem;
  border: 1px solid #24304a;
  box-shadow: 0 8px 28px rgba(0,0,0,.45);
  overflow: hidden;
  background: #0d1120;
}
.hs-phone-mini img { width: 100%; height: auto; display: block; }
.hs-phone-offset { margin-top: 2rem; }
.hs-status-box {
  background: #0d1120; border: 1px solid #24304a;
  border-radius: .875rem; padding: 2rem;
}
.hs-status-header {
  display: flex; align-items: center; gap: 1rem;
  margin-bottom: 1rem; flex-wrap: wrap;
}
.hs-status-header strong { color: #e4e7f2; font-size: 1rem; }
.hs-status-box p { font-size: .9375rem; line-height: 1.7; }

</style>
