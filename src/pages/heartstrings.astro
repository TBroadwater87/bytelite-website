---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="HeartStrings - Relationship Intelligence Platform"
  description="HeartStrings is a deterministic relationship intelligence platform. Authentic connection through structured compatibility, honest matching rationale, and safety-first design. Built on ByteLite + Deep Kore infrastructure."
  keywords={["HeartStrings", "relationship platform", "deterministic matching", "AI dating", "compatibility engine", "ByteLite", "Deep Kore"]}
>

  <div class="page-banner" style="width:100%; overflow:hidden;">
    <img
      src="/HeartStrings_Banner.png"
      alt="HeartStrings - Relationship Intelligence Platform"
      style="width:100%; height:auto; display:block; max-height:480px; object-fit:cover;"
    />
  </div>

  <section class="hs-hero">
    <div class="container">
      <div class="hero-badge">Interface Prototype</div>
      <h1>HeartStrings</h1>
      <p class="hero-tagline">Relationship intelligence built on deterministic structure, not black-box scores.</p>
      <div class="hero-cta">
        <a href="/contact" class="btn btn-pink">Express Interest</a>
        <a href="/demo" class="btn btn-outline">See Demos</a>
      </div>
    </div>
  </section>

  <section class="hs-summary">
    <div class="container">
      <div class="summary-grid">
        <div class="summary-text">
          <h2>What HeartStrings Is</h2>
          <p>
            HeartStrings is a relationship platform that uses deterministic matching rationale instead
            of opaque recommendation scores. When you see a match, you see exactly why — structured
            compatibility dimensions, honest alignment on values, and a clear explanation of what
            you share and where you differ.
          </p>
          <p>
            It is built on the same deterministic engineering philosophy as ByteLite and Deep Kore.
            No mystery box. No engagement-optimized dark patterns. Authentic connection through
            transparent structure.
          </p>
        </div>
        <div class="summary-status">
          <h3>Current Status</h3>
          <ul class="status-list">
            <li><span class="dot prototype"></span> Interface design: Prototype stage</li>
            <li><span class="dot active"></span> Core matching logic: In development</li>
            <li><span class="dot active"></span> ByteLite integration: Planned</li>
            <li><span class="dot planned"></span> Public access: Post-ByteLite demo launch</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="hs-origin">
    <div class="container">
      <blockquote>
        "HeartStrings started as the problem that created ByteLite. AI models required too much
        storage and compute for an independent developer. That constraint became the research question
        that became ByteLite's architecture."
      </blockquote>
      <cite>— Tash Broadwater, Founder</cite>
    </div>
  </section>

  <!-- SECTION A: Interface Gallery -->
  <section class="hs-gallery">
    <div class="container">
      <h2>Interface Samples</h2>
      <p class="section-subtitle">
        Prototype UI - these panels show the planned HeartStrings interface design. Not yet backed by live matching data.
      </p>
      <div class="gallery-grid">

        <!-- Panel 1: Profile Card -->
        <div class="ui-panel panel-pink">
          <div class="preview-badge">Preview</div>
          <div class="panel-header">
            <span class="panel-label">Profile Card</span>
          </div>
          <div class="profile-name">Alex M.</div>
          <div class="profile-location">Helena, MT</div>
          <div class="profile-values">Authenticity | Depth | Growth</div>
          <div class="profile-intent">Intent: Long-term relationship</div>
          <div class="interest-tags">
            <span class="tag">Engineering</span>
            <span class="tag">Hiking</span>
            <span class="tag">Philosophy</span>
          </div>
          <div class="compat-row">
            <span class="compat-label">Compatibility</span>
            <span class="compat-pct">87%</span>
          </div>
          <div class="bar-track">
            <div class="bar-fill bar-pink" style="width:87%;"></div>
          </div>
          <button class="mock-btn btn-pink-sm" disabled>Match</button>
        </div>

        <!-- Panel 2: Match Detail View -->
        <div class="ui-panel panel-cyan">
          <div class="preview-badge">Preview</div>
          <div class="panel-header">
            <span class="panel-label">Why This Match</span>
          </div>
          <div class="dim-row">
            <span class="dim-name">Values alignment</span>
            <span class="dim-pct pct-green">94%</span>
          </div>
          <div class="bar-track"><div class="bar-fill bar-green" style="width:94%;"></div></div>
          <div class="dim-row">
            <span class="dim-name">Communication style</span>
            <span class="dim-pct pct-cyan">81%</span>
          </div>
          <div class="bar-track"><div class="bar-fill bar-cyan" style="width:81%;"></div></div>
          <div class="dim-row">
            <span class="dim-name">Life goals</span>
            <span class="dim-pct pct-green">89%</span>
          </div>
          <div class="bar-track"><div class="bar-fill bar-green" style="width:89%;"></div></div>
          <div class="dim-row dealbreaker-row">
            <span class="dim-name">Dealbreakers</span>
            <span class="check-ok">[OK] None flagged</span>
          </div>
          <a href="#" class="mock-link" onclick="return false;">See full breakdown</a>
        </div>

        <!-- Panel 3: Conversation Screen -->
        <div class="ui-panel panel-purple">
          <div class="preview-badge">Preview</div>
          <div class="panel-header">
            <span class="panel-label">Conversation</span>
          </div>
          <div class="chat-area">
            <div class="chat-msg chat-you">
              <span class="chat-sender">You:</span> What drew you to engineering originally?
            </div>
            <div class="chat-msg chat-them">
              <span class="chat-sender">Alex:</span> Honestly, it started with trying to build a better mousetrap as a kid...
            </div>
          </div>
          <div class="chat-input-bar">
            <span class="chat-input-placeholder">Type a message...</span>
          </div>
          <div class="conv-tip">
            HeartStrings tip: Authentic curiosity builds connection.
          </div>
        </div>

        <!-- Panel 4: Values and Intent Panel -->
        <div class="ui-panel panel-pink">
          <div class="preview-badge">Preview</div>
          <div class="panel-header">
            <span class="panel-label">Your Filters</span>
          </div>
          <div class="filter-list">
            <div class="filter-item">[x] Must share growth mindset</div>
            <div class="filter-item">[x] Open to long-term commitment</div>
            <div class="filter-item">[x] Respect for boundaries</div>
            <div class="filter-item">[x] Intellectual curiosity</div>
          </div>
          <div class="slider-visual">
            <span class="slider-label">Distance:</span>
            <span class="slider-track"><span class="slider-thumb" style="left:50%;"></span></span>
            <span class="slider-value">50 miles</span>
          </div>
          <div class="slider-visual">
            <span class="slider-label">Age range:</span>
            <span class="slider-track"><span class="slider-thumb" style="left:30%;"></span></span>
            <span class="slider-value">28-45</span>
          </div>
        </div>

        <!-- Panel 5: Safety Tools Panel -->
        <div class="ui-panel panel-green">
          <div class="preview-badge">Preview</div>
          <div class="panel-header">
            <span class="panel-label">Boundary Settings</span>
          </div>
          <div class="toggle-list">
            <div class="toggle-item">
              <span class="toggle-on">ON</span>
              <span class="toggle-label">Block unsolicited contact requests</span>
            </div>
            <div class="toggle-item">
              <span class="toggle-on">ON</span>
              <span class="toggle-label">Anonymous browsing mode</span>
            </div>
            <div class="toggle-item">
              <span class="toggle-on">ON</span>
              <span class="toggle-label">AI conversation screening</span>
            </div>
            <div class="toggle-item">
              <span class="toggle-on">ON</span>
              <span class="toggle-label">Match explanation required before chat</span>
            </div>
          </div>
          <div class="safety-note">
            HeartStrings requires that every match comes with a rationale. No blind swiping.
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- SECTION B: Clickable Prototype Flow -->
  <section class="hs-flow">
    <div class="container">
      <h2>How It Flows</h2>
      <p class="section-subtitle">
        Walk through the HeartStrings experience. Interactive Preview - local state only.
      </p>

      <div class="flow-step-indicators" id="flow-indicators">
        <button class="step-dot step-active" onclick="goToStep(1)">1</button>
        <button class="step-dot" onclick="goToStep(2)">2</button>
        <button class="step-dot" onclick="goToStep(3)">3</button>
        <button class="step-dot" onclick="goToStep(4)">4</button>
      </div>

      <div class="flow-panels">

        <!-- Step 1 -->
        <div class="flow-panel" id="flow-step-1">
          <div class="flow-card">
            <div class="flow-card-title">Your Profile</div>
            <div class="flow-row"><span class="flow-key">Compatibility style</span><span class="flow-val">Deep Connector</span></div>
            <div class="flow-row"><span class="flow-key">Top values</span><span class="flow-val">Authenticity, Depth, Intellectual curiosity</span></div>
            <div class="flow-row"><span class="flow-key">Intent</span><span class="flow-val">Long-term relationship</span></div>
            <div class="flow-row"><span class="flow-key">Match radius</span><span class="flow-val">50 miles</span></div>
            <div class="flow-badge-row">
              <span class="flow-badge">Profile Complete</span>
            </div>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="flow-panel flow-hidden" id="flow-step-2">
          <div class="flow-card">
            <div class="flow-card-title">Alex M. - 87% Match</div>
            <div class="flow-dim-row">
              <span class="flow-dim-name">Values</span>
              <span class="flow-dim-bar-wrap"><span class="flow-dim-bar bar-green" style="width:94%;"></span></span>
              <span class="flow-dim-pct">94%</span>
            </div>
            <div class="flow-dim-row">
              <span class="flow-dim-name">Communication</span>
              <span class="flow-dim-bar-wrap"><span class="flow-dim-bar bar-cyan" style="width:81%;"></span></span>
              <span class="flow-dim-pct">81%</span>
            </div>
            <div class="flow-dim-row">
              <span class="flow-dim-name">Life Goals</span>
              <span class="flow-dim-bar-wrap"><span class="flow-dim-bar bar-green" style="width:89%;"></span></span>
              <span class="flow-dim-pct">89%</span>
            </div>
            <div class="flow-dim-row">
              <span class="flow-dim-name">Emotional Intelligence</span>
              <span class="flow-dim-bar-wrap"><span class="flow-dim-bar bar-cyan" style="width:85%;"></span></span>
              <span class="flow-dim-pct">85%</span>
            </div>
            <div class="flow-dim-row">
              <span class="flow-dim-name">Shared Interests</span>
              <span class="flow-dim-bar-wrap"><span class="flow-dim-bar bar-pink" style="width:76%;"></span></span>
              <span class="flow-dim-pct">76%</span>
            </div>
            <div class="flow-note">These dimensions are weighted by what matters most to you.</div>
          </div>
        </div>

        <!-- Step 3 -->
        <div class="flow-panel flow-hidden" id="flow-step-3">
          <div class="flow-card">
            <div class="flow-card-title">Why Alex ranks above 94% of your matches:</div>
            <ul class="flow-bullet-list">
              <li>Shares your top value: Authenticity (confirmed, not inferred)</li>
              <li>Communication style: Reflective and direct (matches your preference)</li>
              <li>Life goal: Long-term commitment (stated, not assumed)</li>
              <li>No dealbreaker flags</li>
              <li>Mutual interest: Philosophy and systems thinking</li>
            </ul>
            <div class="flow-note">This rationale is built from stated preferences, not behavioral inference.</div>
          </div>
        </div>

        <!-- Step 4 -->
        <div class="flow-panel flow-hidden" id="flow-step-4">
          <div class="flow-card">
            <div class="flow-card-title">Conversation Starters</div>
            <div class="starter-card">"What project are you most proud of from the last year?"</div>
            <div class="starter-card">"You both listed philosophy - is there a thinker who changed how you see things?"</div>
            <div class="starter-card">"You flagged depth as your top value. What does that look like in your day-to-day?"</div>
            <button class="mock-btn btn-pink-sm" style="margin-top:1rem;" disabled>Start Conversation</button>
            <div class="flow-note">Conversation starters are generated from your shared match dimensions.</div>
          </div>
        </div>

      </div>

      <div class="flow-nav">
        <button class="flow-btn" id="flow-prev" onclick="flowNav(-1)" disabled>Previous</button>
        <button class="flow-btn flow-btn-primary" id="flow-next" onclick="flowNav(1)">Next</button>
      </div>

    </div>
  </section>

  <!-- SECTION C: Deterministic Match Explanation -->
  <section class="hs-deterministic">
    <div class="container">
      <h2>Why Deterministic Matching Matters</h2>
      <div class="det-grid">
        <div class="det-col">
          <h3 class="det-col-title col-title-pink">The Problem</h3>
          <p class="det-col-text">
            Most platforms use engagement-optimized recommendation engines that favor matches who will
            keep you swiping, not matches who will work out. The scoring is opaque. You cannot verify
            or contest it.
          </p>
        </div>
        <div class="det-col">
          <h3 class="det-col-title col-title-cyan">The HeartStrings Approach</h3>
          <p class="det-col-text">
            Every match is scored against your stated, structured preferences. The dimensions are
            public. The scoring logic is deterministic. If the same two profiles run through the
            system twice, they get the same score. No A/B testing on your relationship outcomes.
          </p>
        </div>
        <div class="det-col">
          <h3 class="det-col-title col-title-green">What You See</h3>
          <p class="det-col-text">
            A ranked list with a full rationale for each position. Not a swipe deck. Not a mystery
            algorithm. A structured explanation of why this person is or is not a good fit for what
            you said you wanted.
          </p>
        </div>
      </div>

      <div class="factor-table-wrap">
        <h3 class="factor-table-title">Sample Match Factor Table</h3>
        <table class="factor-table">
          <thead>
            <tr>
              <th>Factor</th>
              <th>Your Preference</th>
              <th>Their Profile</th>
              <th>Match</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Values</td>
              <td>Authenticity first</td>
              <td>Authenticity first</td>
              <td class="match-strong">Strong match</td>
            </tr>
            <tr>
              <td>Commitment</td>
              <td>Long-term</td>
              <td>Long-term</td>
              <td class="match-strong">Strong match</td>
            </tr>
            <tr>
              <td>Communication</td>
              <td>Direct + reflective</td>
              <td>Direct</td>
              <td class="match-good">Good match</td>
            </tr>
            <tr>
              <td>Distance</td>
              <td>50 miles</td>
              <td>12 miles</td>
              <td class="match-good">Within range</td>
            </tr>
          </tbody>
        </table>
      </div>

    </div>
  </section>

  <section class="hs-features">
    <div class="container">
      <h2>How It Works</h2>
      <div class="features-grid">

        <div class="feature-card">
          <div class="feature-icon-text">[+]</div>
          <h3>Structured Compatibility</h3>
          <p>
            Compatibility is not a single score. HeartStrings breaks it into explicit dimensions —
            values, communication style, life goals, boundaries — and shows you the breakdown.
          </p>
          <span class="status-badge prototype">Prototype UI</span>
        </div>

        <div class="feature-card">
          <div class="feature-icon-text">[?]</div>
          <h3>Match Rationale</h3>
          <p>
            Every match comes with a deterministic explanation: what aligned, what differs, and
            what is genuinely unknown. No black box. No engagement bait.
          </p>
          <span class="status-badge prototype">Prototype UI</span>
        </div>

        <div class="feature-card">
          <div class="feature-icon-text">[S]</div>
          <h3>Safety-First Design</h3>
          <p>
            Boundary settings, authenticity tools, and safety prompts built into the interaction
            layer — not added as an afterthought.
          </p>
          <span class="status-badge development">In Development</span>
        </div>

        <div class="feature-card">
          <div class="feature-icon-text">[B]</div>
          <h3>ByteLite Integration</h3>
          <p>
            HeartStrings is the first planned consumer application of ByteLite compression.
            AI model deployment at a fraction of traditional storage cost.
          </p>
          <span class="status-badge planned">Planned</span>
        </div>

        <div class="feature-card">
          <div class="feature-icon-text">[A]</div>
          <h3>AIya Conversation Layer</h3>
          <p>
            Deep Kore's AIya provides the conversation and reasoning layer —
            structured, deterministic, and governed by the Genesis Goal Keeper framework.
          </p>
          <span class="status-badge planned">Planned</span>
        </div>

        <div class="feature-card">
          <div class="feature-icon-text">[D]</div>
          <h3>Relationship Dashboard</h3>
          <p>
            A personal dashboard showing compatibility trends, communication health,
            and genuine insights — not engagement metrics dressed up as relationship data.
          </p>
          <span class="status-badge prototype">Prototype UI</span>
        </div>

      </div>
    </div>
  </section>

  <section class="hs-what-real">
    <div class="container">
      <h2>What Is Real Today</h2>
      <div class="reality-grid">
        <div class="reality-card live">
          <h3>Live Now</h3>
          <ul>
            <li>Interface design system</li>
            <li>Profile card components</li>
            <li>Compatibility dimension framework</li>
          </ul>
        </div>
        <div class="reality-card preview">
          <h3>Prototype / Preview</h3>
          <ul>
            <li>Match view UI</li>
            <li>Conversation screen layout</li>
            <li>Settings / values / intent filters</li>
            <li>Relationship dashboard wireframe</li>
          </ul>
        </div>
        <div class="reality-card development">
          <h3>In Development</h3>
          <ul>
            <li>Core matching engine</li>
            <li>Safety and authenticity tools</li>
            <li>ByteLite compression integration</li>
            <li>AIya conversation layer</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="hs-next">
    <div class="container">
      <h2>What Comes Next</h2>
      <p>
        HeartStrings expands after the ByteLite demonstration application launches.
        The sequence matters: ByteLite compression first, then HeartStrings as the first
        live deployment of that infrastructure.
      </p>
      <p>
        If you are interested in early access, partnership, or following development,
        reach out directly.
      </p>
      <div class="next-cta">
        <a href="/contact" class="btn btn-pink">Get In Touch</a>
        <a href="/news" class="btn btn-outline">Current Status</a>
      </div>
    </div>
  </section>

</Layout>

<script>
  let currentStep = 1;
  const totalSteps = 4;

  function showStep(n: number) {
    for (let i = 1; i <= totalSteps; i++) {
      const panel = document.getElementById('flow-step-' + i);
      const dots = document.querySelectorAll('.flow-step-indicators .step-dot');
      const dot = dots[i - 1];
      if (panel) {
        if (i === n) {
          panel.classList.remove('flow-hidden');
        } else {
          panel.classList.add('flow-hidden');
        }
      }
      if (dot) {
        if (i === n) {
          dot.classList.add('step-active');
        } else {
          dot.classList.remove('step-active');
        }
      }
    }
    const prevBtn = document.getElementById('flow-prev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('flow-next') as HTMLButtonElement | null;
    if (prevBtn) prevBtn.disabled = n <= 1;
    if (nextBtn) nextBtn.disabled = n >= totalSteps;
  }

  (window as any).goToStep = function(n: number) {
    currentStep = n;
    showStep(currentStep);
  };

  (window as any).flowNav = function(dir: number) {
    currentStep = Math.max(1, Math.min(totalSteps, currentStep + dir));
    showStep(currentStep);
  };
</script>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero */
  .hs-hero {
    padding: 8rem 0 5rem;
    text-align: center;
    background: linear-gradient(180deg, #0A0E27 0%, rgba(236, 72, 153, 0.05) 50%, #060813 100%);
    position: relative;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.375rem 1rem;
    border-radius: 100px;
    background: rgba(236, 72, 153, 0.1);
    border: 1px solid rgba(236, 72, 153, 0.3);
    color: #EC4899;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  .hs-hero h1 {
    font-size: clamp(3rem, 8vw, 6rem);
    font-weight: 800;
    background: linear-gradient(135deg, #F9A8D4 0%, #EC4899 50%, #BE185D 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0 0 1.5rem;
    line-height: 1;
  }

  .hero-tagline {
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    color: rgba(224, 224, 224, 0.8);
    max-width: 600px;
    margin: 0 auto 2.5rem;
    line-height: 1.5;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Buttons */
  .btn {
    padding: 0.875rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    display: inline-block;
    font-size: 1rem;
  }

  .btn-pink {
    background: linear-gradient(135deg, #EC4899 0%, #BE185D 100%);
    color: white;
  }

  .btn-pink:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(236, 72, 153, 0.4);
  }

  .btn-outline {
    background: transparent;
    color: #E0E0E0;
    border: 2px solid rgba(224, 224, 224, 0.3);
  }

  .btn-outline:hover {
    border-color: #EC4899;
    color: #EC4899;
    transform: translateY(-2px);
  }

  /* Summary */
  .hs-summary {
    padding: 5rem 0;
    background: #060813;
  }

  .summary-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .summary-text h2 {
    font-size: 2rem;
    font-weight: 700;
    color: #F9A8D4;
    margin: 0 0 1.5rem;
  }

  .summary-text p {
    color: rgba(224, 224, 224, 0.8);
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .summary-status {
    background: rgba(10, 14, 39, 0.7);
    border: 1px solid rgba(236, 72, 153, 0.2);
    border-radius: 12px;
    padding: 2rem;
  }

  .summary-status h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: #EC4899;
    margin: 0 0 1.25rem;
  }

  .status-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .status-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: rgba(224, 224, 224, 0.8);
    font-size: 0.9rem;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .dot.active { background: #22C55E; }
  .dot.prototype { background: #EC4899; }
  .dot.planned { background: #A855F7; }

  /* Origin */
  .hs-origin {
