---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="ByteLite LLC | Privacy-First Products and Deterministic Systems Research"
  description="ByteLite LLC builds HeartStrings Play, develops private companion tools, and advances research in privacy-first and deterministic software systems."
  keywords="ByteLite LLC, HeartStrings Play, deterministic systems research, privacy-first products, Helena Montana"
  
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="eyebrow">ByteLite LLC</p>
      <h1>Privacy-first products<br/>and deterministic systems research.</h1>
      <p class="hero-sub">
        ByteLite LLC builds HeartStrings Play, develops private companion tools,
        and advances research in more inspectable software systems.
        Built by one founder in Helena, Montana.
      </p>
      <div class="hero-cta">
        <a href="/heartstrings" class="btn btn-pink">Explore HeartStrings Play</a>
        <a href="/status" class="btn btn-outline">View Status</a>
        <a href="/contact" class="btn btn-ghost">Contact</a>
      </div>
    </div>
  </section>

  <!-- Status strip -->
  <section class="section-sm section-alt">
    <div class="container status-strip">
      <div class="status-item">
        <span class="status-label">HeartStrings Play</span>
        <span class="badge badge-prelaunch">Pre-launch</span>
      </div>
      <div class="status-divider"></div>
      <div class="status-item">
        <span class="status-label">HeartStrings App</span>
        <span class="badge badge-private">Private beta development</span>
      </div>
      <div class="status-divider"></div>
      <div class="status-item">
        <span class="status-label">ByteLite Research</span>
        <span class="badge badge-research">Private validation</span>
      </div>
    </div>
  </section>

  <!-- Featured: HeartStrings Play -->
  <section class="section">
    <div class="container featured-grid">
      <div class="featured-text">
        <p class="eyebrow">Featured Product</p>
        <h2>HeartStrings Play</h2>
        <p class="featured-desc">
          A premium adult social board game for private groups that want a more intentional,
          consent-first way to connect. Designed around escalating card-based play with
          clear boundaries and shared agency.
        </p>
        <div class="featured-specs">
          <div class="spec"><span class="spec-num">2–8</span><span class="spec-label">Players</span></div>
          <div class="spec"><span class="spec-num">305</span><span class="spec-label">Cards</span></div>
          <div class="spec"><span class="spec-num">5</span><span class="spec-label">Path types</span></div>
          <div class="spec"><span class="spec-num">6</span><span class="spec-label">Tiers</span></div>
        </div>
        <div style="display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1.75rem;">
          <a href="/heartstrings" class="btn btn-pink">See HeartStrings Play</a>
          <a href="/contact" class="btn btn-outline btn-sm" style="align-self:center;">Express Interest</a>
        </div>
      </div>
      <div class="featured-badge-area">
        <div class="featured-badge">
          <div class="fb-inner">
            <div class="fb-title">HeartStrings Play</div>
            <div class="fb-status"><span class="badge badge-prelaunch">Pre-launch</span></div>
            <div class="fb-tagline">Consent-first.<br/>Adult social play.<br/>Private groups.</div>
            <div class="fb-detail">Manufacturing preparation underway.<br/>No retail release date announced.</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Ecosystem cards -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow" style="text-align:center;">The ByteLite LLC Ecosystem</p>
      <h2 style="text-align:center;margin-bottom:3rem;">Four projects. One company.</h2>
      <div class="eco-grid">
        <a href="/heartstrings" class="card eco-card eco-play">
          <div class="eco-header">
            <span class="badge badge-prelaunch">Pre-launch</span>
          </div>
          <h3 class="eco-title">HeartStrings Play</h3>
          <p class="eco-desc">Premium adult social board game. Consent-first. 2–8 players. Pre-launch manufacturing preparation.</p>
          <span class="eco-arrow">Explore &rarr;</span>
        </a>
        <a href="/heartstrings-app" class="card eco-card eco-app">
          <div class="eco-header">
            <span class="badge badge-private">Private beta</span>
          </div>
          <h3 class="eco-title">HeartStrings App</h3>
          <p class="eco-desc">Private-test digital companion for the HeartStrings ecosystem. No public app store release yet.</p>
          <span class="eco-arrow">See App &rarr;</span>
        </a>
        <a href="/research" class="card eco-card eco-research">
          <div class="eco-header">
            <span class="badge badge-research">Private research</span>
          </div>
          <h3 class="eco-title">ByteLite Research</h3>
          <p class="eco-desc">Private deterministic infrastructure research. Mechanisms intentionally not public during validation.</p>
          <span class="eco-arrow">See Research &rarr;</span>
        </a>
        <a href="/research#deep-kore" class="card eco-card eco-deepkore">
          <div class="eco-header">
            <span class="badge badge-research">Private research</span>
          </div>
          <h3 class="eco-title">Deep Kore / AIya</h3>
          <p class="eco-desc">Private reasoning research and guide concept. Not a public AI product.</p>
          <span class="eco-arrow">See Research &rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Privacy stance -->
  <section class="section">
    <div class="container" style="max-width:760px;">
      <p class="eyebrow" style="text-align:center;">Privacy First</p>
      <h2 style="text-align:center;margin-bottom:1.5rem;">Privacy as a starting constraint,<br/>not an afterthought.</h2>
      <p style="text-align:center;font-size:1.0625rem;line-height:1.8;">
        ByteLite LLC builds products where privacy is a design requirement, not a legal checkbox.
        No surveillance advertising. No data brokering. No hidden collection.
        Product status is clearly separated from research status, so nothing is implied that is not real.
      </p>
    </div>
  </section>

  <!-- Founder / About -->
  <section class="section section-alt">
    <div class="container" style="max-width:760px;text-align:center;">
      <p class="eyebrow">The Company</p>
      <h2 style="margin-bottom:1.5rem;">Founder-led from Helena, Montana.</h2>
      <p style="font-size:1.0625rem;line-height:1.8;margin-bottom:2rem;">
        ByteLite LLC is a solo-founder company. One team, four projects, clear product status.
        HeartStrings Play is the public-facing product. Research into deterministic systems continues privately.
        No investor pressure to overclaim. No hype that cannot be defended.
      </p>
      <a href="/about" class="btn btn-outline">About ByteLite LLC</a>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="section">
    <div class="container cta-block">
      <h2>Questions or partnership inquiries?</h2>
      <p>HeartStrings Play pre-launch interest, app beta requests, research partnerships, and investor conversations are all welcome.</p>
      <a href="/contact" class="btn btn-primary">Get in touch</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>

.hero {
  padding: 7rem 0 5rem;
  background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(99,102,241,.08) 0%, transparent 70%);
}
.hero h1 { max-width: 720px; }
.hero-sub {
  max-width: 600px; font-size: 1.125rem; margin-top: 1.5rem;
  color: #7b829e; line-height: 1.7;
}
.hero-cta { display: flex; flex-wrap: wrap; gap: .875rem; margin-top: 2.25rem; }
@media (max-width: 540px) { .hero { padding: 4.5rem 0 3.5rem; } }

/* Status strip */
.status-strip {
  display: flex; align-items: center; flex-wrap: wrap; gap: 1rem;
}
.status-item { display: flex; align-items: center; gap: .875rem; }
.status-label { font-size: .9375rem; font-weight: 500; color: #e4e7f2; }
.status-divider {
  width: 1px; height: 1.75rem; background: #1a2235; flex-shrink: 0;
}
@media (max-width: 767px) { .status-divider { display: none; } }

/* Featured grid */
.featured-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;
}
@media (max-width: 767px) { .featured-grid { grid-template-columns: 1fr; gap: 3rem; } }
.featured-desc { font-size: 1.0625rem; margin-top: 1rem; line-height: 1.75; }
.featured-specs {
  display: flex; gap: 2rem; margin-top: 2rem; flex-wrap: wrap;
}
.spec { text-align: center; }
.spec-num {
  display: block; font-size: 2rem; font-weight: 700; color: #e4e7f2;
  line-height: 1; letter-spacing: -.04em;
}
.spec-label { font-size: .8125rem; color: #7b829e; margin-top: .25rem; }
.featured-badge-area {
  display: flex; justify-content: center; align-items: center;
}
.featured-badge {
  background: #0d1120; border: 1px solid #24304a;
  border-radius: 1rem; padding: 2.5rem; max-width: 320px; width: 100%;
  background: linear-gradient(135deg, #0d1120 0%, #12142b 100%);
  box-shadow: 0 0 40px rgba(236,72,153,.06);
}
.fb-inner { display: flex; flex-direction: column; gap: 1rem; }
.fb-title { font-size: 1.375rem; font-weight: 700; color: #e4e7f2; }
.fb-status {}
.fb-tagline { font-size: .9375rem; color: #a0a8c0; line-height: 1.6; }
.fb-detail { font-size: .8125rem; color: #4a5068; line-height: 1.6; }

/* Eco grid */
.eco-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
@media (max-width: 767px) { .eco-grid { grid-template-columns: 1fr; } }
.eco-card { display: flex; flex-direction: column; gap: .875rem; text-decoration: none; }
.eco-header {}
.eco-title { color: #e4e7f2; margin: 0; }
.eco-desc { color: #7b829e; font-size: .9375rem; flex: 1; }
.eco-play .eco-title, .eco-play .eco-arrow { color: #f472b6; }
.eco-app .eco-title, .eco-app .eco-arrow { color: #818cf8; }
.eco-research .eco-title, .eco-research .eco-arrow { color: #6366f1; }
.eco-deepkore .eco-title, .eco-deepkore .eco-arrow { color: #a78bfa; }
.eco-arrow { font-size: .875rem; font-weight: 500; margin-top: auto; }

/* CTA block */
.cta-block {
  background: #0d1120; border: 1px solid #1a2235;
  border-radius: 1rem; padding: 3.5rem; text-align: center;
}
.cta-block h2 { margin-bottom: 1rem; }
.cta-block p { max-width: 480px; margin: 0 auto 2rem; font-size: 1.0625rem; }

</style>
