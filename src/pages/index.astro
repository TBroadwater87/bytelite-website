---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="ByteLite LLC | Deterministic Structure for Digital Information"
  description="Privacy-first consumer products and private deterministic systems research from Helena, Montana."
  keywords="ByteLite LLC, HeartStrings Play, deterministic systems research, privacy-first products, Helena Montana"
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="hero">
    <div class="container">
      <p class="eyebrow">ByteLite LLC</p>
      <h1>Play that starts<br/>with consent.</h1>
      <p class="hero-sub">
        ByteLite builds privacy-first products and deterministic systems.
        HeartStrings is the first public product &mdash; a consent-first social
        board game for private groups.
      </p>
      <div style="display:flex;gap:.875rem;flex-wrap:wrap;margin-top:2rem;">
        <a href="/heartstrings" class="btn btn-pink">Explore HeartStrings</a>
        <a href="/status" class="btn btn-outline">View Status</a>
        <a href="/contact" class="btn btn-ghost">Contact</a>
      </div>
    </div>
  </section>

  <!-- HeartStrings hero image (asset pending) -->
  <section class="section-sm">
    <div class="container">
      <div class="asset-ph" style="aspect-ratio:16/9;max-width:960px;margin:0 auto;" role="img" aria-label="HeartStrings Play lifestyle hero image — the game set up for a private group">
        <span class="asset-ph-tag">Asset pending</span>
        <span class="asset-ph-path">/home/heartstrings-hero-16x9.jpg</span>
        <span class="asset-ph-alt">HeartStrings Play lifestyle hero image — the game set up for a private group</span>
      </div>
    </div>
  </section>

  <!-- Split-funnel path cards -->
  <section class="section">
    <div class="container">
      <p class="bridge-text">
        ByteLite LLC develops consumer-facing experiences and private deterministic systems
        under one roof. Public pages are intentionally divided so each audience sees the
        correct context without exposing private mechanisms.
      </p>
      <div class="path-grid">

        <!-- Consumer path -->
        <a href="/heartstrings" class="path-card path-card-consumer">
          <div class="path-card-inner">
            <div class="path-eyebrow">Consumer Products</div>
            <h2 class="path-title">HeartStrings Play</h2>
            <p class="path-desc">
              HeartStrings Play and the HeartStrings ecosystem.
              A consent-first adult social board game designed around connection,
              playful choice, and shared boundaries.
              Pre-launch interest is open while final production materials are prepared.
            </p>
            <div class="path-specs">
              <span>2–18 players</span>
              <span>350 cards</span>
              <span>6 escalation tiers</span>
              <span>Pre-launch</span>
            </div>
            <div class="path-cta">
              <span class="badge badge-prelaunch">Pre-launch</span>
              <span class="path-arrow">Explore HeartStrings &rarr;</span>
            </div>
          </div>
        </a>

        <!-- Research path -->
        <a href="/research" class="path-card path-card-research">
          <div class="path-card-inner">
            <div class="path-eyebrow path-eyebrow-research">Deterministic Systems Research</div>
            <h2 class="path-title path-title-research">ByteLite Research</h2>
            <p class="path-desc">
              ByteLite, Deep Kore, AIya, and private validation work.
              Private deterministic digital information systems research.
              Internal mechanisms remain private during validation.
            </p>
            <div class="path-tags">
              <span class="path-tag">Deterministic structure</span>
              <span class="path-tag">Proof-gated</span>
              <span class="path-tag">Private validation</span>
              <span class="path-tag">Exact round-trip</span>
            </div>
            <div class="path-cta">
              <span class="badge badge-research">Private research</span>
              <span class="path-arrow path-arrow-research">See Research &rarr;</span>
            </div>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- Company brief -->
  <section class="section section-alt">
    <div class="container" style="max-width:760px;text-align:center;">
      <p class="eyebrow">The Company</p>
      <h2 style="margin-bottom:1.5rem;">Founder-led from Helena, Montana.</h2>
      <p style="font-size:1.0625rem;line-height:1.8;margin-bottom:.875rem;">
        ByteLite LLC is an independent systems and product company based in Helena, Montana.
        The company develops HeartStrings consumer products while privately validating
        deterministic digital information and reasoning systems.
      </p>
      <p style="font-size:1.0625rem;line-height:1.8;margin-bottom:2rem;color:#555e7a;">
        No investor pressure to overclaim. No hype that cannot be defended. Product status
        is clearly separated from research status.
      </p>
      <div class="asset-ph" style="aspect-ratio:16/9;max-width:640px;margin:0 auto 2rem;" role="img" aria-label="ByteLite structure graphic — how privacy-first products and deterministic systems relate under one company">
        <span class="asset-ph-tag">Asset pending</span>
        <span class="asset-ph-path">/home/bytelite-structure.svg</span>
        <span class="asset-ph-alt">ByteLite structure graphic — how privacy-first products and deterministic systems relate under one company</span>
      </div>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/about" class="btn btn-outline">About ByteLite LLC</a>
        <a href="/status" class="btn btn-ghost">View Status</a>
      </div>
    </div>
  </section>

  <!-- Ecosystem strip (asset pending) -->
  <section class="section-sm section-alt">
    <div class="container">
      <div class="asset-ph" style="aspect-ratio:6/1;min-height:120px;" role="img" aria-label="ByteLite ecosystem strip — HeartStrings Play, HeartStrings Connect, and ByteLite Research shown together">
        <span class="asset-ph-tag">Asset pending</span>
        <span class="asset-ph-path">/home/ecosystem-strip.png</span>
        <span class="asset-ph-alt">ByteLite ecosystem strip — HeartStrings Play, HeartStrings Connect, and ByteLite Research shown together</span>
      </div>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="section">
    <div class="container cta-block">
      <h2>Questions or partnership inquiries?</h2>
      <p>
        HeartStrings Play pre-launch interest, research partnerships,
        controlled validation discussions, and investor conversations are all welcome.
      </p>
      <a href="/contact" class="btn btn-primary">Get in touch</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>

/* Hero */
.hero {
  padding: 7rem 0 5rem;
  background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(99,102,241,.08) 0%, transparent 70%);
}
.hero h1 { max-width: 680px; }
.hero-sub {
  max-width: 580px; font-size: 1.125rem; margin-top: 1.5rem;
  color: #7b829e; line-height: 1.7;
}
@media (max-width: 540px) { .hero { padding: 4.5rem 0 3.5rem; } }

/* Bridge text */
.bridge-text {
  font-size: 1rem; color: #555e7a; line-height: 1.8;
  max-width: 720px; margin: 0 auto 2.5rem;
  text-align: center;
}

/* Split-path grid */
.path-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;
  max-width: 960px; margin: 0 auto;
}
@media (max-width: 767px) { .path-grid { grid-template-columns: 1fr; } }

.path-card {
  display: block; border-radius: 1rem; text-decoration: none;
  transition: transform .2s, box-shadow .2s;
  overflow: hidden;
}
.path-card:hover { transform: translateY(-2px); }

.path-card-consumer {
  background: linear-gradient(135deg, #100d16 0%, #160b1a 100%);
  border: 1px solid rgba(244,114,182,.2);
  box-shadow: 0 0 40px rgba(236,72,153,.05);
}
.path-card-consumer:hover {
  border-color: rgba(244,114,182,.35);
  box-shadow: 0 8px 32px rgba(236,72,153,.1);
}

.path-card-research {
  background: linear-gradient(135deg, #090d14 0%, #0b0f1c 100%);
  border: 1px solid rgba(99,102,241,.2);
  box-shadow: 0 0 40px rgba(99,102,241,.04);
}
.path-card-research:hover {
  border-color: rgba(99,102,241,.35);
  box-shadow: 0 8px 32px rgba(99,102,241,.1);
}

.path-card-inner {
  padding: 2.25rem 2rem 2rem;
  display: flex; flex-direction: column; gap: 1.125rem; height: 100%;
}

.path-eyebrow {
  font-size: .6875rem; font-weight: 700; letter-spacing: .12em;
  text-transform: uppercase; color: #f472b6;
}
.path-eyebrow-research { color: #818cf8; }

.path-title {
  font-size: clamp(1.375rem, 2.5vw, 1.75rem);
  font-weight: 700; color: #e4e7f2;
  line-height: 1.15; letter-spacing: -.02em;
  margin: 0;
}
.path-title-research { color: #c4c8f0; }

.path-desc {
  font-size: .9375rem; color: #7b829e; line-height: 1.75;
  margin: 0; flex: 1;
}

/* Consumer specs row */
.path-specs {
  display: flex; flex-wrap: wrap; gap: .5rem;
}
.path-specs span {
  font-size: .75rem; color: #c4739a;
  background: rgba(244,114,182,.08); border: 1px solid rgba(244,114,182,.15);
  border-radius: .375rem; padding: .25rem .625rem;
  font-weight: 500;
}

/* Research tags */
.path-tags { display: flex; flex-wrap: wrap; gap: .5rem; }
.path-tag {
  font-size: .75rem; font-family: monospace; color: #818cf8;
  background: rgba(99,102,241,.08); border: 1px solid rgba(99,102,241,.15);
  border-radius: .375rem; padding: .25rem .625rem;
}

/* CTA row */
.path-cta {
  display: flex; align-items: center; justify-content: space-between;
  gap: .75rem; flex-wrap: wrap; margin-top: .25rem;
}
.path-arrow {
  font-size: .875rem; font-weight: 500; color: #f472b6;
  transition: color .15s;
}
.path-arrow-research { color: #818cf8; }
.path-card:hover .path-arrow { color: #fb7eb2; }
.path-card:hover .path-arrow-research { color: #a5b4fc; }

/* CTA block */
.cta-block {
  background: #0d1120; border: 1px solid #1a2235;
  border-radius: 1rem; padding: 3.5rem; text-align: center;
}
.cta-block h2 { margin-bottom: 1rem; }
.cta-block p { max-width: 480px; margin: 0 auto 2rem; font-size: 1.0625rem; }

</style>
