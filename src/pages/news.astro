---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout title="Updates | ByteLite LLC" noindex={true}>
  <Header slot="header" />
  <section style="padding:6rem 0;text-align:center;">
    <div style="max-width:560px;margin:0 auto;padding:0 1.5rem;">
      <p style="font-size:.75rem;color:#4a5068;letter-spacing:.1em;text-transform:uppercase;margin-bottom:.75rem;">Archive</p>
      <h1 style="font-size:1.75rem;color:#e4e7f2;margin-bottom:1rem;">Updates</h1>
      <p style="color:#7b829e;line-height:1.7;margin-bottom:2rem;">This page has been archived and is no longer part of the primary public site. For current information, visit the links below.</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
        <a href="/" style="background:#6366f1;color:#fff;padding:.75rem 1.5rem;border-radius:.5rem;font-size:.875rem;">Home</a>
        <a href="/status" style="background:#0d1120;color:#818cf8;border:1px solid #1a2235;padding:.75rem 1.5rem;border-radius:.5rem;font-size:.875rem;">Status</a>
      </div>
    </div>
  </section>
  <Footer slot="footer" />
</Layout>
