---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Research | ByteLite LLC"
  description="Private deterministic digital information systems research. Current validation focuses on compression-related proof surfaces, exact lossless round-trip behavior, and deterministic structural transformation laws."
  keywords="ByteLite LLC research, deterministic systems, private research, Helena Montana"
>
  <Header slot="header" />

  <!-- Hero -->
  <section class="res-hero">
    <div class="container">
      <p class="eyebrow">Deterministic Systems Research</p>
      <h1>Private systems research.</h1>
      <p class="res-hero-sub">
        ByteLite LLC conducts private research into deterministic digital information systems,
        verification-focused infrastructure, and deterministic reasoning.
        Technical mechanisms are intentionally not public during validation.
      </p>
    </div>
  </section>

  <!-- Proof boundary — required explicit statements -->
  <section class="section-sm">
    <div class="container">
      <div class="proof-boundary">
        <div class="proof-boundary-icon">&#9632;</div>
        <div class="proof-boundary-body">
          <div class="proof-boundary-title">Explicit proof posture</div>
          <p>
            Production-scale real-file compression is not publicly claimed.
            Internal mechanisms remain private during validation.
            Research status does not constitute a claim of commercial readiness,
            public availability, or independent verification.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Architecture link -->
  <section class="section-sm section-alt">
    <div class="container res-arch-band">
      <div>
        <p class="eyebrow">Architecture without mechanism disclosure.</p>
        <p style="font-size:.9375rem;color:#7b829e;margin-top:.5rem;line-height:1.7;">
          The Architecture page explains how ByteLite LLC thinks about deterministic structure,
          reasoning, governance, and proof-gated development without exposing trade-secret mechanisms.
          Technical details remain private during validation.
        </p>
      </div>
      <a href="/architecture" class="btn btn-outline" style="flex-shrink:0;">Explore the Architecture</a>
    </div>
  </section>

  <!-- ByteLite Research -->
  <section class="section section-alt">
    <div class="container" style="max-width:860px;">
      <p class="eyebrow">ByteLite</p>
      <h2 style="margin-bottom:1.25rem;">ByteLite Research</h2>
      <p class="res-body-text">
        Private deterministic digital information systems research.
        Current validation focuses on compression-related proof surfaces,
        exact lossless round-trip behavior, strict artifact accounting,
        and deterministic structural transformation laws.
        Production-scale real-file compression is not publicly claimed.
        Internal mechanisms remain private during validation.
      </p>
      <div class="res-tags" style="margin-top:1.5rem;">
        <span class="res-tag">Compression-related validation</span>
        <span class="res-tag">Exact lossless round-trip</span>
        <span class="res-tag">Strict artifact accounting</span>
        <span class="res-tag">Deterministic structural laws</span>
        <span class="res-tag">Proof-gated claims</span>
      </div>
      <div style="margin-top:1.5rem;"><span class="badge badge-research">Private research</span></div>
    </div>
  </section>

  <!-- Deep Kore / AIya -->
  <section class="section" id="deep-kore">
    <div class="container" style="max-width:860px;">
      <p class="eyebrow">Deep Kore / AIya</p>
      <h2 style="margin-bottom:1.25rem;">Private deterministic reasoning infrastructure.</h2>
      <p class="res-body-text">
        Private deterministic reasoning infrastructure focused on lawful structure,
        relation edges, auditability, and controlled answer selection.
        AIya is the human-facing interaction layer.
        These are private research systems, not public AI products.
      </p>
      <div class="deepkore-stance" style="margin-top:1.5rem;">
        <div class="stance-item">
          <span class="stance-no">&#10005;</span>
          <span>Not a public AI product</span>
        </div>
        <div class="stance-item">
          <span class="stance-no">&#10005;</span>
          <span>No architecture details are public</span>
        </div>
        <div class="stance-item">
          <span class="stance-no">&#10005;</span>
          <span>Not a public commercial product</span>
        </div>
        <div class="stance-item">
          <span class="stance-yes">&#10003;</span>
          <span>Safety-first and proof-gated principles govern all research</span>
        </div>
        <div class="stance-item">
          <span class="stance-yes">&#10003;</span>
          <span>Internal mechanisms remain private during validation</span>
        </div>
      </div>
      <div style="margin-top:1.5rem;"><span class="badge badge-research">Private research</span></div>
    </div>
  </section>

  <!-- Engineering Philosophy -->
  <section class="section section-alt">
    <div class="container" style="max-width:860px;">
      <p class="eyebrow">Engineering Philosophy</p>
      <h2 style="margin-bottom:1.25rem;">Engineering Philosophy</h2>
      <p class="res-body-text">
        ByteLite LLC prioritizes deterministic behavior, local validation, exact round-trip
        correctness, privacy, and proof-gated claims. We avoid public mechanism disclosure
        during validation and do not position private research as production capability
        before proof closes.
      </p>
      <p class="res-body-text" style="margin-top:1rem;">
        Designed for private validation and controlled deployment, without dependence on
        black-box hosted mechanisms for core claims.
      </p>
      <div class="philosophy-grid" style="margin-top:2rem;">
        <div class="card philosophy-card">
          <div class="philosophy-icon" style="color:#6366f1;">&#9632;</div>
          <h4 style="color:#e4e7f2;margin:.625rem 0 .5rem;">Deterministic behavior</h4>
          <p style="font-size:.875rem;">System behavior is predictable, inspectable, and not probabilistic for core correctness claims.</p>
        </div>
        <div class="card philosophy-card">
          <div class="philosophy-icon" style="color:#60a5fa;">&#9632;</div>
          <h4 style="color:#e4e7f2;margin:.625rem 0 .5rem;">Exact round-trip correctness</h4>
          <p style="font-size:.875rem;">Lossless reconstruction is a hard requirement, not an approximation target.</p>
        </div>
        <div class="card philosophy-card">
          <div class="philosophy-icon" style="color:#34d399;">&#9632;</div>
          <h4 style="color:#e4e7f2;margin:.625rem 0 .5rem;">Proof-gated claims</h4>
          <p style="font-size:.875rem;">No public claim is made before the underlying proof closes. Research status is separated from production status.</p>
        </div>
        <div class="card philosophy-card">
          <div class="philosophy-icon" style="color:#a78bfa;">&#9632;</div>
          <h4 style="color:#e4e7f2;margin:.625rem 0 .5rem;">Private mechanism protection</h4>
          <p style="font-size:.875rem;">Internal mechanisms remain private during validation. Technical details shared only under appropriate agreements.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Public boundary -->
  <section class="section">
    <div class="container" style="max-width:760px;">
      <p class="eyebrow">Public Boundary</p>
      <h2 style="margin-bottom:1.25rem;">What is intentionally not public.</h2>
      <p style="font-size:1.0625rem;line-height:1.8;margin-bottom:1.5rem;">
        Detailed technical mechanisms for all research areas are intentionally not public
        while development and validation continue.
      </p>
      <div class="boundary-box">
        <h4 style="color:#e4e7f2;margin-bottom:1rem;">No public claim exists for:</h4>
        <ul class="boundary-list">
          <li>Production-scale real-file compression</li>
          <li>A public production data infrastructure product</li>
          <li>A public API of any kind</li>
          <li>Published independent benchmark results</li>
          <li>A public AI or reasoning system</li>
          <li>Public mechanism or architecture disclosure</li>
        </ul>
      </div>
      <p style="font-size:.9375rem;color:#555e7a;margin-top:1.5rem;">
        Research, partnership, and investor inquiries are welcome.
        Technical details are shared selectively under appropriate agreements.
      </p>
    </div>
  </section>

  <!-- Contact CTA -->
  <section class="section section-alt">
    <div class="container cta-block-alt">
      <h2>Research, partnership, and investor inquiries.</h2>
      <p>Technical details are not public by default. To discuss research, partnership potential, or investment, contact directly.</p>
      <a href="/contact" class="btn btn-primary">Contact ByteLite LLC</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>

.res-hero {
  padding: 6rem 0 4.5rem;
  background: radial-gradient(ellipse 70% 50% at 50% -5%, rgba(99,102,241,.06) 0%, transparent 70%);
}
.res-hero h1 { max-width: 640px; }
.res-hero-sub { max-width: 600px; margin-top: 1.25rem; font-size: 1.0625rem; color: #7b829e; line-height: 1.75; }

/* Proof boundary box */
.proof-boundary {
  display: flex; gap: 1.25rem; align-items: flex-start;
  background: linear-gradient(135deg, rgba(251,146,60,.06) 0%, rgba(99,102,241,.04) 100%);
  border: 1px solid rgba(251,146,60,.25); border-radius: .75rem;
  padding: 1.5rem 1.75rem;
}
.proof-boundary-icon { color: #fb923c; font-size: .625rem; flex-shrink: 0; margin-top: .35rem; }
.proof-boundary-body {}
.proof-boundary-title {
  font-size: .6875rem; font-weight: 700; letter-spacing: .1em;
  text-transform: uppercase; color: #fb923c; margin-bottom: .625rem;
}
.proof-boundary p { font-size: .9375rem; color: #a0a8c0; line-height: 1.75; margin: 0; }

/* Architecture band */
.res-arch-band {
  display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap;
  padding: 1.5rem 0;
}

/* Body text */
.res-body-text { font-size: 1.0625rem; color: #a0a8c0; line-height: 1.8; margin: 0; }

/* Tags */
.res-tags { display: flex; flex-wrap: wrap; gap: .5rem; }
.res-tag {
  font-size: .75rem; font-family: monospace; color: #818cf8;
  background: rgba(99,102,241,.08); border: 1px solid rgba(99,102,241,.15);
  border-radius: .375rem; padding: .3rem .75rem;
}

/* Deep Kore stance */
.deepkore-stance { display: flex; flex-direction: column; gap: .875rem; }
.stance-item { display: flex; align-items: center; gap: .875rem; }
.stance-item span:last-child { font-size: .9375rem; color: #a0a8c0; }
.stance-no { color: #f87171; font-size: 1rem; flex-shrink: 0; width: 1.25rem; text-align: center; }
.stance-yes { color: #34d399; font-size: 1rem; flex-shrink: 0; width: 1.25rem; text-align: center; }

/* Philosophy */
.philosophy-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
@media (max-width: 640px) { .philosophy-grid { grid-template-columns: 1fr; } }
.philosophy-card { display: flex; flex-direction: column; gap: .25rem; }
.philosophy-icon { font-size: .625rem; }
.philosophy-card p { font-size: .875rem; color: #7b829e; line-height: 1.65; margin: 0; }

/* Boundary */
.boundary-box {
  background: #111828; border: 1px solid #1a2235; border-radius: .75rem; padding: 1.75rem;
}
.boundary-list { list-style: none; display: flex; flex-direction: column; gap: .625rem; }
.boundary-list li { font-size: .9375rem; color: #7b829e; padding-left: 1.25rem; position: relative; }
.boundary-list li::before { content: "—"; position: absolute; left: 0; color: #4a5068; }

/* CTA */
.cta-block-alt {
  background: #0d1120; border: 1px solid #1a2235; border-radius: 1rem;
  padding: 3.5rem; text-align: center;
}
.cta-block-alt h2 { margin-bottom: 1rem; }
.cta-block-alt p { max-width: 480px; margin: 0 auto 2rem; font-size: 1.0625rem; }

</style>
