---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Status | ByteLite LLC"
  description="Current public status for HeartStrings Play, HeartStrings App, ByteLite research, Deep Kore / AIya, and related projects."
  keywords="ByteLite LLC status, HeartStrings status, product status"
  
>
  <Header slot="header" />

  <!-- Header -->
  <section class="st-hero">
    <div class="container">
      <p class="eyebrow">ByteLite LLC</p>
      <h1>Public Status</h1>
      <p class="st-sub">
        Canonical product status for ByteLite LLC.
        Status is separated from claims.
        Last updated: July 2026.
      </p>
    </div>
  </section>

  <!-- Product status table -->
  <section class="section section-alt">
    <div class="container">
      <h2 style="margin-bottom:2rem;">Product &amp; Project Status</h2>
      <div class="st-table">
        <div class="st-row st-header">
          <span>Product / Project</span>
          <span>Status</span>
          <span>Notes</span>
        </div>

        <div class="st-row">
          <span class="st-name"><a href="/heartstrings">HeartStrings Play</a></span>
          <span><span class="badge badge-prelaunch">Pre-launch</span></span>
          <span class="st-notes">Board game design and manufacturing preparation. No retail release date announced. No purchase available yet.</span>
        </div>

        <div class="st-row">
          <span class="st-name"><a href="/heartstrings-app">HeartStrings App</a></span>
          <span><span class="badge badge-private">Private test</span></span>
          <span class="st-notes">Private Android test builds only. No public app store listing. No public download available.</span>
        </div>

        <div class="st-row">
          <span class="st-name"><a href="/marketing">HeartStrings Restaurant Program</a></span>
          <span><span class="badge badge-active">Live &middot; pilot</span></span>
          <span class="st-notes">Self-serve portal at <a href="/marketing" style="color:#818cf8;">/marketing</a>: a restaurant creates a profile, commits a required deal, and starts a $20 one-time pilot to become a featured HeartStrings date location. Payments run in Stripe test mode during the pilot. Every paid signup passes a manual review gate before it can appear in the app &mdash; nothing auto-publishes.</span>
        </div>

        <div class="st-row">
          <span class="st-name"><a href="/research">ByteLite Research</a></span>
          <span><span class="badge badge-research">Private research</span></span>
          <span class="st-notes">Private deterministic infrastructure research. No public product, API, or published benchmark result. Mechanisms not public.</span>
        </div>

        <div class="st-row">
          <span class="st-name"><a href="/research#deep-kore">Deep Kore / AIya</a></span>
          <span><span class="badge badge-research">Private research</span></span>
          <span class="st-notes">Private reasoning research and guide concept. Not a public AI product. Architecture not disclosed.</span>
        </div>

        <div class="st-row">
          <span class="st-name">ByteSight</span>
          <span><span class="badge badge-planned">Early research</span></span>
          <span class="st-notes">Private media tooling research. No public product. Details intentionally not public.</span>
        </div>

        <div class="st-row">
          <span class="st-name"><a href="/architecture">Architecture Page</a></span>
          <span><span class="badge badge-active">Public</span></span>
          <span class="st-notes">Public informational page. Explains the system stack and claim boundaries without disclosing mechanisms. Not a product and not a production claim.</span>
        </div>

        <div class="st-row">
          <span class="st-name">Website</span>
          <span><span class="badge badge-active">Public</span></span>
          <span class="st-notes">Public information site. Product claims are separated from research status.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Infrastructure status -->
  <section class="section">
    <div class="container">
      <h2 style="margin-bottom:2rem;">Availability</h2>
      <div class="st-table">
        <div class="st-row st-header">
          <span>Item</span>
          <span>Status</span>
          <span>Notes</span>
        </div>
        <div class="st-row">
          <span class="st-name">Public API</span>
          <span><span class="badge badge-none">Not available</span></span>
          <span class="st-notes">No public API exists. Contact for partnership or research inquiries.</span>
        </div>
        <div class="st-row">
          <span class="st-name">App Store Listing</span>
          <span><span class="badge badge-none">Not available</span></span>
          <span class="st-notes">HeartStrings App is not listed in any public app store.</span>
        </div>
        <div class="st-row">
          <span class="st-name">Restaurant promotion portal</span>
          <span><span class="badge badge-active">Public &middot; pilot</span></span>
          <span class="st-notes">Live at thebytelite.com/marketing (signup) and api.thebytelite.com (backend). Pilot payments are in Stripe test mode until live activation; a manual review gate controls whether an approved restaurant appears in the app.</span>
        </div>
        <div class="st-row">
          <span class="st-name">Independent Benchmark</span>
          <span><span class="badge badge-none">Not available</span></span>
          <span class="st-notes">No independent benchmark of ByteLite research exists publicly. Research continues privately.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Not yet available -->
  <section class="section section-alt">
    <div class="container" style="max-width:760px;">
      <h2 style="margin-bottom:1.5rem;">Not Yet Available</h2>
      <p style="margin-bottom:1.75rem;font-size:1.0625rem;">The following do not exist as public products or services. They are explicitly not claimed.</p>
      <div class="st-unavailable">
        <div class="st-un-item">&#10005; Public retail purchase of HeartStrings Play</div>
        <div class="st-un-item">&#10005; HeartStrings App on any public app store</div>
        <div class="st-un-item">&#10005; Public ByteLite infrastructure product</div>
        <div class="st-un-item">&#10005; Public API of any kind</div>
        <div class="st-un-item">&#10005; Published independent verification of research results</div>
        <div class="st-un-item">&#10005; Public Deep Kore / AIya AI product</div>
        <div class="st-un-item">&#10005; Public ByteSight product</div>
        <div class="st-un-item">&#10005; Public AI product of any kind</div>
        <div class="st-un-item">&#10005; Public mechanism disclosure</div>
        <div class="st-un-item">&#10005; Production compression product</div>
        <div class="st-un-item">&#10005; Finished AGI product</div>
      </div>
    </div>
  </section>

  <!-- Company info -->
  <section class="section">
    <div class="container" style="max-width:760px;">
      <h2 style="margin-bottom:1.5rem;">Company Information</h2>
      <div class="st-table">
        <div class="st-row"><span class="st-name">Company</span><span colspan="2" style="color:#a0a8c0;">ByteLite LLC</span></div>
        <div class="st-row"><span class="st-name">Location</span><span colspan="2" style="color:#a0a8c0;">Helena, Montana, USA</span></div>
        <div class="st-row"><span class="st-name">Founded</span><span colspan="2" style="color:#a0a8c0;">2024</span></div>
        <div class="st-row"><span class="st-name">Structure</span><span colspan="2" style="color:#a0a8c0;">Solo-founder LLC</span></div>
        <div class="st-row"><span class="st-name">Public contact</span><span colspan="2"><a href="/contact" style="color:#818cf8;">Contact page</a></span></div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>

.st-hero { padding: 5rem 0 3.5rem; }
.st-hero h1 { max-width: 480px; }
.st-sub { max-width: 560px; margin-top: 1rem; font-size: 1.0625rem; color: #7b829e; line-height: 1.7; }
.st-table {
  background: #0d1120; border: 1px solid #1a2235;
  border-radius: .75rem; overflow: hidden;
}
.st-row {
  display: grid; grid-template-columns: 1.5fr 1.2fr 3fr;
  gap: 1.5rem; padding: 1.125rem 1.5rem;
  border-bottom: 1px solid #1a2235;
  align-items: start;
}
.st-row:last-child { border-bottom: none; }
.st-header {
  background: #111828; font-size: .75rem; font-weight: 600;
  letter-spacing: .08em; text-transform: uppercase; color: #4a5068;
}
.st-name { font-size: .9375rem; font-weight: 500; color: #e4e7f2; }
.st-name a { color: #818cf8; }
.st-name a:hover { color: #a5b4fc; }
.st-notes { font-size: .875rem; color: #7b829e; line-height: 1.6; }
.st-unavailable {
  background: #0d1120; border: 1px solid #1a2235;
  border-radius: .75rem; padding: 1.75rem;
  display: flex; flex-direction: column; gap: .75rem;
}
.st-un-item { font-size: .9375rem; color: #7b829e; }
.st-un-item { color: #555e7a; }
@media (max-width: 767px) {
  .st-row { grid-template-columns: 1fr; gap: .625rem; }
  .st-header { display: none; }
  .st-name { color: #e4e7f2; font-weight: 600; }
}

</style>
