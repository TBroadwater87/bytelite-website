---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Status - ByteLite LLC Products"
  description="Current status of HeartStrings Play, HeartStrings App, ByteLite compression, and Deep Kore / AIya research. Honest, up-to-date, no hype."
  keywords={["HeartStrings Play status", "HeartStrings App status", "ByteLite status", "Deep Kore status", "product roadmap", "development status"]}
>
  <div class="updated-bar">Last updated: April 2026</div>

  <section class="status-page">
    <div class="container">

      <div class="page-hero">
        <h1 class="page-title">Status Board</h1>
        <p class="page-sub">What is live, what is in development, what is planned. Updated as things change.</p>
      </div>

      <!-- KNOWN LIMITATIONS CALLOUT -->
      <div class="limits-callout">
        This status board reflects the current engineering state as of the last update. Claims are measured against internal test suites and reference corpora. Independent verification and peer review are targeted for 2026.
      </div>

      <!-- LAUNCH ORDER CONTEXT -->
      <div class="launch-context">
        <div class="launch-note">
          <span class="launch-label">Launch Order</span>
          <span class="launch-flow">
            HeartStrings Play (first)
            <span class="arrow">--&gt;</span>
            HeartStrings App (companion)
            <span class="arrow">--&gt;</span>
            ByteLite API (enterprise)
            <span class="arrow">--&gt;</span>
            Deep Kore (long-term research)
          </span>
        </div>
      </div>

      <!-- 4-COLUMN STATUS TABLES -->
      <div class="status-grid">

        <!-- HeartStrings Play -->
        <div class="status-col">
          <div class="col-header col-header--play">
            <div class="col-title-row">
              <h2>HeartStrings Play</h2>
              <span class="col-badge launch">Pre-Launch</span>
            </div>
          </div>
          <div class="col-body">
            <div class="status-row">
              <span class="item-name">Game Board Design</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Card Tier Structure (6 tiers)</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Character Design (AIya and AIon — Deep Kore / App only)</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">A/B Chip Set Design (8 chips, dual-faced)</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Consent Cup Design (8 numbered spheres)</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Five Path Space Types (Bond, Tease, Strip, Elixir, Contact)</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Card Count (305 cards — 6 decks × 50 + 5 reference)</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Player Count (2 to 8, single SKU)</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Decree Economy Spec (SKIP / REDRAW, hand cap 2)</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Game Rules and Mechanics</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Card-Writing Spec (all 305 cards authored)</span>
              <span class="badge badge-indev">In Development</span>
            </div>
            <div class="status-row">
              <span class="item-name">Manufacturer RFQ</span>
              <span class="badge badge-indev">In Development</span>
            </div>
            <div class="status-row">
              <span class="item-name">Component Engineering (board, chips, inserts)</span>
              <span class="badge badge-indev">In Development</span>
            </div>
            <div class="status-row">
              <span class="item-name">Physical Prototype</span>
              <span class="badge badge-indev">In Development</span>
            </div>
            <div class="status-row">
              <span class="item-name">Card Deck Print Run</span>
              <span class="badge badge-indev">In Development</span>
            </div>
            <div class="status-row">
              <span class="item-name">Retail / Direct Launch</span>
              <span class="badge badge-planned">Planned</span>
            </div>
          </div>
        </div>

        <!-- HeartStrings App -->
        <div class="status-col">
          <div class="col-header col-header--app">
            <div class="col-title-row">
              <h2>HeartStrings App</h2>
              <span class="col-badge indev">Companion</span>
            </div>
          </div>
          <div class="col-body">
            <div class="status-row">
              <span class="item-name">App Logo and Brand</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Sign In / Onboarding UI</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Profile Architecture</span>
              <span class="badge badge-indev">In Development</span>
            </div>
            <div class="status-row">
              <span class="item-name">Match Scoring Engine</span>
              <span class="badge badge-indev">In Development</span>
            </div>
            <div class="status-row">
              <span class="item-name">AIya / AIon Integration</span>
              <span class="badge badge-indev">In Development</span>
            </div>
            <div class="status-row">
              <span class="item-name">ByteLite Integration</span>
              <span class="badge badge-indev">In Development</span>
            </div>
            <div class="status-row">
              <span class="item-name">Closed Beta (Play purchasers)</span>
              <span class="badge badge-planned">Planned</span>
            </div>
            <div class="status-row">
              <span class="item-name">App Store Launch</span>
              <span class="badge badge-planned">Planned</span>
            </div>
          </div>
        </div>

        <!-- ByteLite -->
        <div class="status-col">
          <div class="col-header col-header--cyan">
            <div class="col-title-row">
              <h2>ByteLite</h2>
            </div>
          </div>
          <div class="col-body">
            <div class="status-row">
              <span class="item-name">Compression Engine (BME)</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">BME Specification Canonical (1,600 lines)</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Modes A through F Locked</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">SDP Two-Byte Format Locked</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Bitwise Normalization Locked</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">510-Sequence Sigma-9 Motion Dictionary</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">1,029-Test Validation Suite Passing</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">SHA-256 Verification</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Patent Filing (Pending)</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Stage Visualizer</span>
              <span class="badge badge-preview">Interactive Preview</span>
            </div>
            <div class="status-row">
              <span class="item-name">Browser Demo</span>
              <span class="badge badge-preview">Interactive Preview</span>
            </div>
            <div class="status-row">
              <span class="item-name">Demo Application</span>
              <span class="badge badge-indev">In Development</span>
            </div>
            <div class="status-row">
              <span class="item-name">Verification Harness</span>
              <span class="badge badge-indev">In Development</span>
            </div>
            <div class="status-row">
              <span class="item-name">Public API</span>
              <span class="badge badge-planned">Planned</span>
            </div>
          </div>
        </div>

        <!-- Deep Kore / AIya -->
        <div class="status-col">
          <div class="col-header col-header--purple">
            <div class="col-title-row">
              <h2>Deep Kore / AIya</h2>
            </div>
          </div>
          <div class="col-body">
            <div class="status-row">
              <span class="item-name">Genesis Goal Keeper</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Pass 1 Complete (ESEE Stages 0-3)</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">703 Regression Tests Passing</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">MCP AIya Ingest Bridge</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Interactive React Blueprint (27 sections)</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Architecture Research</span>
              <span class="badge badge-inprogress">In Progress</span>
            </div>
            <div class="status-row">
              <span class="item-name">AIya and AIon Characters</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">AIya Gallery (Architecture Demo)</span>
              <span class="badge badge-preview">Architecture Demo</span>
            </div>
            <div class="status-row">
              <span class="item-name">AIya Sandbox (Architecture Demo)</span>
              <span class="badge badge-preview">Architecture Demo</span>
            </div>
            <div class="status-row">
              <span class="item-name">Deep Kore Lab (prompt logging live)</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Deep Kore Lab Build: 2026-04-18</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">AIya Public API (pending backend)</span>
              <span class="badge badge-indev">In Development</span>
            </div>
            <div class="status-row">
              <span class="item-name">Academic Papers</span>
              <span class="badge badge-planned">Planned</span>
            </div>
          </div>
        </div>

      </div>

      <!-- KNOWN LIMITATIONS -->
      <div class="limits-block">
        <h2 class="limits-title">Known Limitations</h2>
        <ul class="limits-list">
          <li>HeartStrings Play is in active development. Physical prototype is not yet complete. No retail purchase is available.</li>
          <li>HeartStrings App matching engine is not live. Login UI is designed but the app is not functional yet.</li>
          <li>AIya on the Deep Kore page shows architecture demonstrations, not live AI responses. The runtime (AIya_chat.exe) runs locally on a Windows machine and is not yet publicly deployed. A backend server is required.</li>
          <li>The Deep Kore Lab at /deepkore-lab accepts prompt submissions and logs them for nightly learning. It does not return live AI responses. Public API deployment is pending.</li>
          <li>ByteLite compression results depend on data type and Sigma-9 domain coverage. Random binary data results will not match structured data results.</li>
          <li>The headline figure "1GB to 15 bytes" has been retracted from public-facing pages. Controlled test results on structured text corpora are under ongoing verification. Full S-formula results are pending independent review.</li>
          <li>Academic verification papers have not been published. Peer review is planned for 2026.</li>
        </ul>
      </div>

      <!-- CONTACT -->
      <div class="contact-row">
        <p>Reach out at <a href="mailto:info@thebytelite.com" class="contact-link">info@thebytelite.com</a> for HeartStrings Play interest, enterprise ByteLite discussions, or to follow specific development.</p>
        <a href="/contact" class="contact-btn">Contact Page</a>
      </div>

    </div>
  </section>
</Layout>

<style>
  .updated-bar {
    background: rgba(236,72,153,0.05);
    border-bottom: 1px solid rgba(236,72,153,0.15);
    text-align: center;
    padding: 0.45rem 1rem;
    font-size: 0.78rem;
    color: rgba(236,72,153,0.65);
    letter-spacing: 0.03em;
  }

  .status-page {
    padding: 3.5rem 0 5rem;
    background: var(--color-bg-darker);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .page-hero {
    text-align: center;
    margin-bottom: 2rem;
  }

  .page-title {
    font-size: 2.75rem;
    font-weight: 800;
    margin: 0 0 0.65rem;
    background: linear-gradient(135deg, #EC4899 0%, #00D4FF 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-sub {
    font-size: 1rem;
    color: var(--color-text-dim);
    margin: 0 auto;
    max-width: 520px;
    line-height: 1.55;
  }

  /* Known Limitations Callout */
  .limits-callout {
    max-width: 800px;
    margin: 0 auto 1.5rem;
    padding: 0.875rem 1.25rem;
    background: rgba(0, 212, 255, 0.04);
    border: 1px solid rgba(0, 212, 255, 0.12);
    border-radius: 8px;
    font-size: 0.8125rem;
    color: rgba(224, 224, 224, 0.55);
    line-height: 1.6;
    text-align: center;
  }

  /* Launch context bar */
  .launch-context {
    margin-bottom: 2rem;
    display: flex;
    justify-content: center;
  }

  .launch-note {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1.5rem;
    background: rgba(236, 72, 153, 0.05);
    border: 1px solid rgba(236, 72, 153, 0.2);
    border-radius: 10px;
  }

  .launch-label {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(236, 72, 153, 0.7);
  }

  .launch-flow {
    font-size: 0.8125rem;
    color: rgba(224, 224, 224, 0.6);
    display: flex;
    align-items: center;
    gap: 0.625rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .arrow {
    color: rgba(236, 72, 153, 0.4);
    font-weight: 700;
  }

  /* 4-column grid */
  .status-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.1rem;
    margin-bottom: 3.5rem;
    align-items: start;
  }

  .status-col {
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
  }

  .col-header {
    padding: 0.875rem 1.25rem 0.75rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .col-title-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .col-header h2 {
    font-size: 0.95rem;
    font-weight: 800;
    margin: 0;
  }

  .col-badge {
    font-size: 0.56rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    padding: 0.15rem 0.45rem;
    border-radius: 100px;
  }

  .col-badge.launch { background: rgba(236,72,153,0.15); color: #EC4899; border: 1px solid rgba(236,72,153,0.4); }
  .col-badge.indev  { background: rgba(168,85,247,0.1); color: #A855F7; border: 1px solid rgba(168,85,247,0.3); }

  .col-header--play   { background: rgba(236,72,153,0.07); }
  .col-header--play h2 { color: #EC4899; }
  .col-header--app    { background: rgba(251,113,133,0.06); }
  .col-header--app h2  { color: #FB7185; }
  .col-header--cyan   { background: rgba(0,212,255,0.06); }
  .col-header--cyan h2 { color: #00D4FF; }
  .col-header--purple { background: rgba(168,85,247,0.06); }
  .col-header--purple h2 { color: #A855F7; }

  .col-body {
    padding: 0.5rem 0;
  }

  .status-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.55rem 1rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background 0.15s ease;
  }

  .status-row:last-child {
    border-bottom: none;
  }

  .status-row:hover {
    background: rgba(255,255,255,0.02);
  }

  .item-name {
    font-size: 0.8125rem;
    color: var(--color-text);
    font-weight: 500;
    line-height: 1.3;
  }

  /* Badges */
  .badge {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.16rem 0.48rem;
    border-radius: 20px;
    white-space: nowrap;
    border: 1px solid;
    flex-shrink: 0;
  }

  .badge-live {
    background: rgba(34,197,94,0.12);
    color: #22C55E;
    border-color: rgba(34,197,94,0.35);
  }

  .badge-preview {
    background: rgba(0,212,255,0.08);
    color: #00D4FF;
    border-color: rgba(0,212,255,0.3);
  }

  .badge-inprogress {
    background: rgba(168,85,247,0.08);
    color: #A855F7;
    border-color: rgba(168,85,247,0.3);
  }

  .badge-indev {
    background: rgba(168,85,247,0.08);
    color: #A855F7;
    border-color: rgba(168,85,247,0.3);
  }

  .badge-planned {
    background: rgba(255,255,255,0.04);
    color: rgba(224,224,224,0.45);
    border-color: rgba(224,224,224,0.12);
  }

  /* Known limitations */
  .limits-block {
    background: rgba(10,14,39,0.6);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: 2rem 2.25rem;
    margin-bottom: 2.5rem;
  }

  .limits-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 1rem;
  }

  .limits-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .limits-list li {
    color: var(--color-text-dim);
    font-size: 0.875rem;
    line-height: 1.55;
    padding-left: 1.3rem;
    position: relative;
  }

  .limits-list li::before {
    content: '--';
    position: absolute;
    left: 0;
    color: rgba(224,224,224,0.25);
    font-size: 0.75rem;
  }

  /* Contact row */
  .contact-row {
    text-align: center;
    padding: 2rem;
    background: linear-gradient(135deg, rgba(236,72,153,0.04) 0%, rgba(0,212,255,0.04) 100%);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .contact-row p {
    font-size: 0.925rem;
    color: var(--color-text-dim);
    margin: 0;
    line-height: 1.5;
  }

  .contact-link {
    color: #EC4899;
    text-decoration: none;
    border-bottom: 1px solid rgba(236,72,153,0.3);
    transition: border-color 0.2s ease;
  }

  .contact-link:hover {
    border-color: #EC4899;
  }

  .contact-btn {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    background: transparent;
    color: #EC4899;
    border: 1px solid rgba(236,72,153,0.4);
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .contact-btn:hover {
    background: rgba(236,72,153,0.1);
    border-color: #EC4899;
  }

  /* Responsive */
  @media (max-width: 1100px) {
    .status-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .status-grid {
      grid-template-columns: 1fr;
    }

    .page-title { font-size: 2rem; }

    .limits-block {
      padding: 1.5rem 1.25rem;
    }

    .contact-row {
      flex-direction: column;
      gap: 1rem;
      padding: 1.5rem 1.25rem;
    }

    .launch-flow {
      flex-direction: column;
      gap: 0.375rem;
      text-align: center;
    }

    .arrow { transform: rotate(90deg); }
  }
</style>
