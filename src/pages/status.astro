---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Status - ByteLite Public Lab"
  description="Current status of ByteLite compression, Deep Kore / AIya research, and HeartStrings platform. Honest, up-to-date, no hype."
  keywords={["ByteLite status", "Deep Kore status", "HeartStrings status", "product roadmap", "development status", "live features"]}
>
  <div class="updated-bar">Last updated: March 2026</div>

  <section class="status-page">
    <div class="container">

      <div class="page-hero">
        <h1 class="page-title">Status Board</h1>
        <p class="page-sub">What is live, what is preview, what is under active development. Updated as things change.</p>
      </div>

      <!-- 3-COLUMN STATUS TABLES -->
      <div class="status-grid">

        <!-- ByteLite -->
        <div class="status-col">
          <div class="col-header col-header--cyan">
            <h2>ByteLite</h2>
          </div>
          <div class="col-body">
            <div class="status-row">
              <span class="item-name">Compression Engine</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Universal Dictionaries</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">SHA-256 Verification</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Patent Filing</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Stage Visualizer</span>
              <span class="badge badge-preview">Interactive Preview</span>
            </div>
            <div class="status-row">
              <span class="item-name">Browser Demo</span>
              <span class="badge badge-preview">Interactive Preview</span>
            </div>
            <div class="status-row">
              <span class="item-name">Demo Application</span>
              <span class="badge badge-indev">In Development</span>
            </div>
            <div class="status-row">
              <span class="item-name">Verification Harness</span>
              <span class="badge badge-indev">In Development</span>
            </div>
            <div class="status-row">
              <span class="item-name">Public API</span>
              <span class="badge badge-planned">Planned</span>
            </div>
          </div>
        </div>

        <!-- Deep Kore / AIya -->
        <div class="status-col">
          <div class="col-header col-header--purple">
            <h2>Deep Kore / AIya</h2>
          </div>
          <div class="col-body">
            <div class="status-row">
              <span class="item-name">Genesis Goal Keeper</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Architecture Research</span>
              <span class="badge badge-inprogress">In Progress</span>
            </div>
            <div class="status-row">
              <span class="item-name">AIya Gallery</span>
              <span class="badge badge-preview">Interactive Preview</span>
            </div>
            <div class="status-row">
              <span class="item-name">AIya Sandbox</span>
              <span class="badge badge-preview">Interactive Preview</span>
            </div>
            <div class="status-row">
              <span class="item-name">AIya Live Interaction</span>
              <span class="badge badge-indev">In Development</span>
            </div>
            <div class="status-row">
              <span class="item-name">Academic Papers</span>
              <span class="badge badge-planned">Planned</span>
            </div>
          </div>
        </div>

        <!-- HeartStrings -->
        <div class="status-col">
          <div class="col-header col-header--pink">
            <h2>HeartStrings</h2>
          </div>
          <div class="col-body">
            <div class="status-row">
              <span class="item-name">Interface Design System</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Compatibility Framework</span>
              <span class="badge badge-live">Live</span>
            </div>
            <div class="status-row">
              <span class="item-name">Interface Gallery</span>
              <span class="badge badge-preview">Interactive Preview</span>
            </div>
            <div class="status-row">
              <span class="item-name">Prototype Flow</span>
              <span class="badge badge-preview">Interactive Preview</span>
            </div>
            <div class="status-row">
              <span class="item-name">Matching Engine</span>
              <span class="badge badge-indev">In Development</span>
            </div>
            <div class="status-row">
              <span class="item-name">Public Beta</span>
              <span class="badge badge-planned">Planned</span>
            </div>
          </div>
        </div>

      </div>

      <!-- KNOWN LIMITATIONS -->
      <div class="limits-block">
        <h2 class="limits-title">Known Limitations</h2>
        <ul class="limits-list">
          <li>ByteLite compression results depend on data type and dictionary coverage. Results on random binary data will not match enwik9 corpus results.</li>
          <li>AIya is currently curated and deterministic only. It is not a live AI system. All responses on this site are pre-written samples.</li>
          <li>HeartStrings matching engine is not yet live. Interface panels are prototype UI only.</li>
          <li>Academic verification papers have not been published. Peer review is planned for 2026.</li>
          <li>No Hutter Prize submission is planned. That framing has been retired.</li>
        </ul>
      </div>

      <!-- CONTACT -->
      <div class="contact-row">
        <p>Reach out at <a href="mailto:info@thebytelite.com" class="contact-link">info@thebytelite.com</a> for enterprise discussions or to follow specific development.</p>
        <a href="/contact" class="contact-btn">Contact Page</a>
      </div>

    </div>
  </section>
</Layout>

<style>
  .updated-bar {
    background: rgba(0,212,255,0.05);
    border-bottom: 1px solid rgba(0,212,255,0.15);
    text-align: center;
    padding: 0.45rem 1rem;
    font-size: 0.78rem;
    color: rgba(0,212,255,0.65);
    letter-spacing: 0.03em;
  }

  .status-page {
    padding: 3.5rem 0 5rem;
    background: var(--color-bg-darker);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .page-hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-title {
    font-size: 2.75rem;
    font-weight: 800;
    margin: 0 0 0.65rem;
    background: linear-gradient(135deg, #00D4FF 0%, #A855F7 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .page-sub {
    font-size: 1rem;
    color: var(--color-text-dim);
    margin: 0;
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.55;
  }

  /* 3-column grid */
  .status-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-bottom: 3.5rem;
    align-items: start;
  }

  .status-col {
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    overflow: hidden;
  }

  .col-header {
    padding: 1rem 1.25rem 0.85rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .col-header h2 {
    font-size: 1.1rem;
    font-weight: 800;
    margin: 0;
  }

  .col-header--cyan { background: rgba(0,212,255,0.06); }
  .col-header--cyan h2 { color: #00D4FF; }
  .col-header--purple { background: rgba(168,85,247,0.06); }
  .col-header--purple h2 { color: #A855F7; }
  .col-header--pink { background: rgba(236,72,153,0.06); }
  .col-header--pink h2 { color: #EC4899; }

  .col-body {
    padding: 0.5rem 0;
  }

  .status-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background 0.15s ease;
  }

  .status-row:last-child {
    border-bottom: none;
  }

  .status-row:hover {
    background: rgba(255,255,255,0.02);
  }

  .item-name {
    font-size: 0.875rem;
    color: var(--color-text);
    font-weight: 500;
    line-height: 1.3;
  }

  /* Badges */
  .badge {
    display: inline-block;
    font-size: 0.64rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.18rem 0.55rem;
    border-radius: 20px;
    white-space: nowrap;
    border: 1px solid;
    flex-shrink: 0;
  }

  .badge-live {
    background: rgba(34,197,94,0.12);
    color: #22C55E;
    border-color: rgba(34,197,94,0.35);
  }

  .badge-preview {
    background: rgba(0,212,255,0.08);
    color: #00D4FF;
    border-color: rgba(0,212,255,0.3);
  }

  .badge-inprogress {
    background: rgba(168,85,247,0.08);
    color: #A855F7;
    border-color: rgba(168,85,247,0.3);
  }

  .badge-indev {
    background: rgba(168,85,247,0.08);
    color: #A855F7;
    border-color: rgba(168,85,247,0.3);
  }

  .badge-planned {
    background: rgba(255,255,255,0.04);
    color: rgba(224,224,224,0.45);
    border-color: rgba(224,224,224,0.12);
  }

  /* Known limitations */
  .limits-block {
    background: rgba(10,14,39,0.6);
    border: 1px solid rgba(255,255,255,0.07);
    border-radius: 12px;
    padding: 2rem 2.25rem;
    margin-bottom: 2.5rem;
  }

  .limits-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 1.1rem;
  }

  .limits-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .limits-list li {
    color: var(--color-text-dim);
    font-size: 0.875rem;
    line-height: 1.55;
    padding-left: 1.3rem;
    position: relative;
  }

  .limits-list li::before {
    content: '--';
    position: absolute;
    left: 0;
    color: rgba(224,224,224,0.25);
    font-size: 0.75rem;
  }

  /* Contact row */
  .contact-row {
    text-align: center;
    padding: 2rem;
    background: linear-gradient(135deg, rgba(0,212,255,0.04) 0%, rgba(168,85,247,0.04) 100%);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .contact-row p {
    font-size: 0.925rem;
    color: var(--color-text-dim);
    margin: 0;
    line-height: 1.5;
  }

  .contact-link {
    color: #00D4FF;
    text-decoration: none;
    border-bottom: 1px solid rgba(0,212,255,0.3);
    transition: border-color 0.2s ease;
  }

  .contact-link:hover {
    border-color: #00D4FF;
  }

  .contact-btn {
    display: inline-block;
    padding: 0.6rem 1.5rem;
    background: transparent;
    color: #00D4FF;
    border: 1px solid rgba(0,212,255,0.4);
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    transition: all 0.2s ease;
    white-space: nowrap;
  }

  .contact-btn:hover {
    background: rgba(0,212,255,0.1);
    border-color: #00D4FF;
  }

  /* Responsive */
  @media (max-width: 900px) {
    .status-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .page-title { font-size: 2rem; }

    .limits-block {
      padding: 1.5rem 1.25rem;
    }

    .contact-row {
      flex-direction: column;
      gap: 1rem;
      padding: 1.5rem 1.25rem;
    }
  }
</style>
