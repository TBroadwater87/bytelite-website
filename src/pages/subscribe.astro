---
import Layout from '../layouts/Layout.astro';
import SubscribeForm from '../components/SubscribeForm.astro';
---

<Layout
  title="Subscribe - ByteLite LLC"
  description="Get updates on ByteLite, Deep Kore / AIya, and HeartStrings. Notified when demos launch and milestones are reached."
>

  <section class="sub-page">
    <div class="sub-container">
      <div class="sub-header">
        <h1>Stay in the Loop</h1>
        <p>Updates go out when milestones are reached. No spam.</p>
      </div>
      <SubscribeForm variant="compact" />

      <div class="sub-links">
        <p>Want the current picture now?</p>
        <div class="link-row">
          <a href="/status">View Status Board</a>
          <a href="/demo">Try the Demos</a>
          <a href="/ethics">Read the Genesis Manifesto</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .sub-page {
    padding: 3rem 0 4rem;
    background: var(--color-bg-darker);
    min-height: 60vh;
  }

  .sub-container {
    max-width: 560px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .sub-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .sub-header h1 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .sub-header p {
    color: rgba(224, 224, 224, 0.6);
    font-size: 0.9rem;
  }

  .sub-links {
    margin-top: 2.5rem;
    text-align: center;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .sub-links p {
    font-size: 0.85rem;
    color: rgba(224, 224, 224, 0.45);
    margin-bottom: 0.75rem;
  }

  .link-row {
    display: flex;
    gap: 1.25rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .link-row a {
    font-size: 0.82rem;
    color: #00D4FF;
    text-decoration: none;
    opacity: 0.8;
    transition: opacity 0.2s;
  }

  .link-row a:hover { opacity: 1; }
</style>
