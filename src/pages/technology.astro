---
import Layout from '../layouts/Layout.astro';
import InteractiveCompressionDemo from '../components/InteractiveCompressionDemo.tsx';
---

<Layout
  title="ByteLite Technology - Bit Motion Encoding Compression Engine"
  description="ByteLite compression: Bit Motion Encoding over the Sigma-9 alphabet. Deterministic, lossless, structured-data compression. Payload convergence to under 64 bytes on structured text corpora. S-formula verification in progress. Patent pending."
  keywords={["Bit Motion Encoding", "Sigma-9 alphabet", "BME compression", "structured data compression", "lossless compression", "ByteLite technology"]}
  schemaType="Article"
>

  <!-- Banner -->
  <img src="/ByteLite_Banner.png" style="width:100%; height:auto; max-height:340px; object-fit:cover; display:block;" alt="ByteLite - Bit Motion Encoding compression">

  <section class="tech-wrap">
    <div class="container">

      <!-- Hero -->
      <div class="hero-block">
        <h1>Not Incremental. Architectural.</h1>
        <p class="hero-sub">ByteLite is a deterministic lossless compression system built on Bit Motion Encoding over the Sigma-9 alphabet. Every byte normalizes bitwise. Every round narrows toward a terminal payload. The model travels with the data. Controlled test on structured text corpora: payload convergence to under 64 bytes. Full S-formula (payload plus decompressor) under independent verification. Results vary by data type.</p>
        <div class="hero-ctas">
          <a href="/demo" class="btn btn-primary">Interactive Demo</a>
          <a href="/status" class="btn btn-outline">Current Status</a>
        </div>
        <p class="patent-tag">Patent pending &nbsp;|&nbsp; Lossless, SHA-256 verified</p>
      </div>

      <!-- File Playground -->
      <div class="section-block">
        <div class="section-label">File Playground</div>
        <h2>Try It</h2>
        <div class="demo-wrap">
          <InteractiveCompressionDemo client:load />
        </div>
      </div>

      <!-- How It Works -->
      <div class="section-block">
        <div class="section-label">How It Works</div>
        <h2>Three Stages in the Compression Pipeline</h2>
        <div class="how-grid">
          <div class="how-card">
            <div class="how-num">01</div>
            <h3>Normalization</h3>
            <ul class="tight-list">
              <li>Source stream enters the engine</li>
              <li>Bitwise normalization into canonical form</li>
              <li>Source bit 0 becomes a single normalized 0. Source bit 1 expands to the eight-bit sequence 00000001</li>
              <li>Stream is now deterministic across any input</li>
            </ul>
          </div>
          <div class="how-card">
            <div class="how-num">02</div>
            <h3>Motion Encoding</h3>
            <ul class="tight-list">
              <li>Bit Motion Encoding operates over the Sigma-9 alphabet</li>
              <li>Each motion value is a REF-relative successor choice</li>
              <li>510-sequence motion dictionary governs choices</li>
              <li>Mode Ladder A through F governs which representation is active</li>
            </ul>
          </div>
          <div class="how-card how-card-final">
            <div class="how-num">03</div>
            <h3>Convergence</h3>
            <ul class="tight-list">
              <li>Sequential rounds reduce structural redundancy</li>
              <li>Payload reaches terminal form</li>
              <li>Output: compressed payload plus round-count in 255-carry format</li>
              <li>Decompressor replays motions in reverse to reconstruct bit-for-bit</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Stage Visualizer -->
      <div class="section-block">
        <div class="section-label">Compression Pipeline</div>
        <h2>Round / Stage Reduction</h2>
        <div class="stage-grid">
          <div class="stage-card">
            <div class="stage-num">Stage 1</div>
            <div class="stage-name">Normalization</div>
            <div class="stage-size">input</div>
            <div class="stage-desc">bitwise normalization</div>
            <div class="stage-bar-wrap"><div class="stage-bar" style="width:100%; background:rgba(0,212,255,0.7);"></div></div>
          </div>
          <div class="stage-card">
            <div class="stage-num">Stage 2</div>
            <div class="stage-name">Motion Encoding</div>
            <div class="stage-size">reduced</div>
            <div class="stage-desc">REF-relative motion over Sigma-9</div>
            <div class="stage-bar-wrap"><div class="stage-bar" style="width:42%; background:rgba(0,212,255,0.6);"></div></div>
          </div>
          <div class="stage-card">
            <div class="stage-num">Stage 3</div>
            <div class="stage-name">Mode Convergence</div>
            <div class="stage-size">further reduced</div>
            <div class="stage-desc">Mode Ladder A-F active</div>
            <div class="stage-bar-wrap"><div class="stage-bar" style="width:12%; background:rgba(168,85,247,0.7);"></div></div>
          </div>
          <div class="stage-card stage-final">
            <div class="stage-num">Stage 4</div>
            <div class="stage-name">Output Key</div>
            <div class="stage-size stage-size-final">compact key</div>
            <div class="stage-desc">controlled test: under 64 bytes on structured text</div>
            <div class="stage-bar-wrap"><div class="stage-bar" style="width:2%; background:rgba(0,212,255,1); min-width:6px;"></div></div>
          </div>
        </div>
        <p class="stage-note">Educational pipeline visualization. Relative proportions are illustrative. Controlled test on structured text corpora: payload convergence to under 64 bytes. Full S-formula (payload plus decompressor) under independent verification. Results vary by data type. Patent pending.</p>
      </div>

      <!-- S-Formula Note -->
      <div class="section-block">
        <div class="section-label">Measurement</div>
        <h2>How Results Are Measured</h2>
        <div class="footnote-box">
          <p>Compression ratios are measured against the Hutter Prize S-formula, which sums the compressed payload size and the decompressor binary size. Dictionary tables, when required, count in S. The S-formula is the standard for the Hutter Prize competition on the enwik9 corpus.</p>
          <p>Random binary data outside the Sigma-9 alphabet domain receives no advantage from BME. Results reported on this site reflect structured text corpora. Performance on other data types varies.</p>
        </div>
      </div>

      <!-- What Is Real Today -->
      <div class="section-block">
        <div class="section-label">Transparency</div>
        <h2>What Is Real Today</h2>
        <div class="reality-grid">
          <div class="reality-box box-green">
            <div class="box-title">Live Now</div>
            <ul class="tight-list">
              <li>BME specification canonical (1,600 lines)</li>
              <li>Lossless compression engine</li>
              <li>SHA-256 output verification</li>
              <li>Patent pending</li>
            </ul>
          </div>
          <div class="reality-box box-cyan">
            <div class="box-title">Interactive Preview</div>
            <ul class="tight-list">
              <li>Browser-based demo at /demo</li>
              <li>Educational stage visualizer</li>
              <li>Sample determinism proof</li>
            </ul>
          </div>
          <div class="reality-box box-purple">
            <div class="box-title">In Development</div>
            <ul class="tight-list">
              <li>Demonstration application</li>
              <li>Public verification harness</li>
              <li>Performance benchmarking suite</li>
            </ul>
          </div>
          <div class="reality-box box-gray">
            <div class="box-title">Planned</div>
            <ul class="tight-list">
              <li>Public API access</li>
              <li>Enterprise licensing portal</li>
              <li>Open-source verifier</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Developer API Preview -->
      <div class="section-block api-section">
        <div class="section-label">Planned API Interface</div>
        <h2>Integration Interface</h2>
        <p class="api-note">API access is in planning. Enterprise partnerships available now.</p>
        <div class="api-block">
          <div class="api-line api-method">POST /api/v1/compress</div>
          <div class="api-line api-header">Content-Type: application/json</div>
          <div class="api-line">&nbsp;</div>
          <div class="api-line api-brace">&#123;</div>
          <div class="api-line api-field">&nbsp;&nbsp;"data": "&lt;base64-encoded-input&gt;",</div>
          <div class="api-line api-field">&nbsp;&nbsp;"mode": "sigma9"</div>
          <div class="api-line api-brace">&#125;</div>
          <div class="api-line">&nbsp;</div>
          <div class="api-line api-comment">// Response</div>
          <div class="api-line api-brace">&#123;</div>
          <div class="api-line api-field">&nbsp;&nbsp;"blc_payload": "a4f8c2b7...",</div>
          <div class="api-line api-field">&nbsp;&nbsp;"original_bytes": 1000000,</div>
          <div class="api-line api-field">&nbsp;&nbsp;"compressed_bytes": 412,</div>
          <div class="api-line api-field">&nbsp;&nbsp;"engine_version": "bme-1.0",</div>
          <div class="api-line api-field">&nbsp;&nbsp;"rounds": 7,</div>
          <div class="api-line api-field">&nbsp;&nbsp;"sha256_input": "9f86d081...",</div>
          <div class="api-line api-field">&nbsp;&nbsp;"sha256_roundtrip": "9f86d081..."</div>
          <div class="api-line api-brace">&#125;</div>
        </div>
      </div>

      <!-- CTA Row -->
      <div class="cta-row">
        <a href="/demo" class="btn btn-primary">Try Demo</a>
        <a href="/status" class="btn btn-outline">View Status</a>
        <a href="/contact" class="btn btn-outline">Contact Us</a>
      </div>

    </div>
  </section>
</Layout>

<style>
  .tech-wrap {
    background: var(--color-bg-darker);
    padding: 3rem 0;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Hero */
  .hero-block {
    text-align: center;
    margin-bottom: 4rem;
  }

  .hero-block h1 {
    font-size: 2rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: rgba(224, 224, 224, 0.75);
    max-width: 740px;
    margin: 0 auto 1.5rem;
    line-height: 1.7;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .patent-tag {
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    color: rgba(224, 224, 224, 0.4);
    font-family: monospace;
    margin: 0;
  }

  /* Section blocks */
  .section-block {
    margin-bottom: 4rem;
  }

  .section-label {
    display: inline-block;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-deepkore);
    background: rgba(168, 85, 247, 0.1);
    border: 1px solid rgba(168, 85, 247, 0.3);
    border-radius: 4px;
    padding: 0.2rem 0.65rem;
    margin-bottom: 0.65rem;
  }

  .section-block h2 {
    font-size: 1.6rem;
    color: var(--color-primary);
    margin-bottom: 1.5rem;
  }

  /* Demo wrap */
  .demo-wrap {
    background: rgba(10, 14, 39, 0.6);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 12px;
    padding: 2rem;
  }

  /* How It Works */
  .how-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .how-card {
    background: rgba(10, 14, 39, 0.7);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 10px;
    padding: 1.5rem;
    transition: border-color 0.2s ease;
  }

  .how-card:hover {
    border-color: var(--color-primary);
  }

  .how-card-final {
    border-color: rgba(168, 85, 247, 0.3);
  }

  .how-card-final:hover {
    border-color: var(--color-deepkore);
  }

  .how-num {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    color: rgba(224, 224, 224, 0.35);
    font-family: monospace;
    margin-bottom: 0.4rem;
  }

  .how-card h3 {
    font-size: 1rem;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .how-card-final h3 {
    color: var(--color-deepkore);
  }

  /* Tight list shared */
  .tight-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tight-list li {
    font-size: 0.875rem;
    color: rgba(224, 224, 224, 0.7);
    padding-left: 1.2rem;
    position: relative;
    margin-bottom: 0.4rem;
    line-height: 1.5;
  }

  .tight-list li::before {
    content: "-";
    position: absolute;
    left: 0;
    color: rgba(0, 212, 255, 0.5);
    font-family: monospace;
  }

  /* Stage Visualizer */
  .stage-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 1.25rem;
    margin-bottom: 1rem;
  }

  .stage-card {
    background: var(--color-bg-dark);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 10px;
    padding: 1.25rem;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .stage-card:hover {
    transform: translateY(-3px);
    border-color: var(--color-primary);
  }

  .stage-final {
    border-color: rgba(168, 85, 247, 0.35);
  }

  .stage-final:hover {
    border-color: var(--color-deepkore);
  }

  .stage-num {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(224, 224, 224, 0.38);
    margin-bottom: 0.35rem;
  }

  .stage-name {
    font-size: 0.9rem;
    font-weight: 700;
    color: #E0E0E0;
    margin-bottom: 0.6rem;
  }

  .stage-size {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-primary);
    font-family: monospace;
    margin-bottom: 0.25rem;
  }

  .stage-size-final {
    color: var(--color-deepkore);
  }

  .stage-desc {
    font-size: 0.75rem;
    color: rgba(224, 224, 224, 0.5);
    margin-bottom: 1rem;
  }

  .stage-bar-wrap {
    height: 5px;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 3px;
    overflow: hidden;
  }

  .stage-bar {
    height: 100%;
    border-radius: 3px;
  }

  .stage-note {
    font-size: 0.78rem;
    color: rgba(224, 224, 224, 0.4);
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.5;
  }

  /* Reality Grid */
  .reality-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .reality-box {
    background: var(--color-bg-dark);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    border-width: 1px;
    border-style: solid;
  }

  .box-green  { border-color: rgba(34, 197, 94, 0.4); }
  .box-cyan   { border-color: rgba(0, 212, 255, 0.4); }
  .box-purple { border-color: rgba(168, 85, 247, 0.4); }
  .box-gray   { border-color: rgba(224, 224, 224, 0.18); }

  .box-title {
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .box-green  .box-title { color: #22c55e; }
  .box-cyan   .box-title { color: var(--color-primary); }
  .box-purple .box-title { color: var(--color-deepkore); }
  .box-gray   .box-title { color: rgba(224, 224, 224, 0.45); }

  /* API Section */
  .api-section {
    background: var(--color-bg-darker);
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 14px;
    padding: 2rem;
  }

  .api-note {
    font-size: 0.9rem;
    color: rgba(224, 224, 224, 0.55);
    margin-bottom: 1.25rem;
    line-height: 1.5;
  }

  .api-block {
    background: var(--color-bg-darker);
    border: 1px solid rgba(0, 212, 255, 0.15);
    border-radius: 8px;
    padding: 1.25rem 1.5rem;
    font-family: monospace;
    font-size: 0.85rem;
    overflow-x: auto;
  }

  .api-line { line-height: 1.65; }
  .api-method  { color: var(--color-primary); font-weight: 700; }
  .api-header  { color: rgba(224, 224, 224, 0.5); }
  .api-brace   { color: #E0E0E0; }
  .api-field   { color: rgba(224, 224, 224, 0.8); }
  .api-comment { color: var(--color-deepkore); }

  /* Buttons */
  .btn {
    padding: 0.65rem 1.5rem;
    border-radius: 7px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.25s ease;
    display: inline-block;
  }

  .btn-primary {
    background: var(--color-primary);
    color: var(--color-bg-dark);
  }

  .btn-primary:hover {
    background: #00B8E6;
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 212, 255, 0.25);
  }

  .btn-outline {
    background: transparent;
    color: var(--color-primary);
    border: 1px solid rgba(0, 212, 255, 0.5);
  }

  .btn-outline:hover {
    border-color: var(--color-primary);
    background: rgba(0, 212, 255, 0.08);
  }

  /* CTA Row */
  .cta-row {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    padding: 2rem 0 1rem;
    border-top: 1px solid rgba(0, 212, 255, 0.1);
    margin-top: 1rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero-block h1 { font-size: 1.65rem; }
    .section-block h2 { font-size: 1.35rem; }
    .how-grid { grid-template-columns: 1fr; }
    .reality-grid { grid-template-columns: 1fr; }
    .api-block { font-size: 0.76rem; padding: 1rem; }
    .api-section { padding: 1.5rem 1.25rem; }
  }

  @media (max-width: 480px) {
    .stage-grid { grid-template-columns: 1fr 1fr; }
  }

  .footnote-box {
    background: rgba(168, 85, 247, 0.06);
    border: 1px solid rgba(168, 85, 247, 0.2);
    border-radius: 10px;
    padding: 1.5rem;
  }
  .footnote-box p {
    font-size: 0.875rem;
    color: rgba(224, 224, 224, 0.65);
    line-height: 1.65;
    margin: 0 0 0.875rem;
  }
  .footnote-box p:last-child { margin-bottom: 0; }
</style>
